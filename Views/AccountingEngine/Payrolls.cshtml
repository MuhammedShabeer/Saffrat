@model IEnumerable<Saffrat.Models.Payroll>

@using Saffrat.Resources
@using System.Globalization
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Flexible Payroll Payments");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles{
    <style>
        .payment-stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .payment-stat-card.success {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        }

        .payment-stat-card.warning {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        }

        .payment-stat-card.danger {
            background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        }

        .payment-stat-card h5 {
            margin: 0 0 10px 0;
            font-size: 14px;
            opacity: 0.9;
        }

        .payment-stat-card .amount {
            font-size: 24px;
            font-weight: bold;
        }

        .payment-table {
            font-size: 14px;
        }

        .payment-badge {
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }

        .badge-unpaid {
            background-color: #f8d7da;
            color: #721c24;
        }

        .badge-partial {
            background-color: #fff3cd;
            color: #856404;
        }

        .badge-paid {
            background-color: #d4edda;
            color: #155724;
        }

        .progress-container {
            margin-top: 10px;
        }

        .progress-text {
            font-size: 12px;
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
        }

        .action-btn-group {
            display: flex;
            gap: 5px;
        }

        .action-btn-group .btn {
            padding: 4px 8px;
            font-size: 12px;
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: #999;
        }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 10px;
            opacity: 0.5;
        }
    </style>
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        <i class="fas fa-hand-holding-usd me-2"></i>@Localize("Flexible Payroll Payments")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item"><a asp-controller="AccountingEngine" asp-action="Index">@Localize("Accounting")</a></li>
                    <li class="breadcrumb-item">@Localize("Payroll Payments")</li>
                </ul>
            </div>
            <div class="col">
                <div class="float-end">
                    <a asp-controller="HRM" asp-action="Payroll" class="btn btn-primary">
                        <i class="fas fa-arrow-left me-1"></i>@Localize("Back to Payroll")
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Summary Cards -->
<div class="row mb-3">
    <div class="col-md-3">
        <div class="payment-stat-card">
            <h5>@Localize("Total Payrolls")</h5>
            <div class="amount" id="totalPayrolls">0</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="payment-stat-card success">
            <h5>@Localize("Paid")</h5>
            <div class="amount" id="paidPayrolls">0</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="payment-stat-card warning">
            <h5>@Localize("Partially Paid")</h5>
            <div class="amount" id="partialPayrolls">0</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="payment-stat-card danger">
            <h5>@Localize("Unpaid")</h5>
            <div class="amount" id="unpaidPayrolls">0</div>
        </div>
    </div>
</div>

<!-- Payroll List -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title">@Localize("All Payrolls - Flexible Payment View")</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover payment-table" id="payrollTable">
                        <thead>
                            <tr>
                                <th>@Localize("Employee")</th>
                                <th>@Localize("Period")</th>
                                <th>@Localize("Net Salary")</th>
                                <th>@Localize("Payment Progress")</th>
                                <th>@Localize("Status")</th>
                                <th>@Localize("Actions")</th>
                            </tr>
                        </thead>
                        <tbody id="payrollBody">
                            <tr>
                                <td colspan="6" class="empty-state">
                                    <i class="fas fa-spinner fa-spin"></i>
                                    <p>@Localize("Loading payrolls...")</p>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-success text-white border-bottom py-3">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-money-bill-wave me-2"></i>@Localize("Record Flexible Payment")
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="p-4 bg-light border-bottom">
                <div class="row gx-5">
                    <div class="col-md-6">
                        <label class="text-muted small text-uppercase fw-bold mb-1">@Localize("Employee")</label>
                        <div id="modalEmployee" class="h6 mb-0 fw-bold"></div>
                    </div>
                    <div class="col-md-6 border-start">
                        <label class="text-muted small text-uppercase fw-bold mb-1">@Localize("Period")</label>
                        <div id="modalPeriod" class="h6 mb-0 fw-bold"></div>
                    </div>
                </div>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    @Localize("Enter any amount up to the remaining balance. You can make multiple payments.")
                </div>

                <div class="row text-center mb-4">
                    <div class="col-md-4">
                        <div class="bg-light p-3 rounded">
                            <small class="text-muted text-uppercase fw-bold d-block mb-2">@Localize("Net Salary")</small>
                            <h5 id="modalNetSalary" class="mb-0">$0.00</h5>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-light p-3 rounded">
                            <small class="text-muted text-uppercase fw-bold d-block mb-2">@Localize("Total Paid")</small>
                            <h5 id="modalTotalPaid" class="mb-0 text-success">$0.00</h5>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="bg-danger text-white p-3 rounded">
                            <small class="text-uppercase fw-bold d-block mb-2">@Localize("Remaining")</small>
                            <h5 id="modalRemaining" class="mb-0">$0.00</h5>
                        </div>
                    </div>
                </div>

                <div class="border-top pt-4 mb-4">
                    <h6 class="fw-bold mb-3">@Localize("Payment Details")</h6>
                    <form id="paymentForm" novalidate>
                        <div class="mb-3">
                            <label for="paymentAmount" class="form-label fw-bold">@Localize("Payment Amount") <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control" id="paymentAmount" step="0.01" min="0.01" required>
                            </div>
                            <small class="form-text text-muted">@Localize("Maximum Available"): <strong id="maxAmount">$0.00</strong></small>
                        </div>

                        <div class="mb-3">
                            <label for="paymentMethod" class="form-label fw-bold">@Localize("Payment Method") <span class="text-danger">*</span></label>
                            <select class="form-select" id="paymentMethod" required>
                                <option value="">@Localize("Select Payment Method")</option>
                                <option value="Cash">@Localize("Cash")</option>
                                <option value="Bank Transfer">@Localize("Bank Transfer")</option>
                                <option value="Cheque">@Localize("Cheque")</option>
                                <option value="Mobile Money">@Localize("Mobile Money")</option>
                                <option value="Other">@Localize("Other")</option>
                            </select>
                        </div>

                        <div class="mb-0">
                            <label for="paymentNotes" class="form-label fw-bold">@Localize("Notes") </label>
                            <textarea class="form-control" id="paymentNotes" rows="2" placeholder="e.g., Advance payment, Reference #12345"></textarea>
                        </div>
                    </form>
                </div>
                    <div class="modal-footer bg-light py-3">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@Localize("Cancel")</button>
                        <button type="button" class="btn btn-success" onclick="SubmitPayment()">
                            <i class="fas fa-check me-1"></i>@Localize("Record Payment")
                        </button>
                    </div>
        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-info text-white border-bottom py-3">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-receipt me-2"></i>@Localize("Payment History")
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="p-4 bg-light border-bottom">
                <div class="row gx-5">
                    <div class="col-md-6">
                        <label class="text-muted small text-uppercase fw-bold mb-1">@Localize("Employee")</label>
                        <div id="detailEmployee" class="h6 mb-0 fw-bold"></div>
                        <label class="text-muted small text-uppercase fw-bold mb-1 mt-3">@Localize("Period")</label>
                        <div id="detailPeriodText" class="h6 mb-0 fw-bold"></div>
                    </div>
                    <div class="col-md-6 border-start">
                        <label class="text-muted small text-uppercase fw-bold mb-1">@Localize("Status")</label>
                        <div id="detailStatusBadge" class="mb-3"></div>
                        <div class="row text-center">
                            <div class="col-6">
                                <small class="text-muted text-uppercase fw-bold">@Localize("Net Salary")</small>
                                <div id="detailSalary" class="fw-bold">$0.00</div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted text-uppercase fw-bold">@Localize("Total Paid")</small>
                                <div id="detailPaid" class="fw-bold text-success">$0.00</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-body">
                <h6 class="fw-bold mb-3">@Localize("Payment Transactions")</h6>
                <div id="paymentDetailsList" style="max-height: 400px; overflow-y: auto;">
                    <div class="text-center text-muted py-3">
                        <i class="fas fa-spinner fa-spin"></i>
                    </div>
                </div>
                <div class="mt-3 p-3 bg-warning bg-opacity-10 rounded border border-warning border-opacity-25">
                    <small class="text-muted"><strong>@Localize("Remaining Balance"):</strong> <span id="detailRemainingText" class="text-warning fw-bold">$0.00</span></small>
                </div>
            </div>
            <div class="modal-footer bg-light py-3">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localize("Close")</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        let currentPayrollId = 0;

        // Format currency with proper decimal places
        function formatCurrency(value) {
            if (!value) value = 0;
            return parseFloat(value).toLocaleString(undefined, { 
                minimumFractionDigits: 2, 
                maximumFractionDigits: 2 
            });
        }

        // Load payrolls on page load
        document.addEventListener('DOMContentLoaded', function () {
            LoadPayrolls();
        });

        function LoadPayrolls() {
            fetch('/AccountingEngine/GetPayrollsList')
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') {
                        DisplayPayrolls(data.data);
                    } else {
                        ShowAlert('error', data.message || 'Failed to load payrolls');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    ShowAlert('error', 'Failed to load payrolls');
                });
        }

        function DisplayPayrolls(payrolls) {
            const tbody = document.getElementById('payrollBody');
            let stats = { total: 0, paid: 0, partial: 0, unpaid: 0 };

            if (!payrolls || payrolls.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="empty-state">
                            <i class="fas fa-inbox"></i>
                            <p>@Localize("No payrolls found")</p>
                        </td>
                    </tr>
                `;
                return;
            }

            let html = '';

            payrolls.forEach(payroll => {
                const status = payroll.paymentStatus || 'Unpaid';
                const statusClass = status === 'Paid' ? 'badge-paid' : 
                                  status === 'PartiallyPaid' ? 'badge-partial' : 'badge-unpaid';

                const paidPercent = payroll.netSalary > 0 ? 
                    Math.round((payroll.totalAmountPaid / payroll.netSalary) * 100) : 0;

                stats.total++;
                if (status === 'Paid') stats.paid++;
                else if (status === 'PartiallyPaid') stats.partial++;
                else stats.unpaid++;

                html += `
                    <tr>
                        <td>
                            <strong>${payroll.employee.name}</strong><br>
                            <small class="text-muted">EMP-${payroll.employee.id}</small>
                        </td>
                        <td>${payroll.month}/${payroll.year}</td>
                        <td><strong>$${formatCurrency(payroll.netSalary)}</strong></td>
                        <td>
                            <div class="progress-container">
                                <div class="progress-text">
                                    <span>$${formatCurrency(payroll.totalAmountPaid)}</span>
                                    <span>${paidPercent}%</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar" role="progressbar" 
                                         style="width: ${paidPercent}%" 
                                         aria-valuenow="${paidPercent}" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="payment-badge ${statusClass}">${status}</span>
                        </td>
                        <td>
                            <div class="action-btn-group">
                                ${status !== 'Paid' ? `
                                    <button class="btn btn-sm btn-success" onclick="OpenPaymentModal(${payroll.id})" title="Pay Partial">
                                        <i class="fas fa-money-bill-wave"></i>
                                    </button>
                                ` : ''}
                                <button class="btn btn-sm btn-info" onclick="ViewDetails(${payroll.id})" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;

            // Update statistics
            document.getElementById('totalPayrolls').innerText = stats.total;
            document.getElementById('paidPayrolls').innerText = stats.paid;
            document.getElementById('partialPayrolls').innerText = stats.partial;
            document.getElementById('unpaidPayrolls').innerText = stats.unpaid;
        }

        function OpenPaymentModal(payrollId) {
            currentPayrollId = payrollId;

            fetch(`/AccountingEngine/PayrollPaymentDetails?payrollId=${payrollId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') {
                        const p = data.data;
                        document.getElementById('modalEmployee').innerText = p.employeeName;
                        document.getElementById('modalPeriod').innerText = p.period;
                        document.getElementById('modalNetSalary').innerText = '$' + formatCurrency(p.netSalary);
                        document.getElementById('modalTotalPaid').innerText = '$' + formatCurrency(p.totalAmountPaid);
                        document.getElementById('modalRemaining').innerText = '$' + formatCurrency(p.remainingBalance);
                        document.getElementById('maxAmount').innerText = '$' + formatCurrency(p.remainingBalance);
                        document.getElementById('paymentAmount').max = p.remainingBalance;

                        document.getElementById('paymentForm').reset();
                        new bootstrap.Modal(document.getElementById('paymentModal')).show();
                    }
                });
        }

        function SubmitPayment() {
            const form = document.getElementById('paymentForm');
            if (!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const amount = parseFloat(document.getElementById('paymentAmount').value);
            const method = document.getElementById('paymentMethod').value;
            const notes = document.getElementById('paymentNotes').value;

            fetch('/AccountingEngine/PayPartialSalary', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    payrollId: currentPayrollId,
                    amount: amount,
                    paymentMethod: method,
                    notes: notes
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.status === 'success') {
                    ShowAlert('success', data.message);
                    bootstrap.Modal.getInstance(document.getElementById('paymentModal')).hide();
                    LoadPayrolls();
                } else {
                    ShowAlert('error', data.message);
                }
            });
        }

        function ViewDetails(payrollId) {
            fetch(`/AccountingEngine/PayrollPaymentDetails?payrollId=${payrollId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') {
                        const p = data.data;

                        document.getElementById('detailEmployee').innerText = p.employeeName;
                        document.getElementById('detailPeriodText').innerText = p.period;
                        document.getElementById('detailSalary').innerText = '$' + formatCurrency(p.netSalary);
                        document.getElementById('detailPaid').innerText = '$' + formatCurrency(p.totalAmountPaid);
                        document.getElementById('detailRemainingText').innerText = '$' + formatCurrency(p.remainingBalance);

                        const statusClass = p.paymentStatus === 'Paid' ? 'badge-paid' :
                                          p.paymentStatus === 'PartiallyPaid' ? 'badge-partial' : 'badge-unpaid';
                        document.getElementById('detailStatusBadge').innerHTML = 
                            `<span class="payment-badge ${statusClass}">${p.paymentStatus}</span>`;

                        let paymentHtml = '';
                        if (p.payments.length === 0) {
                            paymentHtml = '<div class="alert alert-info text-center"><i class="fas fa-info-circle me-2"></i>@Localize("No payments recorded")</div>';
                        } else {
                            p.payments.forEach((pmt, idx) => {
                                paymentHtml += `
                                    <div class="card mb-2">
                                        <div class="card-body p-3">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <strong class="d-block">Payment #${idx + 1}</strong>
                                                    <small class="text-muted d-block mt-1">${pmt.paymentDate}</small>
                                                    <small class="text-muted d-block">${pmt.paymentMethod || 'N/A'}</small>
                                                </div>
                                                <div class="text-end">
                                                    <strong class="text-success d-block">$${formatCurrency(pmt.amount)}</strong>
                                                    ${pmt.notes ? `<small class="text-muted d-block mt-2">${pmt.notes}</small>` : ''}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                `;
                            });
                        }
                        document.getElementById('paymentDetailsList').innerHTML = paymentHtml;
                        new bootstrap.Modal(document.getElementById('detailsModal')).show();
                    }
                });
        }

        function ShowAlert(type, message) {
            const alertClass = type === 'success' ? 'alert-success' : 'alert-danger';
            const icon = type === 'success' ? 'fas fa-check-circle' : 'fas fa-exclamation-circle';
            
            const alert = document.createElement('div');
            alert.className = `alert ${alertClass} alert-dismissible fade show`;
            alert.innerHTML = `
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                <i class="${icon} me-2"></i>${message}
            `;
            
            document.body.insertBefore(alert, document.body.firstChild);
            setTimeout(() => alert.remove(), 4000);
        }
    </script>
}
