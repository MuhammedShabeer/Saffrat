@model IEnumerable<Saffrat.Models.JournalEntry>
@using Saffrat.Resources
@inherits LocService<IEnumerable<Saffrat.Models.JournalEntry>>

@{
    ViewData["Title"] = Localize("Bank Transactions");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-md-12">
                <div class="page-header-title">
                    <h5 class="m-b-10">@Localize("Bank Transactions")</h5>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/"><i class="feather icon-home"></i></a></li>
                    <li class="breadcrumb-item"><a href="#!">@Localize("Accounting")</a></li>
                    <li class="breadcrumb-item"><a href="#!">@Localize("Bank Transactions")</a></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header">
                <h5>@Localize("Bank / Cash Transactions")</h5>
                <div class="card-header-right">
                    <a asp-action="AddBankEntry" class="btn btn-primary btn-sm">
                        <i class="feather icon-plus"></i> @Localize("Add Bank Entry")
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="bank-table" class="table table-striped table-bordered nowrap">
                        <thead>
                            <tr>
                                <th>@Localize("Date")</th>
                                <th>@Localize("Reference")</th>
                                <th>@Localize("Account")</th>
                                <th>@Localize("Type")</th>
                                <th>@Localize("Description")</th>
                                <th>@Localize("Debit")</th>
                                <th>@Localize("Credit")</th>
                                <th>@Localize("Action")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var journal in Model)
                            {
                                foreach (var entry in journal.LedgerEntries.Where(e => e.GLAccount.Type == 1 || e.GLAccount.Type == 2))
                                {
                                    <tr>
                                        <td>@journal.EntryDate.ToShortDateString()</td>
                                        <td>@journal.ReferenceNumber</td>
                                        <td>@entry.GLAccount.AccountName</td>
                                        <td>
                                            @if (entry.Debit > 0)
                                            {
                                                <span class="badge badge-light-success">@Localize("Inflow")</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-light-danger">@Localize("Outflow")</span>
                                            }
                                        </td>
                                        <td>@entry.Description</td>
                                        <td>@entry.Debit.ToString("N2")</td>
                                        <td>@entry.Credit.ToString("N2")</td>
                                        <td>
                                            <a href="/AccountingEngine/JournalEntries?search=@journal.ReferenceNumber" class="btn btn-info btn-sm">
                                                <i class="feather icon-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            $('#bank-table').DataTable({
                "order": [[0, "desc"]]
            });
        });
    </script>
}
