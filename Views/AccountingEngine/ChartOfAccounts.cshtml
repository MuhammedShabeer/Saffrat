@model IEnumerable<Saffrat.Models.GLAccount>
@using Saffrat.Resources
@using Saffrat.Models.AccountingEngine
@inherits LocService<TModel>

@{
    ViewData["Title"] = Localize("Chart of Accounts");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>@Localize("Chart of Accounts")</h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i
                                class="fa fa-home me-1"></i> @Localize("Dashboard")</a></li>
                    <li class="breadcrumb-item">@Localize("Accounting Engine")</li>
                    <li class="breadcrumb-item">@Localize("Chart of Accounts")</li>
                </ul>
            </div>
            <div class="col">
                <div class="float-end">
                    <a asp-action="AddAccount" class="btn btn-primary"><i class="fa fa-plus"></i> @Localize("New Account")</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="datatable">
                        <thead class="bg-light">
                            <tr>
                                <th>@Localize("Account Code")</th>
                                <th>@Localize("Account Name")</th>
                                <th>@Localize("Category")</th>
                                <th>@Localize("Sub-Type")</th>
                                <th>@Localize("Current Balance")</th>
                                <th>@Localize("Status")</th>
                                <th>@Localize("Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var acc in Model)
                                {
                                    <tr>
                                        <td><strong>@acc.AccountCode</strong></td>
                                        <td>@acc.AccountName</td>
                                        <td><span class="badge bg-secondary">@((AccountCategory)acc.Category)</span></td>
                                        <td>@((AccountType)acc.Type)</td>
                                        <td class="@(acc.CurrentBalance < 0 ? "text-danger" : "text-success") fw-bold">
                                            @GetCurrency(acc.CurrentBalance)
                                        </td>
                                        <td>
                                            @if (acc.IsActive)
                                            {
                                                <span class="badge bg-success">@Localize("Active")</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">@Localize("Inactive")</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="EditAccount" asp-route-id="@acc.Id" class="btn btn-sm btn-info text-white"><i class="fa fa-edit"></i> @Localize("Edit")</a>
                                            <button class="btn btn-sm btn-danger" onclick="deleteAccount(@acc.Id, '@acc.AccountName')"><i class="fa fa-trash"></i> @Localize("Delete")</button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-muted">@Localize("No GL Accounts found in the Chart of Accounts.")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $('#datatable').DataTable();
        });

        function deleteAccount(id, name) {
            Swal.fire({
                title: '@Localize("Are you sure?")',
                text: '@Localize("You are about to delete account:") ' + name,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: '@Localize("Yes, delete it!")'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("DeleteAccount")', { id: id }, function (res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '@Localize("Deleted!")',
                                showConfirmButton: false,
                                timer: 1500
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: '@Localize("Cannot Delete")',
                                text: res.message
                            });
                        }
                    });
                }
            });
        }
    </script>
}
