@model IEnumerable<Saffrat.Models.Bill>
@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = Localize("Bills (AP)");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>@Localize("Accounts Payable Bills")</h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i
                                class="fa fa-home me-1"></i> @Localize("Dashboard")</a></li>
                    <li class="breadcrumb-item">@Localize("Accounting Engine")</li>
                    <li class="breadcrumb-item">@Localize("Bills")</li>
                </ul>
            </div>
            <div class="col">
                <div class="float-end">
                    <button class="btn btn-primary" onclick="$('#addBillModal').modal('show')"><i class="fa fa-plus"></i>
                        @Localize("Enter Bill")</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="datatable">
                        <thead class="bg-light">
                            <tr>
                                <th>@Localize("Bill Number")</th>
                                <th>@Localize("Supplier ID")</th>
                                <th>@Localize("Date")</th>
                                <th>@Localize("Due Date")</th>
                                <th>@Localize("Total Amount")</th>
                                <th>@Localize("Amount Paid")</th>
                                <th>@Localize("Status")</th>
                                <th>@Localize("Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var bill in Model)
                                {
                                    <tr>
                                        <td><strong>@bill.BillNumber</strong></td>
                                        <td>
                                            @{
                                                var supplierName = ViewBag.Suppliers != null 
                                                    ? ((IEnumerable<Saffrat.Models.Supplier>)ViewBag.Suppliers).FirstOrDefault(s => s.Id == bill.SupplierId)?.SupplierName 
                                                    : bill.SupplierId.ToString();
                                            }
                                            @supplierName
                                        </td>
                                        <td>@bill.Date.ToString("yyyy-MM-dd")</td>
                                        <td>@bill.DueDate.ToString("yyyy-MM-dd")</td>
                                        <td class="text-danger fw-bold">@GetCurrency(bill.TotalAmount)</td>
                                        <td class="text-info">@GetCurrency(bill.AmountPaid)</td>
                                        <td>
                                            @if (bill.Status == "Paid")
                                            {
                                                <span class="badge bg-success">@Localize(bill.Status ?? "")</span>
                                            }
                                            else if (bill.Status == "Overdue")
                                            {
                                                <span class="badge bg-danger">@Localize(bill.Status ?? "")</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">@Localize(bill.Status ?? "")</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-info text-white" onclick="viewBill(@bill.Id)" title="@Localize("View Bill Details")"><i class="fa fa-eye"></i></button>
                                            @if (bill.Status != "Paid")
                                            {
                                                <button class="btn btn-sm btn-success text-white" onclick="markPaid(@bill.Id)" title="@Localize("Mark as Paid")"><i class="fa fa-check"></i></button>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section models {
    <div class="modal fade" id="addBillModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content shadow-lg border-0">
                <form id="billForm">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title fw-bold"><i class="fa fa-file-invoice-dollar me-2"></i> @Localize("Enter AP Bill")</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4 bg-light">
                        <div class="mb-3">
                            <label class="form-label fw-bold">@Localize("Supplier") <span class="text-danger">*</span></label>
                            <select name="SupplierId" class="form-select" required>
                                <option value="">@Localize("-- Select Supplier --")</option>
                                @if (ViewBag.Suppliers != null)
                                {
                                    foreach (var supplier in ViewBag.Suppliers)
                                    {
                                        <option value="@supplier.Id">@supplier.SupplierName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">@Localize("Date")</label>
                                <input type="date" name="Date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">@Localize("Due Date")</label>
                                <input type="date" name="DueDate" class="form-control" value="@DateTime.Now.AddDays(30).ToString("yyyy-MM-dd")" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">@Localize("Total Amount")</label>
                            <div class="input-group">
                                <span class="input-group-text">@Html.Raw(GetSetting.CurrencySymbol)</span>
                                <input type="number" step="0.01" name="TotalAmount" class="form-control font-monospace" required />
                            </div>
                            <small class="text-muted mt-1 d-block"><i class="fa fa-info-circle"></i> @Localize("This will automatically create an Accounts Payable Entry upon save.")</small>
                        </div>
                    </div>
                    <div class="modal-footer bg-light py-2">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localize("Cancel")</button>
                        <button type="submit" class="btn btn-primary btn-sm"><i class="fa fa-save"></i> @Localize("Enter Bill")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- View Bill Modal -->
    <div class="modal fade" id="viewBillModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content shadow border-0">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title fw-bold"><i class="fa fa-file-invoice-dollar me-2"></i> @Localize("Bill Details")</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="row mb-3">
                        <div class="col-6">
                            <span class="text-muted d-block small fw-bold text-uppercase">@Localize("Bill Number")</span>
                            <span class="fs-5 fw-bold text-dark" id="vBillNumber">--</span>
                        </div>
                        <div class="col-6 text-end">
                            <span class="text-muted d-block small fw-bold text-uppercase">@Localize("Status")</span>
                            <span class="badge bg-secondary fs-6 mt-1" id="vStatus">--</span>
                        </div>
                    </div>
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <div class="row align-items-center mb-2">
                                <div class="col-5 text-muted fw-bold">@Localize("Supplier"):</div>
                                <div class="col-7 text-dark fw-bold" id="vSupplierName">--</div>
                            </div>
                            <div class="row align-items-center mb-2">
                                <div class="col-5 text-muted fw-bold">@Localize("Date"):</div>
                                <div class="col-7 text-dark" id="vDate">--</div>
                            </div>
                            <div class="row align-items-center">
                                <div class="col-5 text-muted fw-bold">@Localize("Due Date"):</div>
                                <div class="col-7 text-dark" id="vDueDate">--</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row bg-white rounded shadow-sm border p-3 align-items-center mx-0 mb-3">
                        <div class="col-6 border-end">
                            <span class="text-muted d-block small fw-bold text-uppercase">@Localize("Total Amount")</span>
                            <span class="fs-4 fw-bold text-danger" id="vTotalAmount">--</span>
                        </div>
                        <div class="col-6 pl-3">
                            <span class="text-muted d-block small fw-bold text-uppercase">@Localize("Amount Paid")</span>
                            <span class="fs-5 fw-bold text-info" id="vAmountPaid">--</span>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <a href="#" id="vJournalLink" class="btn btn-outline-primary btn-sm"><i class="fa fa-book me-1"></i> @Localize("View Journal Entry")</a>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localize("Close")</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#datatable').DataTable({
                "order": [[2, "desc"]]
            });

            $('#billForm').submit(function (e) {
                e.preventDefault();
                var btn = $(this).find('button[type="submit"]');
                btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> @Localize("Saving...")');

                $.post('@Url.Action("AddBill", "AccountingEngine")', $(this).serialize(), function (response) {
                    if (response.status === 'success') {
                        successMessage(response.message);
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        errorMessage(response.message);
                        btn.prop('disabled', false).html('<i class="fa fa-save"></i> @Localize("Enter Bill")');
                    }
                }).fail(function () {
                    errorMessage('@Localize("An error occurred while communicating with the server.")');
                    btn.prop('disabled', false).html('<i class="fa fa-save"></i> @Localize("Enter Bill")');
                });
            });
        });

        function viewBill(id) {
            $.get('@Url.Action("GetBillDetails", "AccountingEngine")/' + id, function (data) {
                $('#vBillNumber').text(data.billNumber);
                $('#vSupplierName').text(data.supplierName);
                $('#vDate').text(data.date);
                $('#vDueDate').text(data.dueDate);
                $('#vTotalAmount').text(GetCurrency(data.totalAmount));
                $('#vAmountPaid').text(GetCurrency(data.amountPaid));
                
                let badgeClass = 'bg-warning text-dark';
                if (data.status === 'Paid') badgeClass = 'bg-success';
                else if (data.status === 'Overdue') badgeClass = 'bg-danger';
                $('#vStatus').attr('class', 'badge fs-6 mt-1 ' + badgeClass).text(data.status || 'Draft');

                if (data.journalEntryId) {
                    $('#vJournalLink').attr('href', '@Url.Action("JournalEntries", "AccountingEngine")?id=' + data.journalEntryId).show();
                } else {
                    $('#vJournalLink').hide();
                }

                $('#viewBillModal').modal('show');
            }).fail(function () {
                errorMessage('@Localize("Error loading bill details")');
            });
        }

        function markPaid(id) {
            $.confirm({
                title: '@Localize("Confirm Payment")',
                content: '@Localize("Are you sure you want to mark this bill as paid? This will generate a Cash Disbursement journal entry.")',
                buttons: {
                    confirm: {
                        text: '@Localize("Yes, Mark Paid")',
                        btnClass: 'btn-success',
                        action: function () {
                            $.post('@Url.Action("MarkBillPaid", "AccountingEngine")/' + id, function (response) {
                                if (response.status === 'success') {
                                    successMessage(response.message);
                                    setTimeout(() => location.reload(), 1500);
                                } else if (response.status === 'warning') {
                                    errorMessage(response.message);
                                } else {
                                    errorMessage(response.message);
                                }
                            }).fail(function () {
                                errorMessage('@Localize("An error occurred while marking as paid.")');
                            });
                        }
                    },
                    cancel: {
                        text: '@Localize("Cancel")',
                        btnClass: 'btn-secondary'
                    }
                }
            });
        }
    </script>
}
