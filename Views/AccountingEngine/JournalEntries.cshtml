@model IEnumerable<Saffrat.Models.JournalEntry>
@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = Localize("Journal Entries");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>@Localize("General Journal")</h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i> @Localize("Dashboard")</a></li>
                    <li class="breadcrumb-item">@Localize("Accounting Engine")</li>
                    <li class="breadcrumb-item">@Localize("Journal Entries")</li>
                </ul>
            </div>
            <div class="col">
                <div class="float-end">
                    <button class="btn btn-outline-info me-2" onclick="runDailyClose()"><i class="fa fa-cogs"></i> @Localize("Run Daily Close")</button>
                    <a asp-action="ManualJournal" class="btn btn-primary"><i class="fa fa-plus"></i> @Localize("Manual Journal")</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4">
                <form asp-action="JournalEntries" method="get" id="filterForm">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label fw-bold small text-muted text-uppercase">@Localize("Filter by Account")</label>
                            <select name="accountId" class="form-control selectpicker" data-live-search="true">
                                <option value="">-- @Localize("All Accounts") --</option>
                                @if (ViewBag.Accounts != null)
                                {
                                    foreach (var acc in (List<Saffrat.Models.GLAccount>)ViewBag.Accounts)
                                    {
                                        var isSelected = (ViewBag.AccountId != null && (int)ViewBag.AccountId == acc.Id);
                                        if (isSelected)
                                        {
                                            <option value="@acc.Id" selected>@acc.AccountCode - @acc.AccountName</option>
                                        }
                                        else
                                        {
                                            <option value="@acc.Id">@acc.AccountCode - @acc.AccountName</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">@Localize("From Date")</label>
                            <input type="date" name="start" class="form-control" value="@ViewBag.Start" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">@Localize("To Date")</label>
                            <input type="date" name="end" class="form-control" value="@ViewBag.End" />
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100"><i class="fa fa-filter me-1"></i> @Localize("Filter")</button>
                        </div>
                    </div>
                    <div class="row g-3 mt-1 align-items-end">
                        <div class="col-md-10">
                            <label class="form-label fw-bold small text-muted text-uppercase">@Localize("Search")</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa fa-search"></i></span>
                                <input type="text" name="search" class="form-control" value="@ViewBag.Search"
                                       placeholder="@Localize("Search by description, reference, supplier, employee, food item, ingredient...")" />
                                @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                                {
                                    <a asp-action="JournalEntries" asp-route-start="@ViewBag.Start" asp-route-end="@ViewBag.End" asp-route-accountId="@ViewBag.AccountId" class="btn btn-outline-secondary" title="@Localize("Clear search")"><i class="fa fa-times"></i></a>
                                }
                            </div>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-outline-primary w-100"><i class="fa fa-search me-1"></i> @Localize("Search")</button>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                    {
                        <div class="mt-2">
                            <span class="badge bg-info text-white"><i class="fa fa-search me-1"></i> @Localize("Searching for"): "@ViewBag.Search"</span>
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="datatable">
                        <thead class="bg-light">
                            <tr>
                                <th>@Localize("Date")</th>
                                <th>@Localize("Reference")</th>
                                <th>@Localize("Description")</th>
                                <th>@Localize("Source Doc")</th>
                                <th>@Localize("Debit Total")</th>
                                <th>@Localize("Credit Total")</th>
                                <th>@Localize("Posted")</th>
                                <th>@Localize("Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var je in Model)
                                {
                                    decimal totalDebits = je.LedgerEntries?.Sum(l => l.Debit) ?? 0;
                                    decimal totalCredits = je.LedgerEntries?.Sum(l => l.Credit) ?? 0;
                                    bool isBalanced = Math.Round(totalDebits, 2) == Math.Round(totalCredits, 2);

                                    <tr>
                                        <td>@je.EntryDate.ToString("yyyy-MM-dd")</td>
                                        <td><strong>@je.ReferenceNumber</strong></td>
                                        <td>@je.Description</td>
                                        <td>@je.SourceDocumentType</td>
                                        <td class="text-success fw-bold">@GetCurrency(totalDebits)</td>
                                        <td class="text-danger fw-bold">@GetCurrency(totalCredits)</td>
                                        <td>
                                            @if (je.IsPosted)
                                            {
                                                <span class="badge bg-success"><i class="fa fa-lock"></i> @Localize("Posted")</span>
                                            }
                                            else
                                            {
                                                if (isBalanced)
                                                {
                                                    <span class="badge bg-warning text-dark"><i class="fa fa-unlock"></i> @Localize("Unposted")</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger"><i class="fa fa-exclamation-triangle"></i> @Localize("Unbalanced")</span>
                                                }
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-info text-white" title="@Localize("View Lines")" onclick="viewLines(@je.Id)"><i class="fa fa-eye"></i></button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Journal Lines Modal -->
@section models {
    <div class="modal fade" id="linesModal" tabindex="-1" role="dialog" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header border-bottom py-3">
                    <h5 class="modal-title fw-bold" id="mainModalTitle"><i class="fa fa-book me-2 text-primary"></i> @Localize("Journal Entry Detail")</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="p-4 bg-light border-bottom">
                    <div class="row gx-5">
                        <div class="col-md-4">
                            <label class="text-muted small text-uppercase fw-bold mb-1">@Localize("Posting Date")</label>
                            <div id="modalDate" class="h6 mb-0 fw-bold"></div>
                        </div>
                        <div class="col-md-8 border-start">
                            <label class="text-muted small text-uppercase fw-bold mb-1">@Localize("Global Description")</label>
                            <div id="modalDesc" class="h6 mb-0"></div>
                        </div>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="bg-light text-uppercase small">
                            <tr>
                                <th class="ps-4">@Localize("Account")</th>
                                <th>@Localize("Line Description")</th>
                                <th class="text-end">@Localize("Debit")</th>
                                <th class="text-end pe-4">@Localize("Credit")</th>
                            </tr>
                        </thead>
                        <tbody id="modalBody" class="border-top-0">
                        </tbody>
                        <tfoot class="fw-bold border-top-2">
                            <tr class="table-info border-bottom-0">
                                <td colspan="2" class="ps-4 text-end">@Localize("Totals")</td>
                                <td class="text-end" id="totalDebit"></td>
                                <td class="text-end pe-4" id="totalCredit"></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="modal-footer bg-light py-2">
                    <div id="sourceInfo" class="me-auto small text-muted"></div>
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localize("Close")</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Source Document Detail Modal -->
    <div class="modal fade" id="sourceDetailModal" tabindex="-1" role="dialog" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content shadow-lg">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold text-info"><i class="fa fa-info-circle me-2"></i> <span id="sourceTitle">Details</span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0" id="sourceDetailBody">
                    <!-- Dynamic Content -->
                </div>
                <div class="modal-footer bg-light py-2">
                    <button type="button" class="btn btn-outline-info btn-sm" onclick="$('#sourceDetailModal').modal('hide'); $('#linesModal').modal('show');"><i class="fa fa-arrow-left"></i> @Localize("Back to Journal")</button>
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localize("Close")</button>
                </div>
            </div>
        </div>
    </div>
}
<style>
    #linesModal .table thead th {
        font-weight: 600;
        letter-spacing: 0.5px;
        padding-top: 12px;
        padding-bottom: 12px;
    }

    #linesModal .modal-content {
        border-radius: 12px;
        overflow: hidden;
    }

    #linesModal .modal-header {
        border-bottom: 0;
    }

    #linesModal .table-info {
        background-color: rgba(23, 162, 184, 0.1) !important;
        border-top: 2px solid #dee2e6;
    }

    .cursor-pointer {
        cursor: pointer;
    }

    #modalBody tr:hover.cursor-pointer {
        background-color: rgba(0, 123, 255, 0.1) !important;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#datatable').DataTable({
                "order": [[0, "desc"]]
            });
        });

        function runDailyClose() {
            var closeDate = prompt("Enter the date for Daily Close (YYYY-MM-DD):", new Date().toISOString().split('T')[0]);
            if (closeDate) {
                $.post('@Url.Action("RunDailyClose", "AccountingEngine")', { closeDate: closeDate }, function(response) {
                    if (response.status === 'success') {
                        successMessage(response.message);
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        errorMessage(response.message);
                    }
                });
            }
        }

        let currentSourceType = '';
        let currentSourceId = 0;

        function viewLines(id) {
            $.get('@Url.Action("GetJournalDetails", "AccountingEngine")/' + id, function (data) {
                $('#modalDate').text(data.entryDate);
                $('#modalDesc').text(data.description);
                
                currentSourceType = data.sourceDocumentType;
                currentSourceId = data.sourceDocumentId;

                if (currentSourceType && currentSourceId) {
                    $('#sourceInfo').html(`<i class="fa fa-link"></i> Linked to <strong>${currentSourceType} #${currentSourceId}</strong>. Click an account row for details.`);
                } else {
                    $('#sourceInfo').text('');
                }

                var html = '';
                var totalDebit = 0;
                var totalCredit = 0;

                $.each(data.lines, function (i, line) {
                    let clickableAttr = (currentSourceType && currentSourceId) ? `onclick="showSourceDetails()"` : '';
                    let clickableClass = (currentSourceType && currentSourceId) ? 'cursor-pointer table-primary' : '';
                    
                    html += `<tr ${clickableAttr} class="${clickableClass}">
                        <td class="ps-4"><strong>${line.accountCode}</strong> - ${line.accountName}</td>
                        <td>${line.description || ''}</td>
                        <td class="text-end text-success font-monospace">${line.debit > 0 ? parseFloat(line.debit).toLocaleString(undefined, { minimumFractionDigits: 2 }) : '-'}</td>
                        <td class="text-end text-danger pe-4 font-monospace">${line.credit > 0 ? parseFloat(line.credit).toLocaleString(undefined, { minimumFractionDigits: 2 }) : '-'}</td>
                    </tr>`;
                    totalDebit += line.debit;
                    totalCredit += line.credit;
                });

                $('#modalBody').html(html);
                $('#totalDebit').text(totalDebit.toLocaleString(undefined, { minimumFractionDigits: 2 }));
                $('#totalCredit').text(totalCredit.toLocaleString(undefined, { minimumFractionDigits: 2 }));

                $('#linesModal').modal('show');
            }).fail(function() {
                errorMessage("Error loading journal details");
            });
        }

        function showSourceDetails() {
            if (!currentSourceType || !currentSourceId) return;

            $('#linesModal').modal('hide');
            
            $.get('@Url.Action("GetSourceDocumentDetails", "AccountingEngine")', { type: currentSourceType, id: currentSourceId }, function (response) {
                if (response.status === 'success') {
                    $('#sourceTitle').text(response.type);
                    let content = renderSourceContent(response.type, response.data);
                    $('#sourceDetailBody').html(content);
                    $('#sourceDetailModal').modal('show');
                } else {
                    errorMessage(response.message);
                    $('#linesModal').modal('show');
                }
            }).fail(function() {
                errorMessage("Error loading source details");
                $('#linesModal').modal('show');
            });
        }

        function renderSourceContent(type, data) {
            let html = '<div class="p-4">';
            
            switch(type.toLowerCase()) {
                case 'payroll':
                    html += `
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold">EMPLOYEE</label>
                                <div class="h5 fw-bold text-primary">${data.employeeName}</div>
                                <div class="text-muted">${data.designation} (${data.department})</div>
                            </div>
                            <div class="col-md-6 text-end">
                                <label class="text-muted small fw-bold">PAY PERIOD</label>
                                <div class="h5 fw-bold">${data.period}</div>
                            </div>
                        </div>
                        <div class="card border-0 bg-light mb-0">
                            <div class="card-body p-0">
                                <table class="table table-sm border mb-0">
                                    <thead class="bg-light small">
                                        <tr><th class="ps-3">DESCRIPTION</th><th class="text-end pe-3">AMOUNT</th></tr>
                                    </thead>
                                    <tbody>
                                        <tr><td class="ps-3">Basic Salary</td><td class="text-end pe-3 fst-italic">${parseFloat(data.salary).toFixed(2)}</td></tr>
                                        ${data.details.map(d => `
                                            <tr class="${d.amountType === 'Earning' ? 'text-success' : 'text-danger'}">
                                                <td class="ps-3">${d.title} (${d.amountType})</td>
                                                <td class="text-end pe-3">${d.amountType === 'Earning' ? '+' : '-'}${parseFloat(d.amount).toFixed(2)}</td>
                                            </tr>
                                        `).join('')}
                                    </tbody>
                                    <tfoot class="fw-bold bg-white">
                                        <tr><td class="ps-3 text-end">NET SALARY</td><td class="text-end pe-3 text-primary h6 fw-bold mb-0">${parseFloat(data.netSalary).toFixed(2)}</td></tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>`;
                    break;

                case 'purchase':
                    html += `
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold">SUPPLIER</label>
                                <div class="h5 fw-bold text-primary">${data.supplierName || 'N/A'}</div>
                                <div class="text-muted">Invoice #: ${data.invoiceNo}</div>
                            </div>
                            <div class="col-md-6 text-end">
                                <label class="text-muted small fw-bold">PURCHASE DATE</label>
                                <div class="h5 fw-bold">${data.purchaseDate}</div>
                            </div>
                        </div>
                        <table class="table table-sm border">
                            <thead class="bg-light small">
                                <tr><th class="ps-3">ITEM</th><th class="text-center">QTY</th><th class="text-end">PRICE</th><th class="text-end pe-4">TOTAL</th></tr>
                            </thead>
                            <tbody>
                                ${data.items.map(i => `
                                    <tr>
                                        <td class="ps-3">${i.itemName}</td>
                                        <td class="text-center">${i.quantity}</td>
                                        <td class="text-end">${parseFloat(i.purchasePrice).toFixed(2)}</td>
                                        <td class="text-end pe-3">${parseFloat(i.total).toFixed(2)}</td>
                                    </tr>
                                `).join('')}
                            </tbody>
                            <tfoot class="fw-bold bg-light">
                                <tr><td colspan="3" class="text-end">GRAND TOTAL</td><td class="text-end pe-3">${parseFloat(data.totalAmount).toFixed(2)}</td></tr>
                                <tr class="text-success small"><td colspan="3" class="text-end">PAID AMOUNT</td><td class="text-end pe-3">${parseFloat(data.paidAmount).toFixed(2)}</td></tr>
                                <tr class="text-danger small"><td colspan="3" class="text-end">DUE AMOUNT</td><td class="text-end pe-3">${parseFloat(data.dueAmount).toFixed(2)}</td></tr>
                            </tfoot>
                        </table>`;
                    break;

                case 'pos order':
                    html += `
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold">CUSTOMER</label>
                                <div class="h5 fw-bold text-primary">${data.customerName || 'Walking Customer'}</div>
                                <div class="text-muted">Method: ${data.paymentMethod}</div>
                            </div>
                            <div class="col-md-6 text-end">
                                <label class="text-muted small fw-bold">ORDER DATE</label>
                                <div class="h5 fw-bold">${data.orderDate}</div>
                            </div>
                        </div>
                        <table class="table table-sm border">
                            <thead class="bg-light small">
                                <tr><th class="ps-3">ITEM</th><th class="text-center">QTY</th><th class="text-end pe-3">TOTAL</th></tr>
                            </thead>
                            <tbody>
                                ${data.items.map(i => `
                                    <tr>
                                        <td class="ps-3">
                                            <div>${i.itemName}</div>
                                            ${i.modifiers.length > 0 ? `<div class="small text-muted ps-2">- ${i.modifiers.join(', ')}</div>` : ''}
                                        </td>
                                        <td class="text-center">${i.quantity}</td>
                                        <td class="text-end pe-3">${parseFloat(i.total).toFixed(2)}</td>
                                    </tr>
                                `).join('')}
                            </tbody>
                            <tfoot class="small bg-light">
                                <tr><td colspan="2" class="text-end">Subtotal</td><td class="text-end pe-3">${parseFloat(data.subTotal).toFixed(2)}</td></tr>
                                ${data.taxTotal > 0 ? `<tr><td colspan="2" class="text-end">Tax</td><td class="text-end pe-3">${parseFloat(data.taxTotal).toFixed(2)}</td></tr>` : ''}
                                ${data.discountTotal > 0 ? `<tr class="text-danger"><td colspan="2" class="text-end">Discount</td><td class="text-end pe-3">-${parseFloat(data.discountTotal).toFixed(2)}</td></tr>` : ''}
                                ${data.chargeTotal > 0 ? `<tr><td colspan="2" class="text-end">Charges</td><td class="text-end pe-3">${parseFloat(data.chargeTotal).toFixed(2)}</td></tr>` : ''}
                                <tr class="fw-bold h6"><td colspan="2" class="text-end">GRAND TOTAL</td><td class="text-end pe-3 text-primary">${parseFloat(data.total).toFixed(2)}</td></tr>
                            </tfoot>
                        </table>`;
                    break;

                case 'stock adjustment':
                    html += `
                        <div class="card bg-light border-0">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-6"><label class="small text-muted fw-bold">ITEM</label><div class="h6 fw-bold">${data.itemName}</div></div>
                                    <div class="col-6"><label class="small text-muted fw-bold">ADJUSTMENT TYPE</label><div class="h6 fw-bold text-${data.type === 'Addition' ? 'success' : 'danger'}">${data.type}</div></div>
                                    <hr class="my-2">
                                    <div class="col-6"><label class="small text-muted fw-bold">QUANTITY</label><div class="h6">${data.quantity}</div></div>
                                    <div class="col-6"><label class="small text-muted fw-bold">DATE</label><div class="h6">${data.date}</div></div>
                                    <div class="col-12 mt-2"><label class="small text-muted fw-bold">REASON</label><div class="p-2 border bg-white rounded">${data.reason || 'No reason provided'}</div></div>
                                </div>
                            </div>
                        </div>`;
                    break;

                case 'cash transaction':
                    html += `
                        <div class="card bg-light border-0">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-6"><label class="small text-muted fw-bold">TYPE</label><div class="h6 fw-bold text-${data.type === 'Income' ? 'success' : 'danger'}">${data.type}</div></div>
                                    <div class="col-6"><label class="small text-muted fw-bold">AMOUNT</label><div class="h6 fw-bold">${parseFloat(data.amount).toFixed(2)}</div></div>
                                    <hr class="my-2">
                                    <div class="col-6"><label class="small text-muted fw-bold">DATE</label><div class="h6">${data.date}</div></div>
                                    <div class="col-6"><label class="small text-muted fw-bold">OFFSET ACCOUNT</label><div class="h6">${data.offsetAccount}</div></div>
                                    <div class="col-12 mt-2"><label class="small text-muted fw-bold">DESCRIPTION</label><div class="p-2 border bg-white rounded">${data.description || 'No description'}</div></div>
                                </div>
                            </div>
                        </div>`;
                    break;

                case 'partner equity transaction':
                    html += `
                        <div class="card bg-light border-0">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-6"><label class="small text-muted fw-bold">PARTNER</label><div class="h6 fw-bold text-primary">${data.partnerName}</div></div>
                                    <div class="col-6"><label class="small text-muted fw-bold">TYPE</label><div class="h6 fw-bold text-info">${data.type}</div></div>
                                    <hr class="my-2">
                                    <div class="col-6"><label class="small text-muted fw-bold">AMOUNT</label><div class="h6 fw-bold">${parseFloat(data.amount).toFixed(2)}</div></div>
                                    <div class="col-6"><label class="small text-muted fw-bold">DATE</label><div class="h6">${data.date}</div></div>
                                    <div class="col-12 mt-2"><label class="small text-muted fw-bold">NOTE</label><div class="p-2 border bg-white rounded">${data.note || 'No note provided'}</div></div>
                                </div>
                            </div>
                        </div>`;
                    break;

                default:
                    html += `<div class="alert alert-warning">Details for this document type are not yet customizable.</div>`;
            }
            
            html += '</div>';
            return html;
        }
    </script>
}
