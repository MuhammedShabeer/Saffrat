@model IEnumerable<Saffrat.Models.Invoice>
@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = Localize("Invoices (AR)");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>@Localize("Accounts Receivable Invoices")</h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i
                                class="fa fa-home me-1"></i> @Localize("Dashboard")</a></li>
                    <li class="breadcrumb-item">@Localize("Accounting Engine")</li>
                    <li class="breadcrumb-item">@Localize("Invoices")</li>
                </ul>
            </div>
            <div class="col">
                <div class="float-end">
                    <!-- Note: Draft Invoice Create view implementation pending -->
                    <button class="btn btn-primary disabled" title="@Localize("Coming Soon")"><i class="fa fa-plus"></i>
                        @Localize("Draft Invoice")</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="datatable">
                        <thead class="bg-light">
                            <tr>
                                <th>@Localize("Invoice Number")</th>
                                <th>@Localize("Customer ID")</th>
                                <th>@Localize("Issue Date")</th>
                                <th>@Localize("Due Date")</th>
                                <th>@Localize("Total Amount")</th>
                                <th>@Localize("Amount Paid")</th>
                                <th>@Localize("Status")</th>
                                <th>@Localize("Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var invoice in Model)
                                {
                                    <tr>
                                        <td><strong>@invoice.InvoiceNumber</strong></td>
                                        <td>@invoice.CustomerId</td>
                                        <td>@invoice.IssueDate.ToString("yyyy-MM-dd")</td>
                                        <td>@invoice.DueDate.ToString("yyyy-MM-dd")</td>
                                        <td class="text-success fw-bold">@GetCurrency(invoice.TotalAmount)</td>
                                        <td class="text-info">@GetCurrency(invoice.AmountPaid)</td>
                                        <td>
                                            @if (invoice.Status == "Paid")
                                            {
                                                <span class="badge bg-success">@Localize(invoice.Status ?? "")</span>
                                            }
                                            else if (invoice.Status == "Overdue")
                                            {
                                                <span class="badge bg-danger">@Localize(invoice.Status ?? "")</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">@Localize(invoice.Status ?? "")</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-info text-white"><i class="fa fa-eye"></i></button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#datatable').DataTable({
                "order": [[2, "desc"]]
            });
        });
    </script>
}
