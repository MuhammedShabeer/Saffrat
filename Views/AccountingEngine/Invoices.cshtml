@model IEnumerable<Saffrat.Models.Invoice>
@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = Localize("Invoices (AR)");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>@Localize("Accounts Receivable Invoices")</h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i
                                class="fa fa-home me-1"></i> @Localize("Dashboard")</a></li>
                    <li class="breadcrumb-item">@Localize("Accounting Engine")</li>
                    <li class="breadcrumb-item">@Localize("Invoices")</li>
                </ul>
            </div>
            <div class="col">
                <div class="float-end">
                    <button class="btn btn-primary" onclick="$('#addInvoiceModal').modal('show')"><i class="fa fa-plus"></i>
                        @Localize("Draft Invoice")</button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover" id="datatable">
                        <thead class="bg-light">
                            <tr>
                                <th>@Localize("Invoice Number")</th>
                                <th>@Localize("Customer ID")</th>
                                <th>@Localize("Issue Date")</th>
                                <th>@Localize("Due Date")</th>
                                <th>@Localize("Total Amount")</th>
                                <th>@Localize("Amount Paid")</th>
                                <th>@Localize("Status")</th>
                                <th>@Localize("Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var invoice in Model)
                                {
                                    <tr>
                                        <td><strong>@invoice.InvoiceNumber</strong></td>
                                        <td>@invoice.CustomerId</td>
                                        <td>@invoice.IssueDate.ToString("yyyy-MM-dd")</td>
                                        <td>@invoice.DueDate.ToString("yyyy-MM-dd")</td>
                                        <td class="text-success fw-bold">@GetCurrency(invoice.TotalAmount)</td>
                                        <td class="text-info">@GetCurrency(invoice.AmountPaid)</td>
                                        <td>
                                            @if (invoice.Status == "Paid")
                                            {
                                                <span class="badge bg-success">@Localize(invoice.Status ?? "")</span>
                                            }
                                            else if (invoice.Status == "Overdue")
                                            {
                                                <span class="badge bg-danger">@Localize(invoice.Status ?? "")</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">@Localize(invoice.Status ?? "")</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-info text-white" onclick="viewInvoice(@invoice.Id)" title="@Localize("View Invoice Details")"><i class="fa fa-eye"></i></button>
                                            @if (invoice.Status != "Paid")
                                            {
                                                <button class="btn btn-sm btn-success text-white" onclick="markPaid(@invoice.Id)" title="@Localize("Mark as Paid")"><i class="fa fa-check"></i></button>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section models {
    <div class="modal fade" id="addInvoiceModal" tabindex="-1" role="dialog" data-bs-backdrop="static">
        <div class="modal-dialog" role="document">
            <div class="modal-content shadow-lg border-0">
                <form id="invoiceForm">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title fw-bold"><i class="fa fa-file-invoice me-2"></i> @Localize("Create Draft Invoice")</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4 bg-light">
                        <div class="mb-3">
                            <label class="form-label fw-bold">@Localize("Customer")</label>
                            <select name="CustomerId" class="form-select" required>
                                <option value="">@Localize("Select Customer")</option>
                                @if (ViewBag.Customers != null)
                                {
                                    foreach (var customer in (IEnumerable<Saffrat.Models.Customer>)ViewBag.Customers)
                                    {
                                        <option value="@customer.Id">@customer.CustomerName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">@Localize("Issue Date")</label>
                                <input type="date" name="IssueDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">@Localize("Due Date")</label>
                                <input type="date" name="DueDate" class="form-control" value="@DateTime.Today.AddDays(30).ToString("yyyy-MM-dd")" required />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">@Localize("Total Amount")</label>
                            <div class="input-group">
                                <span class="input-group-text">@Html.Raw(GetSetting.CurrencySymbol)</span>
                                <input type="number" step="0.01" name="TotalAmount" class="form-control font-monospace" required />
                            </div>
                            <small class="text-muted mt-1 d-block"><i class="fa fa-info-circle"></i> @Localize("This will automatically create an Accounts Receivable Journal Entry upon save.")</small>
                        </div>
                    </div>
                    <div class="modal-footer bg-light py-2">
                        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localize("Cancel")</button>
                        <button type="submit" class="btn btn-primary btn-sm"><i class="fa fa-save"></i> @Localize("Create Draft")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- View Invoice Modal -->
    <div class="modal fade" id="viewInvoiceModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content shadow border-0">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title fw-bold"><i class="fa fa-file-invoice me-2"></i> @Localize("Invoice Details")</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <div class="row mb-3">
                        <div class="col-6">
                            <span class="text-muted d-block small fw-bold text-uppercase">@Localize("Invoice Number")</span>
                            <span class="fs-5 fw-bold text-dark" id="vInvoiceNumber">--</span>
                        </div>
                        <div class="col-6 text-end">
                            <span class="text-muted d-block small fw-bold text-uppercase">@Localize("Status")</span>
                            <span class="badge bg-secondary fs-6 mt-1" id="vStatus">--</span>
                        </div>
                    </div>
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <div class="row align-items-center mb-2">
                                <div class="col-5 text-muted fw-bold">@Localize("Customer"):</div>
                                <div class="col-7 text-dark fw-bold" id="vCustomerName">--</div>
                            </div>
                            <div class="row align-items-center mb-2">
                                <div class="col-5 text-muted fw-bold">@Localize("Issue Date"):</div>
                                <div class="col-7 text-dark" id="vIssueDate">--</div>
                            </div>
                            <div class="row align-items-center">
                                <div class="col-5 text-muted fw-bold">@Localize("Due Date"):</div>
                                <div class="col-7 text-dark" id="vDueDate">--</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row bg-white rounded shadow-sm border p-3 align-items-center mx-0 mb-3">
                        <div class="col-6 border-end">
                            <span class="text-muted d-block small fw-bold text-uppercase">@Localize("Total Amount")</span>
                            <span class="fs-4 fw-bold text-success" id="vTotalAmount">--</span>
                        </div>
                        <div class="col-6 pl-3">
                            <span class="text-muted d-block small fw-bold text-uppercase">@Localize("Amount Paid")</span>
                            <span class="fs-5 fw-bold text-info" id="vAmountPaid">--</span>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <a href="#" id="vJournalLink" class="btn btn-outline-primary btn-sm"><i class="fa fa-book me-1"></i> @Localize("View Journal Entry")</a>
                    </div>
                </div>
                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">@Localize("Close")</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#datatable').DataTable({
                "order": [[2, "desc"]]
            });

            $('#invoiceForm').on('submit', function (e) {
                e.preventDefault();
                var btn = $(this).find('button[type="submit"]');
                btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> @Localize("Creating...")');

                $.post('@Url.Action("AddInvoice", "AccountingEngine")', $(this).serialize(), function (response) {
                    if (response.status === 'success') {
                        successMessage(response.message);
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        errorMessage(response.message);
                        btn.prop('disabled', false).html('<i class="fa fa-save"></i> @Localize("Create Draft")');
                    }
                }).fail(function () {
                    errorMessage('@Localize("An error occurred while communicating with the server.")');
                    btn.prop('disabled', false).html('<i class="fa fa-save"></i> @Localize("Create Draft")');
                });
            });
        });

        function viewInvoice(id) {
            $.get('@Url.Action("GetInvoiceDetails", "AccountingEngine")/' + id, function (data) {
                $('#vInvoiceNumber').text(data.invoiceNumber);
                $('#vCustomerName').text(data.customerName);
                $('#vIssueDate').text(data.issueDate);
                $('#vDueDate').text(data.dueDate);
                $('#vTotalAmount').text(GetCurrency(data.totalAmount));
                $('#vAmountPaid').text(GetCurrency(data.amountPaid));
                
                let badgeClass = 'bg-warning text-dark';
                if (data.status === 'Paid') badgeClass = 'bg-success';
                else if (data.status === 'Overdue') badgeClass = 'bg-danger';
                $('#vStatus').attr('class', 'badge fs-6 mt-1 ' + badgeClass).text(data.status || 'Draft');

                if (data.journalEntryId) {
                    $('#vJournalLink').attr('href', '@Url.Action("JournalEntries", "AccountingEngine")?id=' + data.journalEntryId).show();
                } else {
                    $('#vJournalLink').hide();
                }

                $('#viewInvoiceModal').modal('show');
            }).fail(function () {
                errorMessage('@Localize("Error loading invoice details")');
            });
        }

        function markPaid(id) {
            $.confirm({
                title: '@Localize("Confirm Payment")',
                content: '@Localize("Are you sure you want to mark this invoice as paid? This will generate a Cash Receipt journal entry.")',
                buttons: {
                    confirm: {
                        text: '@Localize("Yes, Mark Paid")',
                        btnClass: 'btn-success',
                        action: function () {
                            $.post('@Url.Action("MarkInvoicePaid", "AccountingEngine")/' + id, function (response) {
                                if (response.status === 'success') {
                                    successMessage(response.message);
                                    setTimeout(() => location.reload(), 1500);
                                } else if (response.status === 'warning') {
                                    errorMessage(response.message);
                                } else {
                                    errorMessage(response.message);
                                }
                            }).fail(function () {
                                errorMessage('@Localize("An error occurred while marking as paid.")');
                            });
                        }
                    },
                    cancel: {
                        text: '@Localize("Cancel")',
                        btnClass: 'btn-secondary'
                    }
                }
            });
        }
    </script>
}
