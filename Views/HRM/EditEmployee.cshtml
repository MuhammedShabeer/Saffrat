                            $("#deductionModalTitle").text('@Localize("Update Deduction")');
                            $("#deductionfrm .submit").text('@Localize("Update")');
                            $("#deductionfrm input[name='Id']").val(result.id);
                            $("#deductionfrm input[name='Title']").val(result.title);
                            $("#deductionfrm input[name='Amount']").val(getNumber(result.amount));
                            $("#deductionfrm select[name='IsPercentage']").selectpicker('val', (result.isPercentage.toString()));
                            $("#deductionModal").modal('show');
