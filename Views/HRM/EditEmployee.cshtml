        $("#incomefrm").submit(function (e) {
            e.preventDefault();
            var formData = new FormData(this);

            if (performValidation($("#incomefrm"))) {
                $("#incomefrm .submit").addClass("disabled btn-progress");
                $.ajax({
                    url: '/HRM/SaveEarning',
                    type: 'POST',
