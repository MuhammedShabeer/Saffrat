        //Employee Attachments
        $('#attachment').change(
            function (e) {
                fileSize = parseInt(e.currentTarget.files[0].size, 10) / 1024;
                filesize = Math.round(fileSize);
                var html = '<div class="item d-flex align-items-center"><div class="icon"><i class="fa fa-file"></i></div><div class="content">';
                html += '<h4>' + e.currentTarget.files[0].name + ' (' + filesize + ' kb)</h4>';
                html += '</div></div>';

                $('#newattachment').html(html);
            });


        $("#attachmentfrm").submit(function (e) {
            e.preventDefault();
            var formData = new FormData(this);

            if (performValidation($("#attachmentfrm"))) {
                $("#attachmentfrm .submit").addClass("disabled btn-progress");
                $.ajax({
                    url: '/HRM/UploadAttachment',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (data) {
                        if (data.status == "success") {
                            $('#newattachment').html('');
                            $("#attachmentfrm")[0].reset();
                            successMessage('@Localize("Attachment uploaded successfully.")');
                            var html = '<div class="item d-flex align-items-center" id="attachment' + data.id + '"><div class="icon"><i class="fa fa-file"></i></div><div class="content">';
                            html += '<h4>' + data.name + '</h4>';
                            html += '<a href="javascript:void(0);" class="btn btn-sm btn-danger" onclick="DeleteAttachment(' + data.id + ')"><i class="fa fa-trash"></i> @Localize("Delete")</a>';
                            html += '<a href="/Media/EmployeeAttachment?name=' + data.name + '" class="btn btn-sm btn-primary"><i class="fa fa-download"></i> @Localize("Download")</a>';
                            html += '</div></div>';
                            $('#oldattachment').append(html);
