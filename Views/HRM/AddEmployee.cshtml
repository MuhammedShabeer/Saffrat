@model Saffrat.Models.Employee

@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Add Employee");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        @Localize("Add Employee")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item"><a asp-controller="HRM" asp-action="Employees">@Localize("Employees")</a></li>
                    <li class="breadcrumb-item">@Localize("Add Employee")</li>
                </ul>
            </div>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <ul class="nav nav-tabs nav-primary" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="employeedetails-tab" data-bs-toggle="tab" data-bs-target="#employeedetails" type="button" role="tab" aria-controls="employeedetails" aria-selected="true">@Localize("Employee Details")</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link disabled" id="payrolldetails-tab" data-bs-toggle="tab" data-bs-target="#payrolldetails" type="button" role="tab" aria-controls="payrolldetails" aria-selected="false">@Localize("Payroll")</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link disabled" id="attachmentdetails-tab" data-bs-toggle="tab" data-bs-target="#attachmentdetails" type="button" role="tab" aria-controls="attachmentdetails" aria-selected="false">@Localize("Attachments")</button>
                    </li>
                </ul>

                <div class="tab-content pt-2" id="myTabContent">
                    <div class="tab-pane fade show active" id="employeedetails" role="tabpanel" aria-labelledby="employeedetails-tab">
                        <form id="frm" class="needs-validation" novalidate>
                            <div class="row">
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Department") <code>*</code></label>
                                    <select class="form-control selectpicker" data-live-search="true" asp-for="DepartmentId" required>
                                        @foreach (var item in ViewBag.Departments)
                                        {
                                            <option value="@item.Key">@item.Value</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback">
                                        @Localize("Please select department.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Designation") <code>*</code></label>
                                    <select class="form-control selectpicker" data-live-search="true" asp-for="DesignationId" required>
                                        @foreach (var item in ViewBag.Designations)
                                        {
                                            <option value="@item.Key">@item.Value</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback">
                                        @Localize("Please select designation.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Shift") <code>*</code></label>
                                    <select class="form-control selectpicker" data-live-search="true" asp-for="ShiftId" required>
                                        @foreach (var item in ViewBag.Shifts)
                                        {
                                            <option value="@item.Key">@item.Value</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback">
                                        @Localize("Please select shift.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Name") <code>*</code></label>
                                    <input asp-for="Name" class="form-control" required />
                                    <div class="invalid-feedback">
                                        @Localize("Please enter name.")
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Joining Date") <code>*</code></label>
                                    <input asp-for="JoiningDate" type="date" class="form-control" onclick="this.showPicker()" required />
                                    <div class="invalid-feedback">
                                        @Localize("Please select date.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Leaving Date") </label>
                                    <input asp-for="LeavingDate" type="date" class="form-control" disabled />
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Email") <code>*</code></label>
                                    <input asp-for="Email" type="email" class="form-control" required />
                                    <div class="invalid-feedback">
                                        @Localize("Please enter email.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Phone") <code>*</code></label>
                                    <input asp-for="Phone" type="tel" class="form-control" required />
                                    <div class="invalid-feedback">
                                        @Localize("Please enter phone.")
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group col-md-6">
                                    <label class="control-label">@Localize("Present Address") <code>*</code></label>
                                    <textarea asp-for="PresentAddress" class="form-control" required></textarea>
                                    <div class="invalid-feedback">
                                        @Localize("Please enter present address.")
                                    </div>
                                </div>
                                <div class="form-group col-md-6">
                                    <label class="control-label">@Localize("Permanent Address") <code>*</code></label>
                                    <textarea asp-for="PermanentAddress" class="form-control" required></textarea>
                                    <div class="invalid-feedback">
                                        @Localize("Please enter permanent address.")
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Emergency Contact") <code>*</code></label>
                                    <input asp-for="EmergencyContact" type="tel" class="form-control" required />
                                    <div class="invalid-feedback">
                                        @Localize("Please enter emergency contact.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("NID Number") <code>*</code></label>
                                    <input asp-for="Nidnumber" class="form-control" required />
                                    <div class="invalid-feedback">
                                        @Localize("Please enter NID number.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Gender") <code>*</code></label>
                                    <select class="form-control selectpicker" asp-for="Gender" required>
                                        <option value="male">@Localize("Male")</option>
                                        <option value="female">@Localize("Female")</option>
                                        <option value="other">@Localize("Other")</option>
                                    </select>
                                    <div class="invalid-feedback">
                                        @Localize("Please select gender.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Religion") <code>*</code></label>
                                    <input asp-for="Religion" class="form-control" required />
                                    <div class="invalid-feedback">
                                        @Localize("Please enter religion.")
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Martial Status") <code>*</code></label>
                                    <select class="form-control selectpicker" asp-for="MaritalStatus" required>
                                        <option value="single">@Localize("Single")</option>
                                        <option value="married">@Localize("Married")</option>
                                        <option value="divorced">@Localize("Divorced")</option>
                                    </select>
                                    <div class="invalid-feedback">
                                        @Localize("Please select martial status.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("DOB") <code>*</code></label>
                                    <input asp-for="Dob" type="date" class="form-control" onclick="this.showPicker()" required />
                                    <div class="invalid-feedback">
                                        @Localize("Please select date.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Salary Type") <code>*</code></label>
                                    <input asp-for="PayslipType" class="form-control" required />
                                    <div class="invalid-feedback">
                                        @Localize("Please enter salary type.")
                                    </div>
                                </div>
                                <div class="form-group col-md-3">
                                    <label class="control-label">@Localize("Salary") <code>*</code></label>
                                    <div class="input-group">
                                        <div class="input-group-text">@GetSetting.CurrencySymbol</div>
                                        <input asp-for="Salary" type="text" inputmode="numeric" class="form-control cleave-number" required />
                                    </div>
                                    <div class="invalid-feedback">
                                        @Localize("Please enter salary.")
                                    </div>
                                </div>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="Status" checked>
                                <label class="control-label" asp-for="Status">@Localize("Status (InActive/Active)")</label>
                            </div>
                            <div class="form-group">
                                <label class="control-label">@Localize("Image")</label>
                                <div id="imagePreview" class="image-preview" style="background-image:url('/uploads/placeholder_image.png')">
                                    <label for="employeeimage">@Localize("Choose File")</label>
                                    <input type="file" accept=".jpg, .jpeg, .png, .gif, .svg, .webp, .Jpg, .ico" id="employeeimage" name="EmployeeImage">
                                </div>
                            </div>
                            <h4>@Localize("Bank Account")</h4>
                            <div class="row">
                                <div class="form-group col-md-4">
                                    <label class="control-label">@Localize("Account Holder Name")</label>
                                    <input asp-for="AccountHolderName" class="form-control" />
                                </div>
                                <div class="form-group col-md-4">
                                    <label class="control-label">@Localize("Account Number")</label>
                                    <input asp-for="AccountNumber" class="form-control" />
                                </div>
                                <div class="form-group col-md-4">
                                    <label class="control-label">@Localize("Bank Name")</label>
                                    <input asp-for="BankName" class="form-control" />
                                </div>
                            </div>
                            <div class="row">
                                <div class="form-group col-md-4">
                                    <label class="control-label">@Localize("Bank Identifier Code")</label>
                                    <input asp-for="BankIdentifierCode" class="form-control" />
                                </div>
                                <div class="form-group col-md-4">
                                    <label class="control-label">@Localize("Branch Location")</label>
                                    <input asp-for="BranchLocation" class="form-control" />
                                </div>
                                <div class="form-group col-md-4">
                                    <label class="control-label">@Localize("Tax Payer Id")</label>
                                    <input asp-for="TaxPayerId" class="form-control" />
                                </div>
                            </div>
                            <div class="form-group">
                                <button class="btn btn-primary mr-1" type="submit" id="submit">@Localize("Save")</button>
                                <a asp-controller="HRM" asp-action="Employees" class="btn btn-secondary mr-1">@Localize("Back To List")</a>
                            </div>
                        </form>
                    </div>
                    <div class="tab-pane fade" id="payrolldetails" role="tabpanel" aria-labelledby="payrolldetails-tab">
                    </div>
                    <div class="tab-pane fade" id="attachmentdetails" role="tabpanel" aria-labelledby="attachmentdetails-tab">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section scripts{
    <script>
        $("#hrm-menu").addClass("active");
        $("#employeeList-menu").addClass("active");

        employeeimage.onchange = evt => {
            const [file] = employeeimage.files
            if (file) {
                $('#imagePreview').css('background-image', 'url("' + URL.createObjectURL(file) + '")');
            }
        }

        $("#frm").submit(function (e) {
            e.preventDefault();
            var formData = new FormData(this);

            if (performValidation($("#frm"))) {
                $("#submit").addClass("disabled btn-progress");
                $.ajax({
                    url: '/HRM/AddEmployee',
                    type: 'POST',
                    data: formData,
                    dataType: "json",
                    contentType: false,
                    processData: false,
                    success: function (data) {
                        if (data.status == "success") {
                            setCookie("successMessage", '@Localize("Employee created successfully.")');
                            window.location.href = '/HRM/Employees';
                        }
                        else {
                            errorMessage(data.message);
                        }
                    },
                    error: function (data) {
                        if (data.status == 401) {
                            window.location.href = '/Account/Login';
                        }
                        else if (data.status == 403) {
                            errorMessage('@Localize("Access denied.")');
                        }
                        else {
                            console.log(JSON.stringify(data));
                        }
                    },
                    complete: function () {
                        $("#submit").removeClass("disabled btn-progress");
                        $("#frm").removeClass("was-validated");
                    }
                });
            }
        });
    </script>
}