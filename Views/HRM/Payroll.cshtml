@model IEnumerable<Saffrat.Models.Payroll>

@using Saffrat.Resources
@using System.Globalization
@inherits LocService<TModel>

@{
    int month = Convert.ToInt32(ViewBag.month);
    int year = Convert.ToInt32(ViewBag.year);
    int currentyear = DateTime.UtcNow.Year;
    bool isAllPeriods = (month == 0 || year == 0);
    ViewData["Title"] = isAllPeriods ? @Localize("Flexible Payroll Management") : @Localize("Payroll");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles{
    <style>
        @@media screen {
            #printSection {
                display: none;
            }
        }

        @@media print {
            body * {
                visibility: hidden;
            }

            #printSection, #printSection * {
                visibility: visible;
            }

            #printSection {
                position: absolute;
                left: 0;
                top: 0;
                right: 0;
                min-width: 800px;
            }

            .col-md-1 {
                flex: 0 0 auto;
                width: 8.33333333%;
            }

            .col-md-2 {
                flex: 0 0 auto;
                width: 16.66666667%;
            }

            .col-md-3 {
                flex: 0 0 auto;
                width: 25%;
            }

            .col-md-4 {
                flex: 0 0 auto;
                width: 33.33333333%;
            }

            .col-md-5 {
                flex: 0 0 auto;
                width: 41.66666667%;
            }

            .col-md-6 {
                flex: 0 0 auto;
                width: 50%;
            }

            .col-md-7 {
                flex: 0 0 auto;
                width: 58.33333333%;
            }

            .col-md-8 {
                flex: 0 0 auto;
                width: 66.66666667%;
            }

            .col-md-9 {
                flex: 0 0 auto;
                width: 75%;
            }

            .col-md-10 {
                flex: 0 0 auto;
                width: 83.33333333%;
            }

            .col-md-11 {
                flex: 0 0 auto;
                width: 91.66666667%;
            }

            .col-md-12 {
                flex: 0 0 auto;
                width: 100%;
            }
        }

        /* Payroll Payment Styles */
        .payment-stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .payment-stat-card.success {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        }

        .payment-stat-card.warning {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        }

        .payment-stat-card.danger {
            background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        }

        .payment-stat-card h5 {
            margin: 0 0 10px 0;
            font-size: 14px;
            opacity: 0.9;
        }

        .payment-stat-card .amount {
            font-size: 24px;
            font-weight: bold;
        }

        .payment-progress-bar {
            height: 8px;
            background-color: rgba(255,255,255,0.3);
            border-radius: 4px;
            overflow: hidden;
            margin-top: 10px;
        }

        .payment-progress-bar .progress-fill {
            background-color: rgba(255,255,255,0.8);
            height: 100%;
            transition: width 0.3s ease;
        }

        .badge-paid {
            background-color: #28a745;
            color: white;
        }

        .badge-partial {
            background-color: #ffc107;
            color: black;
        }

        .badge-unpaid {
            background-color: #dc3545;
            color: white;
        }

        .border-top-dash {
            border-top: 1px dashed #ccc !important;
        }

        .italic {
            font-style: italic;
        }

        /* Custom Payroll Generation Modal Styles */
        .bg-light-primary {
            background-color: #f0f7ff !important;
        }

        .border-start-lg {
            border-left-width: 5px !important;
        }

        .border-start-primary {
            border-left-color: #007bff !important;
        }

        .employee-select-checkbox {
            width: 1.25rem;
            height: 1.25rem;
            cursor: pointer;
        }

        #employeeListContainer .card {
            transition: all 0.2s ease;
            border-radius: 8px;
        }

        #employeeListContainer .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
        }
    </style>
}
<!-- Filter and Controls -->
<div class="row mb-4">
    <div class="col-md-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3">
                <form asp-action="Payroll" method="get" class="row g-3 align-items-center">
                    <div class="col-auto">
                        <h5 class="mb-0">
                            <i class="fas fa-calendar-alt text-primary me-2"></i>
                            @(isAllPeriods ? Localize("All Periods") : $"{CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month)} {year}")
                        </h5>
                    </div>
                    @if (!isAllPeriods) { 
                        <div class="col-auto ms-auto d-flex gap-2">
                            <select name="month" class="form-select form-select-sm d-inline-block w-auto">
                                @for (int i = 1; i <= 12; i++)
                                {
                                    <option value="@i" selected="@(i == month)">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
                                }
                            </select>
                            <select name="year" class="form-select form-select-sm d-inline-block w-auto">
                                @for (int i = currentyear - 5; i <= currentyear + 1; i++)
                                {
                                    <option value="@i" selected="@(i == year)">@i</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary">@Localize("Filter")</button>
                            <button type="button" onclick="OpenGenerateModal();" class="btn btn-sm btn-success ms-2">
                                <i class="fas fa-plus-circle me-1"></i>@Localize("Generate")
                            </button>
                        </div>
                    }
                    else {
                        <div class="col-auto ms-auto">
                            <a asp-action="Payroll" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-calendar-check me-1"></i>@Localize("Switch to Monthly View")
                            </a>
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>

    <partial name="_PayrollSummaryCards" />

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">

                <div class="table-responsive">
                    <table class="table table-hover" id="datatable">
                        <thead>
                            <tr>
                                <th>@Localize("Employee")</th>
                                <th>@Localize("Month/Year")</th>
                                <th>@Localize("Type")</th>
                                <th>@Localize("Net Salary")</th>
                                <th>@Localize("Status")</th>
                                <th>@Localize("Total Paid")</th>
                                <th>@Localize("Balance")</th>
                                <th>@Localize("Action")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var id = "row" + item.Id;
                                <tr id="@id">
                                    <td>
                                        <strong>@item.Employee.Name</strong><br>
                                        <small class="text-muted">EMP-@item.Employee.Id | @(item.Employee.Department?.Title ?? "-")</small>
                                    </td>
                                    <td>@item.Month/@item.Year</td>
                                    <td>@item.PayrollType</td>
                                    <td><strong>@item.NetSalary.ToString("0.00")</strong></td>
                                    <td>
                                        @{
                                            string statusClass = "badge-unpaid";
                                            string statusText = item.PaymentStatus ?? "Unpaid";
                                            if (item.PaymentStatus == "Paid")
                                            {
                                                statusClass = "badge-paid";
                                            }
                                            else if (item.PaymentStatus == "PartiallyPaid")
                                            {
                                                statusClass = "badge-partial";
                                                statusText = "Partially Paid";
                                            }
                                        }
                                        <div class="badge @statusClass">@Localize(statusText)</div>
                                    </td>
                                    <td>
                                        <strong>@(item.TotalAmountPaid > 0 ? item.TotalAmountPaid.ToString("0.00") : "0.00")</strong>
                                    </td>
                                    <td>
                                        <span class="text-danger">
                                            <strong>@((item.NetSalary - item.TotalAmountPaid).ToString("0.00"))</strong>
                                        </span>
                                    </td>
                                    <td>
                                        <div class="action-btn-group d-flex gap-1">
                                            <button class="btn btn-sm btn-primary" onclick="OpenInvoiceModal(@item.Id);" title="@Localize("View Payslip")">
                                                <i class="fas fa-file-invoice-dollar"></i>
                                            </button>
                                            @if (item.PaymentStatus != "Paid")
                                            {
                                                decimal remToPay = item.NetSalary - item.TotalAmountPaid;
                                                <button class="btn btn-sm btn-success" onclick="OpenPaymentModal(@item.Id, '@item.Employee.Name', @item.NetSalary, @remToPay, '@item.PaymentStatus', '@item.Month/@item.Year');" title="@Localize("Record Payment")">
                                                    <i class="fas fa-money-bill-wave"></i>
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-info" onclick="ViewPaymentHistory(@item.Id);" title="@Localize("Payment History")">
                                                <i class="fas fa-history"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger" onclick="Delete(@item.Id);" title="@Localize("Delete")">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


@section models{

    <!-- Enhanced Generate Payroll Modal with Custom Salary Option -->
    <div class="modal fade" id="generateModal" tabindex="-1" role="dialog" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">
                        <i class="fas fa-file-invoice-dollar me-2"></i>@Localize("Generate Payroll")
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="frmgenerate" class="needs-validation" novalidate="">
                    <div class="modal-body">
                        <!-- Month and Year Selection -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label class="form-label fw-bold">@Localize("Month") <code>*</code></label>
                                    <select name="month" id="genMonth" class="form-select" required>
                                        <option value="">@Localize("Select Month")</option>
                                        @for (int i = 1; i < 13; i++)
                                        {
                                            var m = CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(i);
                                            <option value="@i">@m</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback">
                                        @Localize("Please select month.")
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label class="form-label fw-bold">@Localize("Year") <code>*</code></label>
                                    <select name="year" id="genYear" class="form-select" required>
                                        <option value="">@Localize("Select Year")</option>
                                        @{
                                            int ye = currentyear;
                                        }
                                        @for (int i = 1; i < 5; i++)
                                        {
                                            <option value="@ye">@ye</option>
                                            ye--;
                                        }
                                    </select>
                                    <div class="invalid-feedback">
                                        @Localize("Please select year.")
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Bank Selection for Initial Payment -->
                        <div id="initialPaymentBankSection" style="display: none;" class="mb-3">
                            <label class="form-label fw-bold">@Localize("Bank/Cash Account") <code>*</code></label>
                            <select name="glAccountId" id="genBankId" class="form-select" data-live-search="true">
                                <option value="">@Localize("Select Bank/Cash Account")</option>
                                @if (ViewBag.bankAccounts != null)
                                {
                                    foreach (var acc in ViewBag.bankAccounts)
                                    {
                                        <option value="@acc.Id">@acc.AccountCode - @acc.AccountName</option>
                                    }
                                }
                            </select>
                            <small class="text-muted">@Localize("Account to deduct initial payments from.")</small>
                        </div>

                        <!-- Toggle for Custom Salary Mode -->
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="useCustomSalary" onchange="ToggleCustomSalaryMode(this)">
                            <label class="form-check-label" for="useCustomSalary">
                                <strong>@Localize("Use Custom Salary Amounts for Each Employee")</strong>
                                <small class="text-muted d-block">@Localize("Check this to set different salary amounts for each employee this month")</small>
                            </label>
                        </div>

                        <!-- Custom Salary Section (Hidden by Default) -->
                        <div id="customSalarySection" style="display: none;" class="border rounded p-3 mb-3 bg-light">
                            <h6 class="fw-bold mb-3">
                                <i class="fas fa-users me-2"></i>@Localize("Employee Salary Configuration")
                            </h6>
                            <div class="alert alert-info" role="alert">
                                <i class="fas fa-info-circle me-2"></i>
                                @Localize("Enter custom salary and optional initial payment amount for each employee.")
                            </div>
                            <div id="employeeListContainer" style="max-height: 400px; overflow-y: auto;">
                                <!-- Employees will be loaded here dynamically -->
                                <div class="text-center text-muted">
                                    <i class="fas fa-spinner fa-spin"></i> @Localize("Loading employees...")
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localize("Cancel")</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-check me-1"></i>@Localize("Generate")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <partial name="_PayrollInvoiceModal" />
    <partial name="_PayrollPaymentModal" />
    <partial name="_PayrollHistoryModal" />
}

@section scripts{
    <script>

        $('#month').val('@ViewBag.month');
        $('#year').val('@ViewBag.year');

        $("#hrm-menu").addClass("active");
        $("#payrollList-menu").addClass("active");

        var dt; // Will be initialized in $(document).ready()

        function OpenGenerateModal() {
            // Reset form
            document.getElementById('frmgenerate').reset();
            document.getElementById('useCustomSalary').checked = false;
            document.getElementById('customSalarySection').style.display = 'none';
            $("#generateModal").modal('show');
        }

        // Toggle custom salary entry mode
        function ToggleCustomSalaryMode(checkbox) {
            const customSection = document.getElementById('customSalarySection');
            const bankSection = document.getElementById('initialPaymentBankSection');
            if (checkbox.checked) {
                const month = $('#genMonth').val();
                const year = $('#genYear').val();
                
                if (!month || !year) {
                    checkbox.checked = false;
                    errorMessage('@Localize("Please select month and year first.")');
                    return;
                }
                
                customSection.style.display = 'block';
                bankSection.style.display = 'block';
                LoadEmployeesForCustomPayroll();
            } else {
                customSection.style.display = 'none';
                bankSection.style.display = 'none';
            }
        }

        // Load employees for custom salary configuration
        function LoadEmployeesForCustomPayroll() {
            const month = $('#genMonth').val();
            const year = $('#genYear').val();
            
            if (!month || !year || !document.getElementById('useCustomSalary').checked) return;

            const container = document.getElementById('employeeListContainer');
            container.innerHTML = '<div class="text-center p-4"><div class="spinner-border text-primary" role="status"></div></div>';

            jQuery.ajax({
                url: `/HRM/GetEmployeesForPayroll?month=${month}&year=${year}`,
                method: "GET",
                dataType: "json",
                success: function (data) {
                    if (data.status == "success") {
                        let html = '';
                        
                        // Add Select All header
                        if (data.data.length > 0) {
                            html += `
                                <div class="card mb-3 bg-white border-primary shadow-sm">
                                    <div class="card-body p-2 px-3">
                                        <div class="row align-items-center">
                                            <div class="col-auto">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="selectAllEmployees" onchange="ToggleSelectAllEmployees(this)">
                                                    <label class="form-check-label fw-bold" for="selectAllEmployees">@Localize("Select All Employees")</label>
                                                </div>
                                            </div>
                                            <div class="col text-end border-start">
                                                <span class="badge bg-light text-dark me-2">@Localize("Total Found"): <span id="totalFoundCount">${data.data.length}</span></span>
                                                <span class="badge bg-primary text-white">@Localize("Selected"): <span id="selectedCount">0</span></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            `;
                        }

                        data.data.forEach(function (emp, index) {
                            html += `
                                <div class="card mb-2 shadow-sm border-start-lg border-start-primary">
                                    <div class="card-body p-3">
                                        <div class="row align-items-center">
                                            <div class="col-auto pe-0">
                                                <div class="form-check">
                                                    <input class="form-check-input employee-select-checkbox" type="checkbox" 
                                                           data-emp-id="${emp.id}" 
                                                           onchange="UpdateSelectedCount()">
                                                </div>
                                            </div>
                                            <div class="col-md-3">
                                                <div class="fw-bold text-primary">${emp.name}</div>
                                                <small class="text-muted d-block">${emp.departmentName} - ${emp.designationName}</small>
                                            </div>
                                            <div class="col-md-2 text-center border-start border-end">
                                                <small class="text-muted d-block">@Localize("Default Salary")</small>
                                                <div class="fw-bold text-dark">${GetCurrency(getNumber(emp.salary.toFixed(2)))}</div>
                                            </div>
                                            <div class="col-md-6 ps-4">
                                                <div class="row g-2">
                                                    <div class="col-6">
                                                        <label class="form-label small fw-bold mb-1">@Localize("Custom Salary")</label>
                                                        <div class="input-group input-group-sm">
                                                            <span class="input-group-text bg-light"><i class="fas fa-coins fa-xs"></i></span>
                                                            <input type="number" class="form-control custom-salary-input" 
                                                                   data-emp-id="${emp.id}" 
                                                                   value="${emp.salary.toFixed(2)}" 
                                                                   step="0.01" min="0.01" required oninput="UpdateSelectedCount()">
                                                        </div>
                                                    </div>
                                                    <div class="col-6">
                                                        <label class="form-label small fw-bold mb-1">@Localize("Initial Payment")</label>
                                                        <div class="input-group input-group-sm">
                                                            <span class="input-group-text bg-light"><i class="fas fa-wallet fa-xs"></i></span>
                                                            <input type="number" class="form-control initial-payment-input" 
                                                                   data-emp-id="${emp.id}" 
                                                                   value="0.00" 
                                                                   step="0.01" min="0" oninput="UpdateSelectedCount()">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            `;
                        });

                        container.innerHTML = html || `<div class="alert alert-warning text-center">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                @Localize("No employees without payroll found for this period.")
                            </div>`;
                        
                        UpdateSelectedCount();
                    } else {
                        errorMessage(data.message);
                    }
                },
                error: function () {
                    errorMessage('@Localize("Failed to load employees.")');
                }
            });
        }

        function ToggleSelectAllEmployees(checkbox) {
            $('.employee-select-checkbox').prop('checked', checkbox.checked);
            UpdateSelectedCount();
        }

        function UpdateSelectedCount() {
            const count = $('.employee-select-checkbox:checked').length;
            $('#selectedCount').text(count);
            
            // Highlight cards of selected employees
            $('.employee-select-checkbox').each(function() {
                const card = $(this).closest('.card');
                if (this.checked) {
                    card.addClass('border-primary bg-light-primary');
                } else {
                    card.removeClass('border-primary bg-light-primary');
                }
            });
            
            // Update Select All checkbox state
            const total = $('.employee-select-checkbox').length;
            if (total > 0) {
                $('#selectAllEmployees').prop('checked', count === total);
                $('#selectAllEmployees').prop('indeterminate', count > 0 && count < total);
            }
        }

        function OpenInvoiceModal(id) {
            if (id > 0) {
                $('#i-Earnings tr').slice(1).remove();
                $('#i-Deductions tr').slice(1).remove();
                jQuery.ajax({
                    url: "/HRM/PayrollDetail",
                    method: "GET",
                    data: {
                        Id: id
                    },
                    dataType: "json",
                    success: function (data) {
                        if (data.status == "success") {
                            var res = data.data;
                            $('#i-EmployeeId').text(res.employee.id);
                            $('#i-EmployeeName').text(res.employee.name);
                            $('#i-EmployeeDepartment').text(res.employee.department.title);
                            $('#i-EmployeeDesignation').text(res.employee.designation.title);
                            $('#i-EmployeeAddress').text(res.employee.presentAddress);
                            $('#i-JoiningDate').text(getDate(res.employee.joiningDate));
                            $('#i-BankName').text(res.employee.bankName || '-');
                            $('#i-AccountNumber').text(res.employee.accountNumber || '-');

                            $('#i-PayrollNo').text(res.id);
                            $('#i-PayType').text(res.payrollType);
                            $('#i-Period').text(res.month + '/' + res.year);
                            
                            // Status Badge mapping
                            let statusHtml = '';
                            if (res.paymentStatus === 'Paid') statusHtml = '<span class="badge bg-success">@Localize("PAID")</span>';
                            else if (res.paymentStatus === 'PartiallyPaid') statusHtml = '<span class="badge bg-warning">@Localize("PARTIAL")</span>';
                            else statusHtml = '<span class="badge bg-danger">@Localize("UNPAID")</span>';
                            $('#i-StatusBadge').html(statusHtml);

                            $('#i-BasicPay').text(GetCurrency(getNumber(res.salary)));
                            var detail = res.payrollDetails;
                            var earning = res.salary;
                            var deduction = 0;
                            for (var i = 0; i < detail.length; i++) {
                                if (detail[i].amountType == 'Earning') {
                                    var html = '<tr><td>' + detail[i].title + '</td>';
                                    if (detail[i].isPercentage) {
                                        var am = (detail[i].amount * res.salary) / 100;
                                        html += '<td class="text-end">(' + getNumber(detail[i].amount) + ' %) ' + GetCurrency(getNumber(am)) + '</td></tr>';
                                        earning += am;
                                    }
                                    else {
                                        html += '<td class="text-end">' + GetCurrency(getNumber(detail[i].amount)) + '</td></tr>';
                                        earning += detail[i].amount;
                                    }
                                    $('#i-Earnings').append(html);
                                }
                                else {
                                    var html = '<tr><td>' + detail[i].title + '</td>';
                                    if (detail[i].isPercentage) {
                                        var am = (detail[i].amount * res.salary) / 100;
                                        html += '<td class="text-end">(' + getNumber(detail[i].amount) + ' %) ' + GetCurrency(getNumber(am)) + '</td></tr>';
                                        deduction += am;
                                    }
                                    else {
                                        html += '<td class="text-end">' + GetCurrency(getNumber(detail[i].amount)) + '</td></tr>';
                                        deduction += detail[i].amount;
                                    }
                                    $('#i-Deductions').append(html);
                                }
                            }

                            $('#i-TotalEarnings').text(GetCurrency(getNumber(earning.toFixed(2))));
                            $('#i-TotalDeductions').text(GetCurrency(getNumber(deduction.toFixed(2))));
                            $('#i-NetPay').text(GetCurrency(getNumber(res.netSalary.toFixed(2))));
                            $('#i-NetPayWords').text(toWords(res.netSalary) + ' Only');
                            
                            // Payment Summary
                            $('#i-TotalPaid').text(GetCurrency(getNumber(res.totalAmountPaid.toFixed(2))));
                            var remaining = res.netSalary - res.totalAmountPaid;
                            $('#i-Remaining').text(GetCurrency(getNumber(remaining.toFixed(2))));

