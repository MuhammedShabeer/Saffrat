        // Submit custom payroll with individual salary amounts
        function SubmitCustomPayroll(month, year) {
            const glAccountId = $('#genBankId').val();
            const selectedCheckboxes = document.querySelectorAll('.employee-select-checkbox:checked');
            const customData = [];

            selectedCheckboxes.forEach(function (checkbox) {
                const empId = parseInt(checkbox.getAttribute('data-emp-id'));
                const customSalaryInput = document.querySelector(`.custom-salary-input[data-emp-id="${empId}"]`);
                const initialPaymentInput = document.querySelector(`.initial-payment-input[data-emp-id="${empId}"]`);
                
                const customSalary = parseFloat(customSalaryInput.value);
                const initialPayment = parseFloat(initialPaymentInput.value) || 0;

                if (customSalary > 0) {
                    customData.push({
                        employeeId: empId,
                        customSalary: customSalary,
                        initialPayingAmount: initialPayment
                    });
                }
            });

            if (customData.length === 0) {
                errorMessage('@Localize("Please select at least one employee and enter a salary.")');
                return;
            }

            const hasInitialPayments = customData.some(d => d.initialPayingAmount > 0);
            if (hasInitialPayments && !glAccountId) {
                errorMessage('@Localize("Please select a bank/cash account for initial payments.")');
                return;
            }

            $("#frmgenerate button[type='submit']").addClass("disabled btn-progress");

            $.ajax({
                url: `/HRM/GenerateCustomPayroll?month=${month}&year=${year}&glAccountId=${glAccountId || ''}`,
                type: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                data: JSON.stringify(customData),
                dataType: "json",
                success: function (data) {
                    if (data.status == "success") {
                        // Auto-accrue payrolls with initial payments
                        const hasInitialPayments = Array.from(document.querySelectorAll('.initial-payment-input'))
                            .some(input => parseFloat(input.value) > 0);

                        if (hasInitialPayments) {
                            // Fetch the newly created payrolls and accrue them
                            setTimeout(() => {
                                fetch('/AccountingEngine/GetPayrollsList')
                                    .then(r => r.json())
                                    .then(result => {
                                        if (result.status === 'success' && result.data && result.data.length > 0) {
                                            // Accrue only the latest payrolls that don't have JournalEntryId
                                            const latestPayrolls = result.data.filter(p => !p.journalEntryId).slice(0, 5);
                                            Promise.all(latestPayrolls.map(p => 
                                                fetch(`/AccountingEngine/AccruePayroll?payrollId=${p.id}`, { method: 'POST' })
                                            )).then(() => {
                                                setCookie("successMessage", '@Localize("Payroll generated and accrued successfully.")');
                                                window.location.reload(true);
                                            });
                                        }
                                    }).catch(e => {
                                        console.error('Auto-accrue failed:', e);
                                        setCookie("successMessage", '@Localize("Payroll generated. Please accrue manually if needed.")');
                                        window.location.reload(true);
                                    });
                            }, 500);
                        } else {
                            setCookie("successMessage", '@Localize("Payroll generated successfully with custom amounts.")');
                            window.location.reload(true);
                        }
                    }
                    else {
                        errorMessage(data.message);
                    }
                },
                error: function (xhr) {
                    console.error('Error:', xhr);
                    errorMessage('@Localize("Failed to generate payroll. Please check the console for details.")');
                },
                complete: function () {
                    $("#frmgenerate button[type='submit']").removeClass("disabled btn-progress");
                }
            });
        }

        // Calculate Payment Statistics
        function calculatePaymentStats() {
            let totalPayroll = 0;
            let totalPaid = 0;
            let partialCount = 0;
            let unpaidCount = 0;

            dt.rows({ search: 'applied' }).every(function () {
                let row = this.node();
                if (!row) return;

                // Extract numbers from row data - using getLocaleNumber for actual numeric values
                // Column indices (1-indexed): 4: Net Salary, 5: Status, 6: Total Paid
                let netSalary = getLocaleNumber($(row).find('td:nth-child(4)').text().trim());
                let paidAmount = getLocaleNumber($(row).find('td:nth-child(6)').text().trim());
                
                totalPayroll += netSalary;
                totalPaid += paidAmount;

                let status = $(row).find('td:nth-child(5)').text().trim() || '';
                if (status.includes('Partially Paid')) {
                    partialCount++;
                } else if (status.includes('Unpaid')) {
                    unpaidCount++;
                }
            });

            $('#totalPayroll').text(GetCurrency(totalPayroll.toFixed(2)));
            $('#totalPaid').text(GetCurrency(totalPaid.toFixed(2)));
            $('#partiallyPaid').text(partialCount);
            $('#unpaidCount').text(unpaidCount);
        }

