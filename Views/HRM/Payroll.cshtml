@model IEnumerable<Saffrat.Models.Payroll>

@using Saffrat.Resources
@using System.Globalization
@inherits LocService<TModel>

@{
    int month = Convert.ToInt32(ViewBag.month);
    int year = Convert.ToInt32(ViewBag.year);
    int currentyear = DateTime.UtcNow.Year;
    ViewData["Title"] = @Localize("Payroll");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles{
    <style>
        @@media screen {
            #printSection {
                display: none;
            }
        }

        @@media print {
            body * {
                visibility: hidden;
            }

            #printSection, #printSection * {
                visibility: visible;
            }

            #printSection {
                position: absolute;
                left: 0;
                top: 0;
                right: 0;
                min-width: 800px;
            }

            .col-md-1 {
                flex: 0 0 auto;
                width: 8.33333333%;
            }

            .col-md-2 {
                flex: 0 0 auto;
                width: 16.66666667%;
            }

            .col-md-3 {
                flex: 0 0 auto;
                width: 25%;
            }

            .col-md-4 {
                flex: 0 0 auto;
                width: 33.33333333%;
            }

            .col-md-5 {
                flex: 0 0 auto;
                width: 41.66666667%;
            }

            .col-md-6 {
                flex: 0 0 auto;
                width: 50%;
            }

            .col-md-7 {
                flex: 0 0 auto;
                width: 58.33333333%;
            }

            .col-md-8 {
                flex: 0 0 auto;
                width: 66.66666667%;
            }

            .col-md-9 {
                flex: 0 0 auto;
                width: 75%;
            }

            .col-md-10 {
                flex: 0 0 auto;
                width: 83.33333333%;
            }

            .col-md-11 {
                flex: 0 0 auto;
                width: 91.66666667%;
            }

            .col-md-12 {
                flex: 0 0 auto;
                width: 100%;
            }
        }

        /* Payroll Payment Styles */
        .payment-stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .payment-stat-card.success {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        }

        .payment-stat-card.warning {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        }

        .payment-stat-card.danger {
            background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
        }

        .payment-stat-card h5 {
            margin: 0 0 10px 0;
            font-size: 14px;
            opacity: 0.9;
        }

        .payment-stat-card .amount {
            font-size: 24px;
            font-weight: bold;
        }

        .payment-progress-bar {
            height: 8px;
            background-color: rgba(255,255,255,0.3);
            border-radius: 4px;
            overflow: hidden;
            margin-top: 10px;
        }

        .payment-progress-bar .progress-fill {
            background-color: rgba(255,255,255,0.8);
            height: 100%;
            transition: width 0.3s ease;
        }

        .badge-paid {
            background-color: #28a745;
            color: white;
        }

        .badge-partial {
            background-color: #ffc107;
            color: black;
        }

        .badge-unpaid {
            background-color: #dc3545;
            color: white;
        }
    </style>
}
<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        @Localize("Payroll")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item">@Localize("Payroll")</li>
                </ul>
            </div>
            <div class="col">
                <div class="float-end">
                    <button onclick="OpenGenerateModal();" class="btn btn-primary">@Localize("Generate")</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Payment Summary Statistics -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="payment-stat-card">
            <h5><i class="fas fa-money-bill-wave me-2"></i>@Localize("Total Payroll")</h5>
            <div class="amount" id="totalPayroll">0.00</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="payment-stat-card success">
            <h5><i class="fas fa-check-circle me-2"></i>@Localize("Total Paid")</h5>
            <div class="amount" id="totalPaid">0.00</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="payment-stat-card warning">
            <h5><i class="fas fa-hourglass-half me-2"></i>@Localize("Partially Paid")</h5>
            <div class="amount" id="partiallyPaid">0</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="payment-stat-card danger">
            <h5><i class="fas fa-exclamation-circle me-2"></i>@Localize("Unpaid")</h5>
            <div class="amount" id="unpaidCount">0</div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <form asp-action="Payroll" asp-controller="HRM" method="get" class="needs-validation" novalidate="">
                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label class="control-label">@Localize("Month") <code>*</code></label>
                            <select id="month" name="month" class="form-control selectpicker" required>
                                @for (int i = 1; i < 13; i++)
                                {
                                    var m = CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(i);
                                    <option value="@i">@m</option>
                                }
                            </select>
                            <div class="invalid-feedback">
                                @Localize("Please select month.")
                            </div>
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="control-label">@Localize("Year") <code>*</code></label>
                            <select id="year" name="year" class="form-control selectpicker" required>
                                @{
                                    int y = currentyear;
                                }
                                @for (int i = 1; i < 13; i++)
                                {
                                    <option value="@y">@y</option>
                                    y--;
                                }
                            </select>
                            <div class="invalid-feedback">
                                @Localize("Please select year.")
                            </div>
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="w-100 d-none d-md-inline-block">&nbsp;</label>
                            <button class="btn btn-primary btn-icon" type="submit"><i class="fas fa-paper-plane"></i> @Localize("Filter")</button>
                        </div>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table" id="datatable">
                        <thead>
                            <tr>
                                <th>@Localize("#")</th>
                                <th>@Localize("Employee")</th>
                                <th>@Localize("Payroll Type")</th>
                                <th>@Localize("Basic Salary")</th>
                                <th>@Localize("Net Salary")</th>
                                <th>@Localize("Month-Year")</th>
                                <th>@Localize("Payment Status")</th>
                                <th>@Localize("Paid Amount")</th>
                                <th>@Localize("Remaining")</th>
                                <th>@Localize("Generated At")</th>
                                <th>@Localize("Action")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var id = "row" + item.Id;
                                <tr id="@id">
                                    <td>@item.Id</td>
                                    <td>
                                        @String.Format("{0} (EMP-{1})", item.Employee.Name, item.Employee.Id) <br />
                                        @String.Format("{0} - {1}", item.Employee.Department.Title, item.Employee.Designation.Title) <br />
                                    </td>
                                    <td>@item.PayrollType</td>
                                    <td>@item.Salary</td>
                                    <td>@item.NetSalary</td>
                                    <td>@item.Month-@item.Year</td>
                                    <td>
                                        @{
                                            string statusClass = "badge-unpaid";
                                            string statusText = item.PaymentStatus ?? "Unpaid";
                                            if (item.PaymentStatus == "Paid")
                                            {
                                                statusClass = "badge-paid";
                                            }
                                            else if (item.PaymentStatus == "PartiallyPaid")
                                            {
                                                statusClass = "badge-partial";
                                                statusText = "Partially Paid";
                                            }
                                        }
                                        <div class="badge @statusClass">@Localize(statusText)</div>
                                    </td>
                                    <td>
                                        <strong>@(item.TotalAmountPaid > 0 ? item.TotalAmountPaid.ToString("0.00") : "0.00")</strong>
                                    </td>
                                    <td>
                                        <span class="text-danger">@(item.RemainingBalance > 0 ? item.RemainingBalance.ToString("0.00") : item.NetSalary.ToString("0.00"))</span>
                                    </td>
                                    <td>@item.GeneratedAt</td>
                                    <td>
                                        <button class="btn btn-sm btn-light dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"><i class="fas fa-bars me-1"></i></button>
                                        <div class="dropdown-menu">
                                            @if (item.PaymentStatus != "Paid")
                                            {
                                                <a class="dropdown-item btn" onclick="OpenPaymentModal(@item.Id, '@item.Employee.Name', @item.NetSalary, @(item.RemainingBalance > 0 ? item.RemainingBalance : item.NetSalary), '@item.PaymentStatus');"><i class="fas fa-money-bill me-2"></i>@Localize("Record Payment")</a>
                                            }
                                            <a class="dropdown-item btn" onclick="ViewPaymentHistory(@item.Id);"><i class="fas fa-history me-2"></i>@Localize("Payment History")</a>
                                            <a class="dropdown-item btn" onclick="OpenInvoiceModal(@item.Id);"><i class="fas fa-print me-2"></i>@Localize("View Payslip")</a>
                                            @if (item.PaymentStatus == "Unpaid")
                                            {
                                                <a class="dropdown-item btn" onclick="PayInvoice(@item.Id);"><i class="fas fa-check-circle me-2"></i>@Localize("Mark Fully Paid")</a>
                                            }
                                            <a class="dropdown-item btn" onclick="Delete(@item.Id);"><i class="fas fa-trash me-2"></i>@Localize("Delete")</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


@section models{

    <!-- Enhanced Generate Payroll Modal with Custom Salary Option -->
    <div class="modal fade" id="generateModal" tabindex="-1" role="dialog" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">
                        <i class="fas fa-file-invoice-dollar me-2"></i>@Localize("Generate Payroll")
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="frmgenerate" class="needs-validation" novalidate="">
                    <div class="modal-body">
                        <!-- Month and Year Selection -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label class="form-label fw-bold">@Localize("Month") <code>*</code></label>
                                    <select name="month" id="genMonth" class="form-select" required>
                                        <option value="">@Localize("Select Month")</option>
                                        @for (int i = 1; i < 13; i++)
                                        {
                                            var m = CultureInfo.CurrentCulture.DateTimeFormat.GetAbbreviatedMonthName(i);
                                            <option value="@i">@m</option>
                                        }
                                    </select>
                                    <div class="invalid-feedback">
                                        @Localize("Please select month.")
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-3">
                                    <label class="form-label fw-bold">@Localize("Year") <code>*</code></label>
                                    <select name="year" id="genYear" class="form-select" required>
                                        <option value="">@Localize("Select Year")</option>
                                        @{
                                            int ye = currentyear;
                                        }
                                        @for (int i = 1; i < 5; i++)
                                        {
                                            <option value="@ye">@ye</option>
                                            ye--;
                                        }
                                    </select>
                                    <div class="invalid-feedback">
                                        @Localize("Please select year.")
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Toggle for Custom Salary Mode -->
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="useCustomSalary" onchange="ToggleCustomSalaryMode(this)">
                            <label class="form-check-label" for="useCustomSalary">
                                <strong>@Localize("Use Custom Salary Amounts for Each Employee")</strong>
                                <small class="text-muted d-block">@Localize("Check this to set different salary amounts for each employee this month")</small>
                            </label>
                        </div>

                        <!-- Custom Salary Section (Hidden by Default) -->
                        <div id="customSalarySection" style="display: none;" class="border rounded p-3 mb-3 bg-light">
                            <h6 class="fw-bold mb-3">
                                <i class="fas fa-users me-2"></i>@Localize("Employee Salary Configuration")
                            </h6>
                            <div class="alert alert-info" role="alert">
                                <i class="fas fa-info-circle me-2"></i>
                                @Localize("Enter custom salary and optional initial payment amount for each employee.")
                            </div>
                            <div id="employeeListContainer" style="max-height: 400px; overflow-y: auto;">
                                <!-- Employees will be loaded here dynamically -->
                                <div class="text-center text-muted">
                                    <i class="fas fa-spinner fa-spin"></i> @Localize("Loading employees...")
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localize("Cancel")</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-check me-1"></i>@Localize("Generate")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="invoiceModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Localize("Payslip")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <i class="fa fa-x" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="text-md-end">
                        <div class="mb-3">
                            <button type="button" id="printinv" class="btn btn-info">
                                <i class="fas fa-print me-2"></i>
                                Print
                            </button>
                        </div>
                    </div>
                    <div class="invoice" id="empinv">
                        <div class="row">
                            <div class="col-12">
                                <div class="row">
                                    <div class="col-md-8">
                                        <div class="title">
                                            <h4>@GetSetting.CompanyName</h4>
                                            <address>
                                                @GetSetting.CompanyAddress<br>
                                                @Localize("Phone"): @GetSetting.CompanyPhone @Localize("Email"): @GetSetting.CompanyEmail
                                            </address>
                                        </div>
                                    </div>
                                    <div class="col-md-4 text-md-end">
                                        <div class="title">
                                            <h4 class="text-primary">@Localize("PAYSLIP")</h4>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <address>
                                            <strong>@Localize("Employee Information")</strong><br>
                                            <span id="i-EmployeeName"></span> (EMP-<span id="i-EmployeeId"></span>)<br>
                                            <span id="i-EmployeeDepartment"></span> - <span id="i-EmployeeDesignation"></span><br>
                                            <span id="i-EmployeeAddress"></span><br>
                                        </address>
                                    </div>
                                    <div class="col-md-6 text-md-end">
                                        <address>
                                            <strong>@Localize("Payroll") #</strong> <span id="i-PayrollNo"></span><br>
                                            <strong>@Localize("Pay Type"):</strong> <span id="i-PayType"></span><br>
                                            <strong>@Localize("Generated At"):</strong> <span id="i-PayDate"></span><br>
                                            <strong>@Localize("Period"):</strong> <span id="i-Period"></span><br>
                                        </address>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row g-1 mt-4">
                            <div class="col-md-6">
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered">
                                        <thead>
                                            <tr>
                                                <th scope="col">@Localize("Earning")</th>
                                                <th scope="col" class="text-end">@Localize("Amount")</th>
                                            </tr>
                                        </thead>
                                        <tbody id="i-Earnings">
                                            <tr>
                                                <td>@Localize("Basic Pay")</td>
                                                <td class="text-end" id="i-BasicPay"></td>
                                            </tr>
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <th scope="col">@Localize("Gross Earnings")</th>
                                                <th scope="col" class="text-end" id="i-TotalEarnings"></th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered">
                                        <thead>
                                            <tr>
                                                <th scope="col">@Localize("Deduction")</th>
                                                <th scope="col" class="text-end">@Localize("Amount")</th>
                                            </tr>
                                        </thead>
                                        <tbody id="i-Deductions">
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <th scope="col">@Localize("Total Deductions")</th>
                                                <th scope="col" class="text-end" id="i-TotalDeductions"></th>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <div class="details text-end">
                                <div class="title">@Localize("Net Pay")</div>
                                <div class="value" id="i-NetPay"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Payment Recording Modal -->
    <div class="modal fade" id="paymentModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Localize("Record Payroll Payment")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <i class="fa fa-x" aria-hidden="true"></i>
                    </button>
                </div>
                <form id="frmPayment" class="needs-validation" novalidate="">
                    <div class="modal-body">
                        <input type="hidden" id="paymentPayrollId" name="payrollId">

                        <div class="alert alert-info" role="alert">
                            <strong id="paymentEmployeeName"></strong><br>
                            <small id="paymentPeriod"></small>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">@Localize("Net Salary")</label>
                                <input type="text" class="form-control" id="paymentNetSalary" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">@Localize("Remaining")</label>
                                <input type="text" class="form-control text-danger" id="paymentRemaining" readonly>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label">@Localize("Payment Amount") <code>*</code></label>
                            <input type="number" id="paymentAmount" name="amount" class="form-control" step="0.01" min="0.01" placeholder="@Localize("Enter amount")" required>
                            <div class="invalid-feedback">
                                @Localize("Please enter a valid amount.")
                            </div>
                            <small class="form-text text-muted">
                                @Localize("Maximum: ") <span id="maxAmount">0.00</span>
                            </small>
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label">@Localize("Payment Method") <code>*</code></label>
                            <select id="paymentMethod" name="paymentMethod" class="form-control selectpicker" required>
                                <option value="">@Localize("Select Payment Method")</option>
                                <option value="Cash">@Localize("Cash")</option>
                                <option value="Check">@Localize("Check")</option>
                                <option value="BankTransfer">@Localize("Bank Transfer")</option>
                                <option value="Card">@Localize("Card")</option>
                                <option value="Other">@Localize("Other")</option>
                            </select>
                            <div class="invalid-feedback">
                                @Localize("Please select payment method.")
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label">@Localize("Notes")</label>
                            <textarea id="paymentNotes" name="notes" class="form-control" rows="2" placeholder="@Localize("Optional notes")"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer bg-whitesmoke br">
                        <button type="submit" class="btn btn-primary submit">@Localize("Record Payment")</button>
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">@Localize("Cancel")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Payment History Modal -->
    <div class="modal fade" id="historyModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Localize("Payment History")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <i class="fa fa-x" aria-hidden="true"></i>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="payment-stat-card">
                                <h5 style="font-size: 12px;">@Localize("Net Salary")</h5>
                                <div class="amount" style="font-size: 18px;" id="histNetSalary">0.00</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="payment-stat-card success">
                                <h5 style="font-size: 12px;">@Localize("Paid Amount")</h5>
                                <div class="amount" style="font-size: 18px;" id="histPaidAmount">0.00</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="payment-stat-card danger">
                                <h5 style="font-size: 12px;">@Localize("Remaining")</h5>
                                <div class="amount" style="font-size: 18px;" id="histRemaining">0.00</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="payment-stat-card warning">
                                <h5 style="font-size: 12px;">@Localize("Paid %")</h5>
                                <div class="amount" style="font-size: 18px;" id="histPercentage">0%</div>
                            </div>
                        </div>
                    </div>

                    <h6 class="mb-3">@Localize("Payment Transactions")</h6>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover" id="historyTable">
                            <thead>
                                <tr>
                                    <th>@Localize("Date")</th>
                                    <th>@Localize("Amount")</th>
                                    <th>@Localize("Method")</th>
                                    <th>@Localize("Notes")</th>
                                    <th>@Localize("Action")</th>
                                </tr>
                            </thead>
                            <tbody id="historyTableBody">
                            </tbody>
                        </table>
                    </div>
                    <div id="noPaymentHistory" class="alert alert-info" style="display: none;">
                        @Localize("No payment history found for this payroll.")
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section scripts{
    <script>

        $('#month').val('@ViewBag.month');
        $('#year').val('@ViewBag.year');

        $("#hrm-menu").addClass("active");
        $("#payrollList-menu").addClass("active");

        var dt = $('#datatable').DataTable({
            'language': {
                "processing": '@Localize("Processing...")',
                "loadingRecords": "@Localize("Loading...")",
                'lengthMenu': '@Localize("Show") _MENU_ @Localize("Entries")',
                "zeroRecords": "@Localize("No Result Found")",
                "info": '<small>@Localize("Showing") _START_ - _END_ (_TOTAL_)</small>',
                "infoEmpty": '',
                "infoFiltered": '',
                "search": '@Localize("Search")',
                'paginate': {
                    'previous': '<i class="fa fa-chevron-left"></i>',
                    'next': '<i class="fa fa-chevron-right"></i>'
                }
            },
            'columnDefs': [
                {
                    "orderable": false,
                    'targets': [9]
                }
            ],
            'lengthMenu': [[50, 100, 150, -1], [50, 100, 150, "All"]],
        });

        function OpenGenerateModal() {
            // Reset form
            document.getElementById('frmgenerate').reset();
            document.getElementById('useCustomSalary').checked = false;
            document.getElementById('customSalarySection').style.display = 'none';
            $("#generateModal").modal('show');
        }

        // Toggle custom salary entry mode
        function ToggleCustomSalaryMode(checkbox) {
            const customSection = document.getElementById('customSalarySection');
            if (checkbox.checked) {
                customSection.style.display = 'block';
                LoadEmployeesForCustomPayroll();
            } else {
                customSection.style.display = 'none';
            }
        }

        // Load employees for custom salary configuration
        function LoadEmployeesForCustomPayroll() {
            jQuery.ajax({
                url: "/HRM/GetEmployeesForPayroll",
                method: "GET",
                dataType: "json",
                success: function (data) {
                    if (data.status == "success") {
                        const container = document.getElementById('employeeListContainer');
                        let html = '';

                        data.data.forEach(function (emp, index) {
                            html += `
                                <div class="card mb-2 shadow-sm">
                                    <div class="card-body p-3">
                                        <div class="row align-items-center">
                                            <div class="col-md-4">
                                                <small class="text-muted">@Localize("Employee")</small>
                                                <div class="fw-bold">${emp.name}</div>
                                                <small class="text-muted">${emp.departmentName} - ${emp.designationName}</small>
                                            </div>
                                            <div class="col-md-3">
                                                <small class="text-muted">@Localize("Default Salary")</small>
                                                <div class="fw-bold">${GetCurrency(getNumber(emp.salary))}</div>
                                            </div>
                                            <div class="col-md-5">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <label class="form-label small fw-bold mb-1">@Localize("Custom Salary")</label>
                                                        <input type="number" class="form-control form-control-sm custom-salary-input" 
                                                               data-emp-id="${emp.id}" 
                                                               value="${emp.salary}" 
                                                               step="0.01" min="0.01" required>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <label class="form-label small fw-bold mb-1">@Localize("Initial Payment") <span class="text-muted">(Optional)</span></label>
                                                        <input type="number" class="form-control form-control-sm initial-payment-input" 
                                                               data-emp-id="${emp.id}" 
                                                               value="0" 
                                                               step="0.01" min="0">
                                                    </div>
                                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                            `;
                        });

                        container.innerHTML = html || '<div class="alert alert-info">@Localize("No active employees found.")</div>';
                    } else {
                        alert('Error: ' + data.message);
                    }
                },
                error: function () {
                    alert('Failed to load employees.');
                }
            });
        }

        function OpenInvoiceModal(id) {
            if (id > 0) {
                $('#i-Earnings tr').slice(1).remove();
                $('#i-Deductions tr').slice(1).remove();
                jQuery.ajax({
                    url: "/HRM/PayrollDetail",
                    method: "GET",
                    data: {
                        Id: id
                    },
                    dataType: "json",
                    success: function (data) {
                        if (data.status == "success") {
                            var res = data.data;
                            $('#i-EmployeeId').text(res.employee.id);
                            $('#i-EmployeeName').text(res.employee.name);
                            $('#i-EmployeeDepartment').text(res.employee.department.title);
                            $('#i-EmployeeDesignation').text(res.employee.designation.title);
                            $('#i-EmployeeAddress').text(res.employee.presentAddress);
                            $('#i-PayrollNo').text(res.id);
                            $('#i-PayType').text(res.payrollType);
                            $('#i-PayDate').text(getDate(res.generatedAt));
                            $('#i-Period').text(res.month + '-' + res.year);
                            $('#i-BasicPay').text(GetCurrency(getNumber(res.salary)));
                            var detail = res.payrollDetails;
                            var earning = res.salary;
                            var deduction = 0;
                            for (var i = 0; i < detail.length; i++) {
                                if (detail[i].amountType == 'Earning') {
                                    var html = '<tr><td>' + detail[i].title + '</td>';
                                    if (detail[i].isPercentage) {
                                        var am = (detail[i].amount * res.salary) / 100;
                                        html += '<td class="text-end">(' + getNumber(detail[i].amount) + ' %) ' + GetCurrency(getNumber(am)) + '</td></tr>';
                                        earning += am;
                                    }
                                    else {
                                        html += '<td class="text-end">' + GetCurrency(getNumber(detail[i].amount)) + '</td></tr>';
                                        earning += detail[i].amount;
                                    }
                                    $('#i-Earnings').append(html);
                                }
                                else {
                                    var html = '<tr><td>' + detail[i].title + '</td>';
                                    if (detail[i].isPercentage) {
                                        var am = (detail[i].amount * res.salary) / 100;
                                        html += '<td class="text-end">(' + getNumber(detail[i].amount) + ' %) ' + GetCurrency(getNumber(am)) + '</td></tr>';
                                        deduction += am;
                                    }
                                    else {
                                        html += '<td class="text-end">' + GetCurrency(getNumber(detail[i].amount)) + '</td></tr>';
                                        deduction += detail[i].amount;
                                    }
                                    $('#i-Deductions').append(html);
                                }
                            }

                            $('#i-TotalEarnings').text(GetCurrency(getNumber(earning.toFixed(2))));
                            $('#i-TotalDeductions').text(GetCurrency(getNumber(deduction.toFixed(2))));
                            $('#i-NetPay').text(GetCurrency(getNumber(res.netSalary.toFixed(2))));

                            $("#invoiceModal").modal('show');
                        }
                        else {
                            errorMessage(data.message);
                        }
                    },
                    error: function (data) {
                        if (data.status == 401) {
                            window.location.href = '/Account/Login';
                        }
                        else if (data.status == 403) {
                            errorMessage('@Localize("Access denied.")');
                        }
                        else {
                            console.log(JSON.stringify(data));
                        }
                    }
                });
            }
        }

        function printData() {
            var elem = document.getElementById("empinv");
            var domClone = elem.cloneNode(true);

            var $printSection = document.getElementById("printSection");

            if (!$printSection) {
                var $printSection = document.createElement("div");
                $printSection.id = "printSection";
                document.body.appendChild($printSection);
            }

            $printSection.innerHTML = "";
            $printSection.appendChild(domClone);
            window.print();
        }

        $('#printinv').on('click', function () {
            printData();
        })

        function PayInvoice(id) {
            $.alert({
                title: '@Localize("Pay Salary")',
                content: '@Localize("Are you sure want to pay salary?")',
                rtl: isRTL(),
                theme: 'modern',
                buttons: {
                    confirm: {
                        text: '<i class="fa fa-check"></i> @Localize("Pay Now")',
                        btnClass: 'btn btn-primary',
                        action: function (btn) {
                            var self = this;
                            self.showLoading(true);
                            $.ajax({
                                url: "/HRM/PaySalary",
                                type: 'PUT',
                                data: {
                                    Id: id
                                },
                                error: function (data) {
                                    if (data.status == 401) {
                                        window.location.href = '/Account/Login';
                                    }
                                    else if (data.status == 403) {
                                        errorMessage('@Localize("Access denied.")');
                                    }
                                    else {
                                        console.log(JSON.stringify(data));
                                    }
                                },
                                success: function (data) {
                                    if (data.status == "success") {
                                        setCookie('successMessage', '@Localize("Salary paid successfully.")');
                                        window.location.reload(true);
                                    }
                                    else {
                                        errorMessage(data.message);
                                    }
                                },
                                complete: function () {

                                    self.close();
                                }
                            });
                            return false;
                        }
                    },
                    cancel: {
                        text: '@Localize("Cancel")',
                        action: function () {
                        }
                    }
                }
            });
        }

        function Delete(id) {
            $.alert({
                title: '@Localize("Are you sure want to delete?")',
                content: '@Localize("Once deleted, you will not be able to recover this record.")',
                rtl: isRTL(),
                theme: 'modern',
                buttons: {
                    confirm: {
                        text: '<i class="fa fa-trash"></i> @Localize("Delete")',
                        btnClass: 'btn btn-danger',
                        action: function (btn) {
                            var self = this;
                            self.showLoading(true);
                            $.ajax({
                                url: "/HRM/DeletePayroll",
                                type: 'DELETE',
                                data: {
                                    Id: id
                                },
                                error: function (data) {
                                    if (data.status == 401) {
                                        window.location.href = '/Account/Login';
                                    }
                                    else if (data.status == 403) {
                                        errorMessage('@Localize("Access denied.")');
                                    }
                                    else {
                                        console.log(JSON.stringify(data));
                                    }
                                },
                                success: function (data) {
                                    if (data.status == "success") {
                                        successMessage('@Localize("Payroll deleted successfully.")');
                                        dt.row("#row" + id).remove().draw();
                                    }
                                    else {
                                        errorMessage(data.message);
                                    }
                                },
                                complete: function () {
                                    self.close();
                                }
                            });
                            return false;
                        }
                    },
                    cancel: {
                        text: '@Localize("Cancel")',
                        action: function () {
                        }
                    }
                }
            });
        }

        $("#frmgenerate").submit(function (e) {
            e.preventDefault();

            if (performValidation($("#frmgenerate"))) {
                const month = document.getElementById('genMonth').value;
                const year = document.getElementById('genYear').value;
                const useCustomSalary = document.getElementById('useCustomSalary').checked;

                if (useCustomSalary) {
                    // Handle custom salary generation
                    SubmitCustomPayroll(month, year);
                } else {
                    // Handle standard payroll generation
                    var formData = new FormData(this);
                    $("#frmgenerate button[type='submit']").addClass("disabled btn-progress");

                    $.ajax({
                        url: '/HRM/GeneratePayroll',
                        type: 'POST',
                        data: formData,
                        dataType: "json",
                        contentType: false,
                        processData: false,
                        success: function (data) {
                            if (data.status == "success") {
                                setCookie("successMessage", '@Localize("Payroll generated successfully.")');
                                window.location.reload(true);
                            }
                            else {
                                errorMessage(data.message);
                            }
                        },
                        error: function (data) {
                            if (data.status == 401) {
                                window.location.href = '/Account/Login';
                            }
                            else if (data.status == 403) {
                                errorMessage('@Localize("Access denied.")');
                            }
                            else {
                                console.log(JSON.stringify(data));
                            }
                        },
                        complete: function () {
                            $("#frmgenerate button[type='submit']").removeClass("disabled btn-progress");
                        }
                    });
                }
            }
        });

        // Submit custom payroll with individual salary amounts
        function SubmitCustomPayroll(month, year) {
            const customSalaryInputs = document.querySelectorAll('.custom-salary-input');
            const customData = [];

            customSalaryInputs.forEach(function (input) {
                const empId = parseInt(input.getAttribute('data-emp-id'));
                const customSalary = parseFloat(input.value);
                const initialPayment = parseFloat(document.querySelector(`.initial-payment-input[data-emp-id="${empId}"]`).value) || 0;

                if (customSalary > 0) {
                    customData.push({
                        employeeId: empId,
                        customSalary: customSalary,
                        initialPayingAmount: initialPayment
                    });
                }
            });

            if (customData.length === 0) {
                alert('@Localize("Please enter at least one employee salary.")');
                return;
            }

            $("#frmgenerate button[type='submit']").addClass("disabled btn-progress");

            $.ajax({
                url: `/HRM/GenerateCustomPayroll?month=${month}&year=${year}`,
                type: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                data: JSON.stringify(customData),
                dataType: "json",
                success: function (data) {
                    if (data.status == "success") {
                        setCookie("successMessage", '@Localize("Payroll generated successfully with custom amounts.")');
                        window.location.reload(true);
                    }
                    else {
                        errorMessage(data.message);
                    }
                },
                error: function (xhr) {
                    console.error('Error:', xhr);
                    errorMessage('@Localize("Failed to generate payroll. Please check the console for details.")');
                },
                complete: function () {
                    $("#frmgenerate button[type='submit']").removeClass("disabled btn-progress");
                }
            });
        }

        // Calculate Payment Statistics
        function calculatePaymentStats() {
            let totalPayroll = 0;
            let totalPaid = 0;
            let partialCount = 0;
            let unpaidCount = 0;

            dt.rows().every(function () {
                let row = this.data();
                let netSalary = parseFloat(row[4]) || 0;
                let paidAmount = parseFloat(row[7]) || 0;
                totalPayroll += netSalary;
                totalPaid += paidAmount;

                let status = row[6] || '';
                if (status.includes('Partial')) {
                    partialCount++;
                } else if (status.includes('Unpaid')) {
                    unpaidCount++;
                }
            });

            $('#totalPayroll').text(GetCurrency(totalPayroll.toFixed(2)));
            $('#totalPaid').text(GetCurrency(totalPaid.toFixed(2)));
            $('#partiallyPaid').text(partialCount);
            $('#unpaidCount').text(unpaidCount);
        }

        // Open Payment Modal
        function OpenPaymentModal(payrollId, employeeName, netSalary, remaining, status) {
            $('#paymentPayrollId').val(payrollId);
            $('#paymentEmployeeName').text(employeeName);
            $('#paymentNetSalary').val(GetCurrency(netSalary));
            $('#paymentRemaining').val(GetCurrency(remaining));
            $('#maxAmount').text(remaining.toFixed(2));
            $('#paymentAmount').attr('max', remaining);
            $('#paymentAmount').val('');
            $('#paymentMethod').val('');
            $('#paymentNotes').val('');

            $("#paymentModal").modal('show');
        }

        // View Payment History
        function ViewPaymentHistory(payrollId) {
            jQuery.ajax({
                url: "/AccountingEngine/PayrollPaymentDetails",
                method: "GET",
                data: { payrollId: payrollId },
                dataType: "json",
                success: function (data) {
                    if (data.status == "success") {
                        var res = data.data;

                        // Update statistics
                        $('#histNetSalary').text(GetCurrency(res.netSalary));
                        $('#histPaidAmount').text(GetCurrency(res.totalPaid));
                        $('#histRemaining').text(GetCurrency(res.remaining));

                        let percentage = res.netSalary > 0 ? ((res.totalPaid / res.netSalary) * 100).toFixed(0) : 0;
                        $('#histPercentage').text(percentage + '%');

                        // Clear and populate table
                        $('#historyTableBody').empty();

                        if (res.payments && res.payments.length > 0) {
                            $('#noPaymentHistory').hide();
                            $.each(res.payments, function (index, payment) {
                                var row = '<tr>' +
                                    '<td>' + new Date(payment.paymentDate).toLocaleDateString() + '</td>' +
                                    '<td><strong>' + GetCurrency(payment.amount) + '</strong></td>' +
                                    '<td><span class="badge bg-info">' + payment.paymentMethod + '</span></td>' +
                                    '<td>' + (payment.notes || '-') + '</td>' +
                                    '<td><button class="btn btn-sm btn-danger" onclick="ReversePayment(' + payment.id + ', ' + payrollId + ')"><i class="fas fa-undo"></i></button></td>' +
                                    '</tr>';
                                $('#historyTableBody').append(row);
                            });
                        } else {
                            $('#noPaymentHistory').show();
                        }

                        $("#historyModal").modal('show');
                    } else {
                        errorMessage(data.message);
                    }
                },
                error: function (data) {
                    if (data.status == 401) {
                        window.location.href = '/Account/Login';
                    } else if (data.status == 403) {
                        errorMessage('@Localize("Access denied.")');
                    } else {
                        console.log(JSON.stringify(data));
                    }
                }
            });
        }

        // Record Payment
        $("#frmPayment").submit(function (e) {
            e.preventDefault();

            if (performValidation($("#frmPayment"))) {
                var payrollId = $('#paymentPayrollId').val();
                var amount = parseFloat($('#paymentAmount').val());
                var method = $('#paymentMethod').val();
                var notes = $('#paymentNotes').val();

                $("#frmPayment .submit").addClass("disabled btn-progress");

                $.ajax({
                    url: "/AccountingEngine/PayPartialSalary",
                    type: 'POST',
                    data: {
                        payrollId: payrollId,
                        amount: amount,
                        paymentMethod: method,
                        notes: notes
                    },
                    dataType: "json",
                    success: function (data) {
                        if (data.status == "success") {
                            successMessage('@Localize("Payment recorded successfully.")');
                            $("#paymentModal").modal('hide');
                            window.location.reload(true);
                        } else {
                            errorMessage(data.message);
                        }
                    },
                    error: function (data) {
                        if (data.status == 401) {
                            window.location.href = '/Account/Login';
                        } else if (data.status == 403) {
                            errorMessage('@Localize("Access denied.")');
                        } else {
                            console.log(JSON.stringify(data));
                        }
                    },
                    complete: function () {
                        $("#frmPayment .submit").removeClass("disabled btn-progress");
                    }
                });
            }
        });

        // Reverse Payment
        function ReversePayment(paymentId, payrollId) {
            $.alert({
                title: '@Localize("Reverse Payment")',
                content: '@Localize("Are you sure you want to reverse this payment?")',
                rtl: isRTL(),
                theme: 'modern',
                buttons: {
                    confirm: {
                        text: '<i class="fa fa-undo"></i> @Localize("Reverse")',
                        btnClass: 'btn btn-danger',
                        action: function (btn) {
                            var self = this;
                            self.showLoading(true);
                            $.ajax({
                                url: "/AccountingEngine/ReversePayrollPayment",
                                type: 'POST',
                                data: { paymentId: paymentId },
                                dataType: "json",
                                success: function (data) {
                                    if (data.status == "success") {
                                        successMessage('@Localize("Payment reversed successfully.")');
                                        ViewPaymentHistory(payrollId);
                                    } else {
                                        errorMessage(data.message);
                                    }
                                },
                                error: function (data) {
                                    if (data.status == 401) {
                                        window.location.href = '/Account/Login';
                                    } else if (data.status == 403) {
                                        errorMessage('@Localize("Access denied.")');
                                    } else {
                                        console.log(JSON.stringify(data));
                                    }
                                },
                                complete: function () {
                                    self.close();
                                }
                            });
                            return false;
                        }
                    },
                    cancel: {
                        text: '@Localize("Cancel")',
                        action: function () {
                        }
                    }
                }
            });
        }

        // Initialize payment stats on page load
        $(document).ready(function () {
            setTimeout(function () {
                calculatePaymentStats();
            }, 1000);
        });
    </script>
}
