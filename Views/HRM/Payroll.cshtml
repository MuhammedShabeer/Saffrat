        // View Payment History
        function ViewPaymentHistory(payrollId) {
            jQuery.ajax({
                url: "/AccountingEngine/PayrollPaymentDetails",
                method: "GET",
                data: { payrollId: payrollId },
                dataType: "json",
                success: function (data) {
                    if (data.status == "success") {
                        var res = data.data;

                        // Update statistics - calculate accurate remaining balance if DB is out of sync
                        $('#histNetSalary').text(GetCurrency(res.netSalary || 0));
                        $('#histPaidAmount').text(GetCurrency(res.totalAmountPaid || 0));
                        
                        let remaining = (res.netSalary || 0) - (res.totalAmountPaid || 0);
                        $('#histRemaining').text(GetCurrency(remaining.toFixed(2)));

                        let percentage = res.netSalary > 0 ? ((res.totalAmountPaid / res.netSalary) * 100).toFixed(0) : 0;
                        $('#histPercentage').text(percentage + '%');

                        // Clear and populate table
                        $('#historyTableBody').empty();

                        if (res.payments && res.payments.length > 0) {
                            $('#noPaymentHistory').hide();
                            $.each(res.payments, function (index, payment) {
                                var row = '<tr>' +
                                    '<td>' + new Date(payment.paymentDate).toLocaleDateString() + '</td>' +
                                    '<td><strong>' + GetCurrency(payment.amount) + '</strong></td>' +
                                    '<td><span class="badge bg-info">' + payment.paymentMethod + '</span></td>' +
                                    '<td>' + (payment.notes || '-') + '</td>' +
                                    '<td><button class="btn btn-sm btn-danger" onclick="ReversePayment(' + payment.id + ', ' + payrollId + ')"><i class="fas fa-undo"></i></button></td>' +
                                    '</tr>';
                                $('#historyTableBody').append(row);
                            });
                        } else {
                            $('#noPaymentHistory').show();
                        }

                        $("#historyModal").modal('show');
                    } else {
                        errorMessage(data.message);
                    }
                },
                error: function (data) {
                    if (data.status == 401) {
                        window.location.href = '/Account/Login';
                    } else if (data.status == 403) {
                        errorMessage('@Localize("Access denied.")');
                    } else {
                        console.log(JSON.stringify(data));
                    }
                }
            });
        }

