@using Saffrat.Resources
@inherits LocService<dynamic>

<!-- Payslip Modal -->
<div class="modal fade" id="invoiceModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@Localize("View Payslip")</h5>
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                    <i class="fa fa-x" aria-hidden="true"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="p-3">
                    <div class="mb-3">
                        <button type="button" id="printinv" class="btn btn-info">
                            <i class="fas fa-print me-2"></i>
                            @Localize("Print")
                        </button>
                    </div>
                </div>
                <div class="invoice" id="empinv">
                    <div class="row">
                        <div class="col-12">
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="title">
                                        <h4>@GetSetting.CompanyName</h4>
                                        <address>
                                            @GetSetting.CompanyAddress<br>
                                            @Localize("Phone"): @GetSetting.CompanyPhone @Localize("Email"): @GetSetting.CompanyEmail
                                        </address>
                                    </div>
                                </div>
                                <div class="col-md-4 text-md-end">
                                    <div class="title">
                                        <h4 class="text-primary">@Localize("PAYSLIP")</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <address>
                                        <strong>@Localize("Employee Information")</strong><br>
                                        <span id="i-EmployeeName" class="h6 mb-1 d-block text-dark fw-bold"></span>
                                        <span class="text-muted">EMP-<span id="i-EmployeeId"></span> | <span id="i-EmployeeDepartment"></span></span><br>
                                        <span id="i-EmployeeDesignation" class="text-muted"></span><br>
                                        <span id="i-EmployeeAddress" class="text-muted small"></span>
                                    </address>
                                </div>
                                <div class="col-md-6 text-md-end">
                                    <address>
                                        <strong>@Localize("Payroll Information")</strong><br>
                                        <strong>@Localize("No"):</strong> <span id="i-PayrollNo"></span><br>
                                        <strong>@Localize("Period"):</strong> <span id="i-Period" class="fw-bold"></span><br>
                                        <strong>@Localize("Status"):</strong> <span id="i-StatusBadge"></span><br>
                                    </address>
                                </div>
                            </div>

                            <hr class="my-3">

                            <div class="row">
                                <div class="col-md-6">
                                    <address class="small text-muted">
                                        <strong>@Localize("Bank Details")</strong><br>
                                        @Localize("Bank"): <span id="i-BankName" class="text-dark"></span><br>
                                        @Localize("Account"): <span id="i-AccountNumber" class="text-dark"></span>
                                    </address>
                                </div>
                                <div class="col-md-6 text-md-end">
                                    <address class="small text-muted">
                                        <strong>@Localize("Payment Details")</strong><br>
                                        @Localize("Joining Date"): <span id="i-JoiningDate" class="text-dark"></span><br>
                                        @Localize("Pay Type"): <span id="i-PayType" class="text-dark"></span>
                                    </address>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row g-1 mt-4">
                        <div class="col-md-6">
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr class="bg-light">
                                            <th scope="col">@Localize("Earnings")</th>
                                            <th scope="col" class="text-end">@Localize("Amount")</th>
                                        </tr>
                                    </thead>
                                    <tbody id="i-Earnings">
                                        <tr>
                                            <td>@Localize("Basic Pay")</td>
                                            <td class="text-end" id="i-BasicPay"></td>
                                        </tr>
                                    </tbody>
                                    <tfoot>
                                        <tr class="fw-bold bg-light">
                                            <td>@Localize("Total Gross")</td>
                                            <td class="text-end" id="i-TotalEarnings"></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr class="bg-light">
                                            <th scope="col">@Localize("Deductions")</th>
                                            <th scope="col" class="text-end">@Localize("Amount")</th>
                                        </tr>
                                    </thead>
                                    <tbody id="i-Deductions">
                                    </tbody>
                                    <tfoot>
                                        <tr class="fw-bold bg-light">
                                            <td>@Localize("Total Deductions")</td>
                                            <td class="text-end" id="i-TotalDeductions"></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-4 align-items-end">
                        <div class="col-md-7">
                            <div class="p-3 border rounded bg-light" style="min-height: 80px;">
                                <small class="text-muted d-block mb-1">@Localize("Net Pay in Words")</small>
                                <div id="i-NetPayWords" class="fw-bold text-dark italic small"></div>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="details text-end">
                                <div class="title h6 mb-0">@Localize("Net Payable")</div>
                                <div class="value h4 text-primary fw-bold" id="i-NetPay"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Payment Summary (Paid vs Remaining) -->
                    <div class="row mt-3">
                        <div class="col-12">
                            <div class="d-flex justify-content-end gap-4 text-end small border-top pt-2">
                                <div>
                                    <span class="text-muted">@Localize("Total Paid"):</span>
                                    <div class="fw-bold text-success" id="i-TotalPaid"></div>
                                </div>
                                <div>
                                    <span class="text-muted">@Localize("Balance"):</span>
                                    <div class="fw-bold text-danger" id="i-Remaining"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Signature Section -->
                    <div class="row mt-5 pt-4 border-top-dash">
                        <div class="col-6 text-center">
                            <div style="border-top: 1px solid #ccc; width: 150px; margin: 0 auto;" class="mt-4"></div>
                            <small class="text-muted">@Localize("Employer Signature")</small>
                        </div>
                        <div class="col-6 text-center">
                            <div style="border-top: 1px solid #ccc; width: 150px; margin: 0 auto;" class="mt-4"></div>
                            <small class="text-muted">@Localize("Employee Signature")</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
