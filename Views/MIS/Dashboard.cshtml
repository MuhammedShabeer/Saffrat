@using Saffrat.Resources
@inherits LocService<TModel>
@{
    ViewData["Title"] = Localize("MIS Analytics Dashboard");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.7);
        --glass-border: rgba(255, 255, 255, 0.4);
        --premium-blue: #4e73df;
        --premium-emerald: #1cc88a;
        --premium-gold: #f6c23e;
        --premium-crimson: #e74a3b;
        --premium-indigo: #6610f2;
        --premium-purple: #6f42c1;
    }

    .mis-container {
        padding: 20px;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: calc(100vh - 150px);
        border-radius: 20px;
    }

    .glass-card {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid var(--glass-border);
        border-radius: 15px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        overflow: hidden;
    }

    .glass-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.15);
    }

    .stat-card {
        padding: 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        color: white;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 800;
        color: #2e384d;
    }

    .stat-label {
        font-size: 14px;
        color: #707070;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .chart-container {
        padding: 15px;
    }

    .card-title {
        font-size: 16px;
        font-weight: 700;
        color: #2e384d;
        margin-bottom: 20px;
        padding-left: 10px;
        border-left: 4px solid var(--premium-blue);
    }

    /* Pulse Animation */
    .pulse-live {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: var(--premium-emerald);
        border-radius: 50%;
        margin-right: 5px;
        box-shadow: 0 0 0 rgba(28, 200, 138, 0.4);
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(28, 200, 138, 0.7); }
        70% { box-shadow: 0 0 0 10px rgba(28, 200, 138, 0); }
        100% { box-shadow: 0 0 0 0 rgba(28, 200, 138, 0); }
    }
</style>

<div class="mis-container mt-2">
    <div class="glass-card mb-4 p-3 d-flex flex-wrap justify-content-between align-items-center">
        <div>
            <h3 class="fw-bold text-dark mb-0"><i class="fas fa-chart-pie text-primary me-2"></i> @Localize("MIS Analytics Control Center")</h3>
            <p class="text-muted small mb-0">@Localize("Strategic business insights & performance tracking")</p>
        </div>
        <div class="d-flex gap-2 align-items-end flex-wrap">
            <div>
                <label class="small fw-bold text-muted">@Localize("From")</label>
                <input type="date" id="filter-from" class="form-control form-control-sm rounded-pill border-primary shadow-sm" style="width:140px;">
            </div>
            <div>
                <label class="small fw-bold text-muted">@Localize("To")</label>
                <input type="date" id="filter-to" class="form-control form-control-sm rounded-pill border-primary shadow-sm" style="width:140px;">
            </div>
            <button onclick="LoadMISDashboard()" class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm h-100">
                <i class="fas fa-sync-alt me-1"></i> @Localize("Apply Filter")
            </button>
            <div class="badge bg-white text-dark p-2 rounded-pill shadow-sm border h-100 d-flex align-items-center">
                <span class="pulse-live"></span> @Localize("LIVE VISION")
            </div>
        </div>
    </div>

    <!-- Primary Financial Row -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="glass-card stat-card border-start border-4 border-primary">
                <div>
                    <div class="stat-label">@Localize("Total Inflow")</div>
                    <div class="stat-value text-primary" id="stat-total-collected">...</div>
                    <div class="text-muted small">@Localize("Incl. Debt"): <span id="stat-old-debt">...</span></div>
                </div>
                <div class="stat-icon bg-primary shadow-sm">
                    <i class="fas fa-hand-holding-usd"></i>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="glass-card stat-card border-start border-4 border-success">
                <div>
                    <div class="stat-label">@Localize("Net Sales (POS)")</div>
                    <div class="stat-value text-success" id="stat-pos-revenue">...</div>
                    <div class="text-danger small fw-bold">@Localize("Due"): <span id="stat-pos-due">...</span></div>
                </div>
                <div class="stat-icon bg-success shadow-sm">
                    <i class="fas fa-cash-register"></i>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="glass-card stat-card border-start border-4 border-indigo">
                <div>
                    <div class="stat-label">@Localize("Net Sales (Van)")</div>
                    <div class="stat-value text-indigo" id="stat-van-revenue">...</div>
                    <div class="text-danger small fw-bold">@Localize("Due"): <span id="stat-van-due">...</span></div>
                </div>
                <div class="stat-icon bg-indigo shadow-sm" style="background-color: var(--premium-indigo);">
                    <i class="fas fa-truck-pickup"></i>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-3">
            <div class="glass-card stat-card border-start border-4 border-warning">
                <div>
                    <div class="stat-label">@Localize("Total Discounts")</div>
                    <div class="stat-value text-warning" id="stat-total-discount">...</div>
                    <div class="text-muted small">@Localize("Avg Tip/Order"): <span id="stat-avg-value">...</span></div>
                </div>
                <div class="stat-icon bg-warning shadow-sm">
                    <i class="fas fa-tags"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts & Leaderboards -->
    <div class="row mb-4">
        <div class="col-lg-12 mb-4">
            <div class="glass-card chart-container">
                <div class="card-title">@Localize("Revenue Velocity Comparison (POS vs Van Sales)")</div>
                <div id="chart-revenue-comparison"></div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="glass-card chart-container">
                <div class="card-title">@Localize("POS Top Product Leaderboard")</div>
                <div id="chart-top-pos-items"></div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="glass-card chart-container">
                <div class="card-title">@Localize("Van Sale Top Product Leaderboard")</div>
                <div id="chart-top-van-items"></div>
            </div>
        </div>
        <div class="col-lg-4 mb-4">
            <div class="glass-card h-100 chart-container">
                <div class="card-title">@Localize("Activity Pulse (Hourly)")</div>
                <div id="chart-hourly-pulse"></div>
            </div>
        </div>
        <div class="col-lg-4 mb-4">
            <div class="glass-card h-100 chart-container">
                <div class="card-title">@Localize("Order Mix (POS+Van)")</div>
                <div id="chart-order-mix"></div>
            </div>
        </div>
        <div class="col-lg-4 mb-4">
            <div class="glass-card h-100 chart-container">
                <div class="card-title">@Localize("Payment Distribution")</div>
                <div id="chart-payment-mix"></div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/lib/apexchart/apexcharts.min.js"></script>
    <script>
        let charts = {};

        $(document).ready(function() {
            const today = new Date().toISOString().split('T')[0];
            $('#filter-from').val(today);
            $('#filter-to').val(today);
            LoadMISDashboard();
        });

        function LoadMISDashboard() {
            const start = $('#filter-from').val();
            const end = $('#filter-to').val();

            $.ajax({
                url: `/MIS/GetMISData?fromDate=${start}&toDate=${end}`,
                type: 'GET',
                success: function(response) {
                    if (response.status === "success") {
                        const data = response.data;
                        
                        // Financial Stats
                        $('#stat-total-collected').text(GetCurrency(data.totalCollected));
                        $('#stat-old-debt').text(GetCurrency(data.oldDebtCollected));
                        $('#stat-pos-revenue').text(GetCurrency(data.todayRevenue));
                        $('#stat-pos-due').text(GetCurrency(data.todayDue));
                        $('#stat-van-revenue').text(GetCurrency(data.vanSaleTodayRevenue));
                        $('#stat-van-due').text(GetCurrency(data.vanSaleTodayDue));
                        $('#stat-total-discount').text(GetCurrency(data.totalDiscount));
                        $('#stat-avg-value').text(GetCurrency(data.avgOrderValue.toFixed(2)));

                        RenderCharts(data);
                    }
                }
            });
        }

        function safeDestroy(chartKey) {
            if (charts[chartKey]) { charts[chartKey].destroy(); }
        }

        function RenderCharts(data) {
            // 1. Comparison
            safeDestroy('comparison');
            charts['comparison'] = new ApexCharts(document.querySelector("#chart-revenue-comparison"), {
                series: [
                    { name: '@Localize("POS Sales")', data: data.dailySales.map(x => x.amount) },
                    { name: '@Localize("Van Sales")', data: data.dailyVanSales.map(x => x.amount) }
                ],
                chart: { type: 'area', height: 350, toolbar: { show: true } },
                stroke: { curve: 'smooth', width: 2 },
                colors: ['#4e73df', '#6610f2'],
                xaxis: { categories: data.dailySales.map(x => x.date) },
                yaxis: { labels: { formatter: (val) => GetCurrency(val.toFixed(0)) } }
            });
            charts['comparison'].render();

            // 2. Top POS
            safeDestroy('topPos');
            charts['topPos'] = new ApexCharts(document.querySelector("#chart-top-pos-items"), {
                series: [{ name: '@Localize("Revenue")', data: data.topPosItems.map(x => x.revenue) }],
                chart: { type: 'bar', height: 300 },
                plotOptions: { bar: { horizontal: true, borderRadius: 5 } },
                colors: ['#1cc88a'],
                xaxis: { categories: data.topPosItems.map(x => x.itemName) }
            });
            charts['topPos'].render();

            // 3. Top Van
            safeDestroy('topVan');
            charts['topVan'] = new ApexCharts(document.querySelector("#chart-top-van-items"), {
                series: [{ name: '@Localize("Revenue")', data: data.topVanSaleItems.map(x => x.revenue) }],
                chart: { type: 'bar', height: 300 },
                plotOptions: { bar: { horizontal: true, borderRadius: 5 } },
                colors: ['#6f42c1'],
                xaxis: { categories: data.topVanSaleItems.map(x => x.itemName) }
            });
            charts['topVan'].render();

            // 4. Hourly
            safeDestroy('hourly');
            charts['hourly'] = new ApexCharts(document.querySelector("#chart-hourly-pulse"), {
                series: [{ name: '@Localize("Sales")', data: data.hourlySales.map(x => x.amount) }],
                chart: { type: 'bar', height: 300 },
                colors: ['#36b9cc'],
                xaxis: { categories: data.hourlySales.map(x => x.hourLabel) }
            });
            charts['hourly'].render();

            // 5. Order Mix
            safeDestroy('orderMix');
            charts['orderMix'] = new ApexCharts(document.querySelector("#chart-order-mix"), {
                series: data.orderTypeSales.map(x => x.amount),
                labels: data.orderTypeSales.map(x => x.typeName),
                chart: { type: 'donut', height: 300 },
                colors: ['#4e73df', '#1cc88a', '#f6c23e', '#e74a3b', '#6610f2'],
                legend: { position: 'bottom' }
            });
            charts['orderMix'].render();

            // 6. Payment Mix
            safeDestroy('paymentMix');
            charts['paymentMix'] = new ApexCharts(document.querySelector("#chart-payment-mix"), {
                series: data.paymentMethodSales.map(x => x.amount),
                labels: data.paymentMethodSales.map(x => x.methodName),
                chart: { type: 'donut', height: 300 },
                colors: ['#36b9cc', '#f6c23e', '#4e73df', '#e74a3b'],
                legend: { position: 'bottom' }
            });
            charts['paymentMix'].render();
        }
    </script>
}
