@model Saffrat.ViewModels.POSVM

@using Saffrat.Resources
@using System.Globalization
@inherits LocService<TModel>

@{
    var numberdelimeter = CultureInfo.CurrentCulture.NumberFormat.NumberDecimalSeparator;
    ViewData["Title"] = @Localize("POS");
    Layout = "~/Views/Shared/_POSLayout.cshtml";
}
@section styles {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/owl-carousel/1.3.3/owl.carousel.css" rel="stylesheet" />
}

<nav class="top-nav" style="margin-top:71px; margin-bottom:3px;">
    <div class="row g-0">
        <div class="col-12">
            <ul class="list-items" id="topBtns">
                <li class="item" id="dineInBtn" onclick="SetDineInOrder();">
                    <i class="fas fa-store"></i>
                    <span>@Localize("Dine In")</span>
                </li>
                <li class="item" id="pickUpBtn" onclick="SetPickUpOrder();">
                    <i class="fas fa-person-walking"></i>
                    <span>@Localize("Pick Up")</span>
                </li>
                <li class="item" id="deliveryBtn" onclick="SetDeliveryOrder();">
                    <i class="fas fa-truck"></i>
                    <span>@Localize("Delivery")</span>
                </li>
                <li class="item" id="orderBtn" onclick="OpenOrderModel();" style="border-left:1px solid #e6e8e6">
                    <i class="fas fa-circle-notch"></i>
                    <span>@Localize("Orders")</span>
                </li>
                <li class="item" id="resetBtn" onclick="ResetControls();">
                    <i class="fas fa-rotate-right"></i>
                    <span>@Localize("Reset")</span>
                </li>
                <li class="item" id="resetBtn" onclick="ReloadData();">
                    <i class="fas fa-spinner"></i>
                    <span>@Localize("Reload")</span>
                </li>
                <li class="item" onclick="OpenNoteModel();">
                    <i class="fas fa-message"></i>
                    <span>@Localize("Note")</span>
                </li>
                <li class="item" id="splitBtn" onclick="OpenSplitBillModel();">
                    <i class="fas fa-scissors"></i>
                    <span>@Localize("Split")</span>
                </li>
                <li class="item" id="paymentBtn" onclick="OpenPaymentModel();">
                    <i class="fas fa-money-bill"></i>
                    <span>@Localize("Payment")</span>
                </li>
                <li class="item" id="submitBtn" onclick="SubmitOrder();">
                    <i class="fas fa-save"></i>
                    <span>@Localize("Submit")</span>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="pos p-2">
    <div class="row g-2">
        <div class="pos-left col-xxl-4 col-lg-5 col-12">
            <div class="card mb-0">
                <div class="card-header bg-primary p-2">
                    <div class="order-header-btns">
                        <a class="btn btn-icon icon-left">
                            <i class="fas fa-hashtag"></i> <span id="d-OrderId"></span>
                        </a>
                        <a class="btn btn-icon icon-left">
                            <i class="fas fa-cube"></i> <span id="d-OrderType">@Localize("Select Order Type")</span>
                        </a>
                        <a href="javascript:void(0);" onclick="OpenCustomerModel();" class="btn btn-icon icon-left">
                            <i class="fas fa-user"></i><span id="d-Customer"></span> <i class="fas fa-edit"></i>
                        </a>
                        <a href="javascript:void(0);" onclick="OpenGuestModel();" class="btn btn-icon icon-left dineinOption d-none">
                            <i class="fas fa-users"></i><span id="d-Guest"></span><i class="fas fa-edit"></i>
                        </a>
                        <a href="javascript:void(0);" onclick="OpenTableModel();" class="btn btn-icon icon-left dineinOption d-none">
                            <i class="fa table-white"></i><span id="d-TableName">@Localize("Select Table")</span> <i class="fas fa-edit"></i>
                        </a>
                        <a href="javascript:void(0);" onclick="OpenWaiterModel();" class="btn btn-icon icon-left waiterOption d-none">
                            <i class="fas fa-building-user"></i><span id="d-Waiter">@Localize("Select Waiter")</span> <i class="fas fa-edit"></i>
                        </a>
                        <a href="javascript:void(0);" onclick="OpenDeliveryManModel();" class="btn btn-icon icon-left deliveryOption d-none">
                            <i class="fas fa-building-user"></i><span id="d-DeliveryMan">@Localize("Select Driver")</span> <i class="fas fa-edit"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="cart overflow-auto">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>@Localize("Food Item")</th>
                                        <th class="text-center">@Localize("Quantity")</th>
                                        <th class="text-end">@Localize("Price")</th>
                                    </tr>
                                </thead>
                                <tbody class="cartItems" id="cartItems">
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="buttons pt-2 ps-2 bg-whitesmoke" id="cartActions">
                        <a href="javascript:void(0);" onclick="IncreaseQuantity();" class="btn btn-primary disabled">
                            <i class="fas fa-plus"></i>
                        </a>
                        <a href="javascript:void(0);" onclick="DecreaseQuantity();" id="decreaseBtn" class="btn btn-primary disabled">
                            <i class="fas fa-minus"></i>
                        </a>
                        <a href="javascript:void(0);" onclick="DeleteItem();" class="btn btn-danger disabled">
                            <i class="fas fa-trash"></i>
                        </a>
                        <a href="javascript:void(0);" onclick="OpenModifierModel();" class="btn btn-dark disabled"><i class="fas fa-sliders-h"></i> @Localize("Modifiers")</a>
                    </div>
                    <div class="calculation">
                        <table class="table table-bordered">
                            <tr>
                                <td>@Localize("Sub Total")<br /><span id="d-SubTotal">@GetCurrency(0)</span></td>
                                <td class="clickable" onclick="OpenDiscountModel();">
                                    @Localize("Discount")<br />
                                    <span id="d-Discount"></span>
                                    <i class="fas fa-edit"></i>
                                </td>
                                <td class="clickable" onclick="OpenChargeModel();">
                                    @Localize("Charge")<br />
                                    <span id="d-Charge"></span>
                                    <i class="fas fa-edit"></i>
                                </td>
                            </tr>
                            <tr>
                                <td class="clickable" onclick="OpenTaxModel();">
                                    @Localize("Tax")<br />
                                    <span id="d-Tax"></span>
                                    <i class="fas fa-edit"></i>
                                </td>
                                <td colspan="2">@Localize("Total")<br /><span class="d-Total">@GetCurrency(0)</span></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="pos-right col-xxl-8 col-lg-7 col-12">
            <div class="card mb-0">
                <div class="card-body p-2">
                    <div class="categories col-12" id="categories">
                    </div>
                    <div class="input-group">
                        <input type="text" id="barcodeInput" onkeyup="BarcodeScan(event);" placeholder="@Localize("Scan barcode")" class="form-control" />
                        <input type="text" id="searchInput" oninput="SearchItems();" placeholder="@Localize("Search by food name")" class="form-control" />
                    </div>
                    <div class="products-block mt-3">
                        <div class="d-flex flex-wrap" id="products">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section models {
    <!--Guest Model-->
    <div class="modal fade" id="GuestModel" tabindex="-1" role="dialog" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modalTitle">@Localize("Guest")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <span aria-hidden="true">x</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form>
                        <div class="form-group p-0">
                            <input type="text" id="guestInput" placeholder="0" value="1" class="form-control d-invtotal cleave-number" inputmode="numeric" readonly />
                        </div>
                    </form>
                    <div class="numpad">
                        <div class="row g-0" id="guests">
                            <div class="col-4"><div data-value="7" class="item">@Localize("7")</div></div>
                            <div class="col-4"><div data-value="8" class="item">@Localize("8")</div></div>
                            <div class="col-4"><div data-value="9" class="item">@Localize("9")</div></div>
                            <div class="col-4"><div data-value="4" class="item">@Localize("4")</div></div>
                            <div class="col-4"><div data-value="5" class="item">@Localize("5")</div></div>
                            <div class="col-4"><div data-value="6" class="item">@Localize("6")</div></div>
                            <div class="col-4"><div data-value="1" class="item">@Localize("1")</div></div>
                            <div class="col-4"><div data-value="2" class="item">@Localize("2")</div></div>
                            <div class="col-4"><div data-value="3" class="item">@Localize("3")</div></div>
                            <div class="col-8"><div data-value="0" class="item">@Localize("0")</div></div>
                            <div class="col-4"><div data-value="x" class="item"><i class="fas fa-circle-xmark"></i></div></div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-whitesmoke">
                    <button type="button" onclick="EnterGuests();" class="btn btn-primary">@Localize("Enter")</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@Localize("Cancel")</button>
                </div>
            </div>
        </div>
    </div>

    <!--Payment Model-->
    <div class="modal fade" id="PaymentModel" tabindex="-1" role="dialog" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modalTitle">@Localize("Payment")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <span aria-hidden="true">x</span>
                    </button>
                </div>
                <div class="modal-body">
                    <table class="table table-bordered table-sm mb-4">
                        <tbody>
                            <tr>
                                <th>@Localize("Total Amount")</th>
                                <td class="d-OrderTotalAmount" colspan="2"></td>
                            </tr>
                            <tr>
                                <th>@Localize("Due Amount")</th>
                                <td class="d-OrderDueAmount" colspan="2"></td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="form-group">
                        <label class="control-label">@Localize("Payment Method")</label>
                        <select id="PaymentMethod" name="PaymentMethod" class="form-control selectpicker">
                            @foreach (var item in Model.PaymentMethods)
                            {
                                <option value="@item.Title">@item.Title</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="control-label">@Localize("Amount")</label>
                        <div class="input-group">
                            <div class="input-group-text">@GetSetting.CurrencySymbol</div>
                            <input value="" id="PaymentAmount" name="PaymentAmount" onkeyup="PaymentAmountChange();" type="text" class="form-control d-invtotal cleave-number" inputmode="numeric" disabled />
                        </div>
                    </div>
                    <div class="row g-0">
                        <div class="col-12 col-md-8">
                            <div class="numpad">
                                <div class="row g-0" id="amounts">
                                    <div class="col-4"><div data-value="7" class="item">@Localize("7")</div></div>
                                    <div class="col-4"><div data-value="8" class="item">@Localize("8")</div></div>
                                    <div class="col-4"><div data-value="9" class="item">@Localize("9")</div></div>
                                    <div class="col-4"><div data-value="4" class="item">@Localize("4")</div></div>
                                    <div class="col-4"><div data-value="5" class="item">@Localize("5")</div></div>
                                    <div class="col-4"><div data-value="6" class="item">@Localize("6")</div></div>
                                    <div class="col-4"><div data-value="1" class="item">@Localize("1")</div></div>
                                    <div class="col-4"><div data-value="2" class="item">@Localize("2")</div></div>
                                    <div class="col-4"><div data-value="3" class="item">@Localize("3")</div></div>
                                    <div class="col-4"><div data-value="0" class="item">@Localize("0")</div></div>
                                    <div class="col-4"><div data-value="@numberdelimeter" class="item">@numberdelimeter</div></div>
                                    <div class="col-4"><div data-value="x" class="item"><i class="fas fa-circle-xmark"></i></div></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="numpad">
                                <div class="row g-0" id="amountsPlus">
                                    <div class="col-4 col-md-6"><div data-value="5" class="item">+@Localize("5")</div></div>
                                    <div class="col-4 col-md-6"><div data-value="10" class="item">+@Localize("10")</div></div>
                                    <div class="col-4 col-md-6"><div data-value="50" class="item">+@Localize("50")</div></div>
                                    <div class="col-4 col-md-6"><div data-value="75" class="item">+@Localize("75")</div></div>
                                    <div class="col-4 col-md-6"><div data-value="100" class="item">+@Localize("100")</div></div>
                                    <div class="col-4 col-md-6"><div data-value="500" class="item">+@Localize("500")</div></div>
                                    <div class="col-4 col-md-6"><div data-value="1000" class="item">+@Localize("1000")</div></div>
                                    <div class="col-4 col-md-6"><div data-value="total" class="item">@Localize("Total")</div></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-whitesmoke">
                    <button type="button" onclick="PrintOrderSticker();" class="btn btn-dark">@Localize("Print Stickers")</button>
                    <button type="button" id="closeOrderBtn" onclick="CloseOrder();" class="btn btn-primary">@Localize("Print & Close")</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@Localize("Cancel")</button>
                </div>
            </div>
        </div>
    </div>

    <!--Split Bill Model-->
    <div class="modal fade" id="SplitBillModel" tabindex="-1" role="dialog" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modalTitle">@Localize("Split Bill")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <span aria-hidden="true">x</span>
                    </button>
                </div>
                <div class="modal-body">
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th></th>
                                <th>@Localize("Food Item")</th>
                                <th>@Localize("Quantity")</th>
                                <th>@Localize("Price")</th>
                            </tr>
                        </thead>
                        <tbody id="splitBillItems">
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="button" id="splitSubmitBtn" onclick="SplitBill();" class="btn btn-primary">@Localize("Split Bill")</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@Localize("Cancel")</button>
                </div>
            </div>
        </div>
    </div>

    <!--Tax Model-->
    <div class="modal fade" id="TaxModel" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modalTitle">@Localize("Select Tax")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <span aria-hidden="true">x</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row g-3" id="taxes">
                        @foreach (var item in Model.TaxRates)
                        {
                            <div class="col-6 col-md-4 item" data-id="@item.Id" data-value="@item.Value" data-percentage="@item.IsPercentage" data-default="@item.IsDefault">
                                <div class="card-box p-2 text-center">
                                    <h2>@item.Title</h2>
                                    @if (item.IsPercentage == true)
                                    {
                                        <h2>@item.Value %</h2>
                                    }
                                    else
                                    {
                                        <h2>@GetCurrency(item.Value)</h2>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--Discount Model-->
    <div class="modal fade" id="DiscountModel" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modalTitle">@Localize("Select Discount")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <span aria-hidden="true">x</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row g-3" id="discounts">
                        @foreach (var item in Model.Discounts)
                        {
                            <div class="col-6 col-md-4 item" data-id="@item.Id" data-value="@item.Value" data-percentage="@item.IsPercentage" data-default="@item.IsDefault">
                                <div class="card-box p-2 text-center">
                                    <h2>@item.Title</h2>
                                    @if (item.IsPercentage == true)
                                    {
                                        <h2>@item.Value %</h2>
                                    }
                                    else
                                    {
                                        <h2>@GetCurrency(item.Value)</h2>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--Charges Model-->
    <div class="modal fade" id="ChargeModel" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modalTitle">@Localize("Select Charge")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <span aria-hidden="true">x</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row g-3" id="charges">
                        @foreach (var item in Model.Charges)
                        {
                            <div class="col-6 col-md-4 item" data-id="@item.Id" data-value="@item.Value" data-percentage="@item.IsPercentage" data-default="@item.IsDefault">
                                <div class="card-box p-2 text-center">
                                    <h2>@item.Title</h2>
                                    @if (item.IsPercentage == true)
                                    {
                                        <h2>@item.Value %</h2>
                                    }
                                    else
                                    {
                                        <h2>@GetCurrency(item.Value)</h2>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--Note Model-->
    <div class="modal fade" id="NoteModel" tabindex="-1" role="dialog" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modalTitle">@Localize("Enter Note")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <span aria-hidden="true">x</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label class="control-label">@Localize("Note")</label>
                        <textarea id="noteInput" class="form-control"></textarea>
                    </div>
                </div>
                <div class="modal-footer bg-whitesmoke br">
                    <button type="submit" class="btn btn-primary" onclick="EnterNote();">@Localize("Enter")</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@Localize("Cancel")</button>
                </div>
            </div>
        </div>
    </div>

    <!--Table Model-->
    <div class="modal fade" id="TableModel" tabindex="-1" role="dialog" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modalTitle">@Localize("Select Table")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <span aria-hidden="true">x</span>
                    </button>
                </div>
                <div class="modal-body" style="min-height:300px;">
                    <div class="row g-2" id="tables">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!--Customer Model-->
    <div class="modal fade" id="CustomerModel" tabindex="-1" role="dialog" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modalTitle">@Localize("Customer")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <span aria-hidden="true">x</span>
                    </button>
                </div>
                <div class="modal-body">
                    <ul class="nav nav-tabs nav-primary" id="myTab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="newcustomer-tab" data-bs-toggle="tab" data-bs-target="#newcustomer" type="button" role="tab" aria-controls="newcustomer" aria-selected="true">@Localize("Add Customer")</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="customersearch-tab" data-bs-toggle="tab" data-bs-target="#customersearch" type="button" role="tab" aria-controls="customersearch" aria-selected="false">@Localize("Search")</button>
                        </li>
                    </ul>
                    <div class="tab-content pt-2" id="myTabContent">
                        <div class="tab-pane fade show active" id="newcustomer" role="tabpanel" aria-labelledby="newcustomer-tab">
                            <form id="customerfrm" class="needs-validation" novalidate="">
                                <div class="form-group">
                                    <label class="control-label">@Localize("Customer Name") <code>*</code></label>
                                    <input name="CustomerName" class="form-control" required />
                                    <div class="invalid-feedback">
                                        @Localize("Please enter customer name.")
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 form-group">
                                        <label class="control-label">@Localize("Email")</label>
                                        <input name="Email" type="email" class="form-control">
                                    </div>
                                    <div class="col-md-6 form-group">
                                        <label class="control-label">@Localize("Phone Number") <code>*</code></label>
                                        <input name="Phone" type="tel" class="form-control" required />
                                        <div class="invalid-feedback">
                                            @Localize("Please enter phone number.")
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label class="control-label">@Localize("Address") <code>*</code></label>
                                    <textarea name="Address" class="form-control" required></textarea>
                                    <div class="invalid-feedback">
                                        @Localize("Please enter address.")
                                    </div>
                                </div>
                                <div class="form-group">
                                    <button class="btn btn-primary mr-1" type="submit" id="submitCustomer">@Localize("Save")</button>
                                </div>
                            </form>
                        </div>
                        <div class="tab-pane fade" id="customersearch" role="tabpanel" aria-labelledby="customersearch-tab">
                            <div class="form-group w-100">
                                <div class="input-group">
                                    <input type="text" placeholder="Search by name or phone number" id="customerSearchInput" class="form-control" />
                                    <a href="javascript:void(0);" onclick="SearchCustomer();" id="customerSearchBtn" class="btn btn-primary m-0">@Localize("Search")</a>
                                </div>
                            </div>
                            <div class="customers mt-4">
                                <div class="row g-2" id="customers">
                                    <div class="col-6 col-md-4 item" data-id="@Model.DefaultCustomer.Id" data-name="@Model.DefaultCustomer.CustomerName" data-default="True">
                                        <div class="card-box p-2 text-center">
