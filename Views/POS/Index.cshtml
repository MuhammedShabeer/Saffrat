    <!--Delivery Man Model-->
    <div class="modal fade" id="DeliveryManModel" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modalTitle">@Localize("Select Delivery Man")</h5>
                    <button type="button" class="btn btn-light" data-dismiss="modal">
                        <span aria-hidden="true">x</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="row g-3" id="deliverymans">
                        @foreach (var item in Model.Drivers)
                        {
                            <div class="col-6 col-md-4 item" data-id="@item.Id" data-uname="@item.UserName">
                                <div class="card-box p-2 text-center">
                                    <h2>@item.FullName</h2>
                                    <p>&#64;@item.UserName</p>
