@using Saffrat.Resources
@inherits LocService<dynamic>
@{
    ViewData["Title"] = Localize("Van Expense Entry");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="main-content">
    <section class="section">
        <div class="section-header">
            <h1>@Localize("Van Expense Entry")</h1>
            <div class="section-header-breadcrumb">
                <div class="breadcrumb-item active"><a href="/">@Localize("Dashboard")</a></div>
                <div class="breadcrumb-item">@Localize("Van Expense")</div>
            </div>
        </div>

        <div class="section-body">
            <h2 class="section-title">@Localize("Record Daily Expense")</h2>
            <p class="section-lead">
                @Localize("Use this page to record expenses for fuel, maintenance, and other van-related costs.")
            </p>

            <div class="row">
                <div class="col-12 col-md-6 col-lg-6">
                    <div class="card card-primary shadow-sm">
                        <div class="card-header">
                            <h4>@Localize("Expense Details")</h4>
                        </div>
                        <div class="card-body">
                            <form id="expenseForm">
                                <div class="form-group">
                                    <label>@Localize("Amount")</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <div class="input-group-text">
                                                <i class="fas fa-money-bill-wave"></i>
                                            </div>
                                        </div>
                                        <input type="number" step="0.01" class="form-control" name="amount" id="expenseAmount" required placeholder="0.00">
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label>@Localize("Description / Free Text")</label>
                                    <textarea class="form-control" name="description" id="expenseDescription" style="height: 100px" required placeholder="@Localize("e.g. Fuel for Van 1, Oil change...")"></textarea>
                                </div>
                                <div class="text-right">
                                    <button type="submit" id="saveExpenseBtn" class="btn btn-primary btn-lg px-4">
                                        <i class="fas fa-save mr-2"></i> @Localize("Save Expense")
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="card shadow-sm border-left-success">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                        @Localize("Operating Account")</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">Main Cash Account</div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-university fa-2x text-gray-300"></i>
                                </div>
                            </div>
                            <div class="mt-3 text-muted small">
                                <i class="fas fa-info-circle"></i> @Localize("All expenses recorded here will be deducted from the Main Cash balance.")
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $("#expenseForm").submit(function(e) {
                e.preventDefault();
                
                var amount = $("#expenseAmount").val();
                var description = $("#expenseDescription").val();
                
                if(!amount || amount <= 0) {
                    errorMessage("@Localize("Please enter a valid amount.")");
                    return;
                }
                
                if(!description) {
                    errorMessage("@Localize("Please enter a description.")");
                    return;
                }
                
                $("#saveExpenseBtn").addClass("btn-progress disabled");
                
                $.ajax({
                    url: '/VanExpense/SaveExpense',
                    type: 'POST',
                    data: {
                        amount: amount,
                        description: description
                    },
                    success: function(data) {
                        if(data.status == "success") {
                            successMessage(data.message);
                            $("#expenseForm")[0].reset();
                        } else {
                            errorMessage(data.message);
                        }
                    },
                    error: function() {
                        errorMessage("@Localize("An error occurred while saving the expense.")");
                    },
                    complete: function() {
                        $("#saveExpenseBtn").removeClass("btn-progress disabled");
                    }
                });
            });
        });
    </script>
}
