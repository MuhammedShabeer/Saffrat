@model Saffrat.Models.Customer

@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Customer Detail");
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.3/css/dataTables.bootstrap5.min.css" />
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        @Localize("Customer Detail")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item"><a asp-controller="People" asp-action="Customers">@Localize("Customers")</a></li>
                    <li class="breadcrumb-item">@Localize("Customer Detail")</li>
                </ul>
            </div>
        </div>
    </div>
</div>


<div class="row mt-5">
    <div class="col-12 col-sm-8 offset-sm-2">
        <div class="card profile-widget">
            <div class="profile-widget-header">
                <img alt="image" src="~/uploads/user_icon.png" class="rounded-circle profile-widget-picture">
                    <div class="profile-widget-items">
                        <div class="profile-widget-item">
                            <div class="profile-widget-item-label">@Localize("Orders")</div>
                            <div class="profile-widget-item-value">@ViewBag.totalOrders</div>
                        </div>
                        <div class="profile-widget-item">
                            <div class="profile-widget-item-label">@Localize("Sales")</div>
                            <div class="profile-widget-item-value">@GetCurrency(ViewBag.totalSales)</div>
                        </div>
                        <div class="profile-widget-item">
                            <div class="profile-widget-item-label">@Localize("Due")</div>
                            <div class="profile-widget-item-value">@GetCurrency(ViewBag.totalDue)</div>
                            @if (ViewBag.totalDue > 0)
                            {
                                <button class="btn btn-sm btn-outline-danger mt-2" onclick="$('#paymentModal').modal('show');">
                                    <i class="fas fa-hand-holding-usd me-1"></i> @Localize("Receive Payment")
                                </button>
                            }
                        </div>
                    </div>
                </div>
                <div class="profile-widget-description pb-0">
                    <div class="profile-widget-name">
                        @Model.CustomerName
                    </div>
                    <dl class="row">
                        <dt class="col-sm-3">
                            @Localize("Email"):
                        </dt>
                        <dd class="col-sm-9">
                            @Html.DisplayFor(model => model.Email)
                        </dd>
                        <dt class="col-sm-3">
                            @Localize("Phone Number"):
                        </dt>
                        <dd class="col-sm-9">
                            @Html.DisplayFor(model => model.Phone)
                        </dd>
                        <dt class="col-sm-3">
                            @Localize("Address"):
                        </dt>
                        <dd class="col-sm-9">
                            @Html.DisplayFor(model => model.Address)
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>
    @section models {
        <!-- Payment Collection Modal -->
        <div class="modal fade" id="paymentModal" tabindex="-1" role="dialog" data-bs-backdrop="static">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@Localize("Receive Due Payment")</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form id="paymentForm">
                        <div class="modal-body">
                            <input type="hidden" name="customerId" value="@Model.Id" />
                            <div class="form-group mb-3">
                                <label>@Localize("Amount to Collect")</label>
                                <div class="input-group">
                                    <span class="input-group-text">@GetSetting.CurrencySymbol</span>
                                    <input type="number" step="0.01" max="@ViewBag.totalDue" name="amount" class="form-control" value="@ViewBag.totalDue" required />
                                </div>
                            </div>
                            <div class="form-group mb-3">
                                <label>@Localize("Deposit To")</label>
                                <input type="text" class="form-control" value="Main Cash" readonly />
                                <input type="hidden" name="glAccountId" value="18" />
                            </div>
                            <div class="form-group">
                                <label>@Localize("Notes")</label>
                                <textarea name="note" class="form-control" rows="2" placeholder="@Localize("Optional collection notes...")"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localize("Cancel")</button>
                            <button type="submit" class="btn btn-primary">@Localize("Confirm Payment")</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
    @section Scripts {
        <script>
            $("#people-menu").addClass("active");
            $("#customerList-menu").addClass("active");

            $("#paymentForm").on("submit", function (e) {
                e.preventDefault();
                var formData = $(this).serialize();
                var btn = $(this).find('button[type="submit"]');
                var originalText = btn.text();
                btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

                $.ajax({
                    url: '/AccountingEngine/CollectCustomerPayment',
                    type: 'POST',
                    data: formData,
                    success: function (res) {
                        if (res.status === "success") {
                            iziToast.success({ title: 'Success', message: res.message, position: 'topRight' });
                            setTimeout(function () { location.reload(); }, 1500);
                        } else {
                            iziToast.error({ title: 'Error', message: res.message, position: 'topRight' });
                            btn.prop('disabled', false).text(originalText);
                        }
                    },
                    error: function () {
                        iziToast.error({ title: 'Error', message: 'Something went wrong.', position: 'topRight' });
                        btn.prop('disabled', false).text(originalText);
                    }
                });
            });
        </script>
    }