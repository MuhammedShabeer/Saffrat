@model IEnumerable<Saffrat.Models.FoodItem>

@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Food Items");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        @Localize("Food Items")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i
                                class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item">@Localize("Food Items")</li>
                </ul>
            </div>
            <div class="col">
                <div class="float-end">
                    <a asp-controller="Food" asp-action="DownloadFoodExcel" class="btn btn-outline-secondary me-2">
                        <i class="fas fa-file-excel me-1"></i> @Localize("Export Excel")
                    </a>
                    <button type="button" class="btn btn-outline-primary me-2" data-bs-toggle="modal" data-bs-target="#importModal">
                        <i class="fas fa-file-import me-1"></i> @Localize("Import Excel")
                    </button>
                    <a asp-controller="Food" asp-action="AddFoodItem" class="btn btn-primary">
                        @Localize("Add New")
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table" id="datatable">
                        <thead>
                            <tr>
                                <th>@Localize("#")</th>
                                <th>@Localize("Image")</th>
                                <th>@Localize("Food Group")</th>
                                <th>@Localize("Item Name")</th>
                                <th>@Localize("Barcode")</th>
                                <th>@Localize("Price")</th>
                                <th>@Localize("Updated At")</th>
                                <th>@Localize("Updated By")</th>
                                <th>@Localize("Action")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var id = "row" + item.Id;
                                <tr id="@id">
                                    <td>@item.Id</td>
                                    <td>
                                        <img src="/Media/ProductImage?name=@item.Image" width="50" height="40" />
                                    </td>
                                    <td>@item.Group.GroupName</td>
                                    <td>@item.ItemName</td>
                                    <td>@item.Barcode</td>
                                    <td>@GetCurrency(item.Price)</td>
                                    <td>@item.UpdatedAt</td>
                                    <td><span>&#64;</span>@item.UpdatedBy</td>
                                    <td>
                                        <button class="btn btn-sm btn-light dropdown-toggle" data-bs-toggle="dropdown"
                                            aria-expanded="false"><i class="fas fa-bars me-1"></i></button>
                                        <div class="dropdown-menu">
                                            <a class="dropdown-item btn" asp-controller="Food" asp-action="EditFoodItem"
                                                asp-route-Id="@item.Id"><i class="fas fa-edit"></i> <span
                                                    class="ml-2">@Localize("Edit")</span></a>
                                            <a class="dropdown-item btn" href="javascript:void(0);"
                                                onclick="Delete(@item.Id);"><i class="fas fa-trash"></i> <span
                                                    class="ml-2">@Localize("Delete")</span></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section models {
    <div class="modal fade" id="importModal" tabindex="-1" aria-labelledby="importModalLabel" role="dialog" data-bs-backdrop="static">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header border-bottom py-3">
                    <h5 class="modal-title fw-bold" id="mainModalTitle"><i class="fa fa-file-excel me-2 text-primary"></i> @Localize("Import Food Items via Excel")</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted mb-3">
                        @Localize("Upload an Excel (.xlsx) file to bulk insert or update food items with perfect Arabic character support. Use the 'Export Excel' button to get the latest data.")
                    </p>
                    <div class="mb-3">
                        <label class="form-label fw-bold">@Localize("Select File")</label>
                        <input type="file" id="menuFileInput" class="form-control" accept=".xlsx, .csv" />
                        <small class="text-info"><i class="fas fa-info-circle me-1"></i> @Localize("Recommended format: .xlsx")</small>
                    </div>
                    <div id="importLoading" class="text-center d-none">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2 text-primary font-weight-bold">@Localize("Processing file, please wait...")</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localize("Close")</button>
                    <button type="button" class="btn btn-primary" id="btnImportFile">@Localize("Start Import")</button>
                </div>
            </div>
        </div>
    </div>

}

@section scripts{
    <script>

        $("#food-menu").addClass("active");
        $("#foodList-menu").addClass("active");

        var dt = $('#datatable').DataTable({
            'language': {
                "processing": '@Localize("Processing...")',
                "loadingRecords": "@Localize("Loading...")",
                'lengthMenu': '@Localize("Show") _MENU_ @Localize("Entries")',
                "zeroRecords": "@Localize("No Result Found")",
                "info": '<small>@Localize("Showing") _START_ - _END_ (_TOTAL_)</small>',
                "infoEmpty": '',
                "infoFiltered": '',
                "search": '@Localize("Search")',
                'paginate': {
                    'previous': '<i class="fa fa-chevron-left"></i>',
                    'next': '<i class="fa fa-chevron-right"></i>'
                }
            },
            order: [['0', 'desc']],
            'columnDefs': [
                {
                    "orderable": false,
                    'targets': [8]
                }
            ],
            'lengthMenu': [[50, 100, 150, 250, -1], [50, 100, 150, 250, "All"]],
        });

        function Delete(id) {
            $.alert({
                title: '@Localize("Are you sure want to delete?")',
                content: '@Localize("Once deleted, you will not be able to recover this record.")',
                rtl: isRTL(),
                theme: 'modern',
                buttons: {
                    confirm: {
                        text: '<i class="fa fa-trash"></i> @Localize("Delete")',
                        btnClass: 'btn btn-danger',
                        action: function (btn) {
                            var self = this;
                            self.showLoading(true);
                            $.ajax({
                                url: "/Food/DeleteFoodItem",
                                type: 'DELETE',
                                data: {
                                    Id: id
                                },
                                error: function (data) {
                                    if (data.status == 401) {
                                        window.location.href = '/Account/Login';
                                    }
                                    else if (data.status == 403) {
                                        errorMessage('@Localize("Access denied.")');
                                    }
                                    else {
                                        console.log(JSON.stringify(data));
                                    }
                                },
                                success: function (data) {
                                    if (data.status == "success") {
                                        successMessage('@Localize("Food Item deleted successfully.")');
                                        dt.row("#row" + id).remove().draw();
                                    }
                                    else {
                                        errorMessage(data.message);
                                    }
                                },
                                complete: function () {
                                    self.close();
                                }
                            });
                            return false;
                        }
                    },
                    cancel: {
                        text: '@Localize("Cancel")',
                        action: function () {
                        }
                    }
                }
            });
        }
        $('#btnImportFile').on('click', function () {
            var fileInput = $('#menuFileInput')[0];
            if (fileInput.files.length === 0) {
                errorMessage('@Localize("Please select an Excel or CSV file to upload.")');
                return;
            }

            var formData = new FormData();
            formData.append('menuFile', fileInput.files[0]);

            $('#btnImportFile').attr('disabled', true);
            $('#importLoading').removeClass('d-none');

            $.ajax({
                url: '/Food/ImportFoodItems',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (data) {
                    if (data.status === "success") {
                        successMessage(data.message);
                        setTimeout(function () {
                            window.location.reload();
                        }, 2000);
                    } else {
                        errorMessage(data.message);
                    }
                },
                error: function (xhr) {
                    errorMessage('@Localize("Error occurred while processing the file.")');
                    console.log(xhr.responseText);
                },
                complete: function () {
                    $('#btnImportFile').attr('disabled', false);
                    $('#importLoading').addClass('d-none');
                }
            });
        });
    </script>
}
