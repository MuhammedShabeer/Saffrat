@model Saffrat.Models.FoodItem

@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Add Food Item");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        @Localize("Add Food Item")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Food" asp-action="FoodItems">@Localize("Food Items")</a></li>
                    <li class="breadcrumb-item">@Localize("Add Food Item")</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <form id="frm" class="needs-validation" novalidate="">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="control-label">@Localize("Food Group") <code>*</code></label>
                            <select asp-for="GroupId" class="form-control selectpicker" data-live-search="true" required>
                                <option value="">@Localize("Choose Option")</option>
                                @foreach (var item in ViewBag.foodgroups)
                                {
                                    <option value="@item.Key">@item.Value</option>
                                }
                            </select>
                            <div class="invalid-feedback">
                                @Localize("Please select food group.")
                            </div>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="control-label">@Localize("Item Name") <code>*</code></label>
                            <input asp-for="ItemName" type="text" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please enter item name.")
                            </div>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="control-label">@Localize("Arabic Name") <code>*</code></label>
                            <input asp-for="ArabicName" type="text" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please enter arabic name.")
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="control-label">@Localize("Description")</label>
                        <textarea asp-for="Description" class="form-control"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label class="control-label">@Localize("Price") <code>*</code></label>
                            <div class="input-group">
                                <div class="input-group-text">@GetSetting.CurrencySymbol</div>
                                <input asp-for="Price" type="text" class="form-control cleave-number" inputmode="numeric" required />
                            </div>
                            <div class="invalid-feedback">
                                @Localize("Please enter price.")
                            </div>
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="control-label">@Localize("Van Sale Price")</label>
                            <div class="input-group">
                                <div class="input-group-text">@GetSetting.CurrencySymbol</div>
                                <input asp-for="VanSalePrice" type="text" class="form-control cleave-number" inputmode="numeric" />
                            </div>
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="control-label">@Localize("Whole Sale Price")</label>
                            <div class="input-group">
                                <div class="input-group-text">@GetSetting.CurrencySymbol</div>
                                <input asp-for="WholeSalePrice" type="text" class="form-control cleave-number" inputmode="numeric" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="control-label">@Localize("Barcode")</label>
                            <input asp-for="Barcode" type="text" class="form-control" />
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="control-label">@Localize("Permitted Sales Types")</label>
                            <div class="mt-2">
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input sales-type-check" type="checkbox" value="POS" id="salesPOS" @(string.IsNullOrEmpty(Model?.PermittedSalesTypes) || Model.PermittedSalesTypes.Contains("POS") ? "checked" : "")>
                                    <label class="form-check-label" for="salesPOS">@Localize("POS")</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input sales-type-check" type="checkbox" value="VanSale" id="salesVan" @(Model?.PermittedSalesTypes?.Contains("VanSale") == true ? "checked" : "")>
                                    <label class="form-check-label" for="salesVan">@Localize("Van Sale")</label>
                                </div>
                                <input type="hidden" asp-for="PermittedSalesTypes" id="PermittedSalesTypes" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="control-label">@Localize("Image")</label>
                        <div id="imagePreview" class="image-preview" style="background-image:url('/Media/ProductImage?name=default')">
                            <label for="groupimage">@Localize("Choose File")</label>
                            <input type="file" accept=".jpg, .jpeg, .png, .gif, .svg, .webp, .Jpg, .ico" name="itemimage" id="itemimage">
                        </div>
                    </div>
                    <div class="section-title">@Localize("Ingredient Consumptions")</div>
                    <div class="form-group">
                        <label class="control-label">@Localize("Ingredient Item")</label>
                        <select id="IngredientItem" class="form-control selectpicker" data-live-search="true" onchange="AddItemInCart();">
                            <option value="">@Localize("Choose Option")</option>
                            @foreach (var item in ViewBag.ingredients)
                            {
                                <option value="@item.Key">@item.Value</option>
                            }
                        </select>
                    </div>
                    <div>
                        <div class="table-responsive">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>@Localize("Item Name")</th>
                                        <th>@Localize("Stock")</th>
                                        <th>@Localize("Consumptions")</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="cart">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button class="btn btn-primary mr-1" type="submit" id="submit">@Localize("Save")</button>
                    <a asp-controller="Food" asp-action="FoodItems" class="btn btn-secondary mr-1">@Localize("Back To List")</a>
                </div>
            </form>
        </div>
    </div>
</div>


@section scripts{
    <script>
        $("#food-menu").addClass("active");
        $("#addFood-menu").addClass("active");

        $(function () {
            itemimage.onchange = evt => {
                const [file] = itemimage.files
                if (file) {
                    $('#imagePreview').css('background-image', 'url("' + URL.createObjectURL(file) + '")');
                }
            }
        });

        function AddItemInCart() {
            var IngredientItemId = $("#IngredientItem").val();

            if (IngredientItemId > 0) {
                jQuery.ajax({
                    url: "/Ingredient/IngredientItemDetail",
                    method: "GET",
                    data: {
                        Id: IngredientItemId
                    },
                    dataType: "json",
                    success: function (data) {
                        if (data.status == "success") {
                            var result = data.data;
                            if ($('#ingredient' + result.id).length) {
                                errorMessage('@Localize("Ingredient Item already in cart.")');
                            } else {
                                var htmlText = '<tr id="ingredient' + result.id + '"><td>' + result.itemName + '</td>';
                                htmlText += '<td><input type="hidden" name="ItemId[]" value="' + result.id + '"/>' + result.quantity + result.unit + '</td>';
                                htmlText += '<td><div class="mt-1 mb-1"><input id="quantity' + result.id + '" inputmode="numeric" name="ItemConsumption[]" type="text" value="1" class="form-control cleave-number" required /></div></td>';
                                htmlText += '<td><a href="javascript:void(0);" onclick="DeleteItemInCart(' + result.id + ');" class="btn btn-sm btn-danger mt-1 mr-1" title="Delete"><i class="fa fa-trash"></i></a></td></tr>';
                                $("#cart").append(htmlText);
                                InitCleaveNumber('#quantity' + result.id);
                            }
                        }
                        else {
                            errorMessage(data.message);
                        }
                    },
                    error: function (data) {
                        if (data.status == 401) {
                            window.location.href = '/Account/Login';
                        }
                        else if (data.status == 403) {
                            errorMessage('@Localize("Access denied.")');
                        }
                        else {
                            console.log(JSON.stringify(data));
                        }
                    }
                });
            }
        }

        function DeleteItemInCart(id) {
            $("#ingredient" + id).remove();
        }

        $("#frm").submit(function (e) {
            e.preventDefault();

            var salesTypes = [];
            $('.sales-type-check:checked').each(function () {
                salesTypes.push($(this).val());
            });
            $('#PermittedSalesTypes').val(salesTypes.join(','));

            var formData = new FormData(this);

            if (performValidation($("#frm"))) {
                $("#submit").addClass("disabled btn-progress");
                $.ajax({
                    url: '/Food/AddFoodItem',
                    type: 'POST',
                    data: formData,
                    dataType: "json",
                    contentType: false,
                    processData: false,
                    success: function (data) {
                        if (data.status == "success") {
                            successMessage('@Localize("Food Item created successfully.")');
                            $('#cart').html('');
                            $("#frm select[name='GroupId']").selectpicker('val', '');
                            $("#frm select[id='IngredientItem']").selectpicker('val', '');
                            $("#frm")[0].reset();
                            $('#imagePreview').css('background-image', 'url("/Media/ProductImage?name=default")');
                        }
                        else {
                            errorMessage(data.message);
                        }
                    },
                    error: function (data) {
                        if (data.status == 401) {
                            window.location.href = '/Account/Login';
                        }
                        else if (data.status == 403) {
                            errorMessage('@Localize("Access denied.")');
                        }
                        else {
                            console.log(JSON.stringify(data));
                        }
                    },
                    complete: function () {
                        $("#submit").removeClass("disabled btn-progress");
                        $("#frm").removeClass("was-validated");
                    }
                });
            }
        });
    </script>
}