@using Saffrat.Resources
@inherits LocService<TModel>

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = Localize("Forgot Password");
}

<div class="container mt-5">
    <div class="container">
        <div class="row">
            <div class="col-12 col-sm-8 offset-sm-2 col-md-6 offset-md-3 col-lg-6 offset-lg-3 col-xl-4 offset-xl-4">
                <div class="card">
                    <div class="card-header">
                        <h4>@Localize("Forgot Password")</h4>
                        <div class="card-header-action ms-auto">
                            <a href="javascript:void(0)" id="switchTheme" class="btn btn-light" data-toggle="tooltip">
                                <i class="fas fa-moon"></i>
                            </a>
                            <a href="#" id="switchLanguage" class="btn btn-light" data-toggle="tooltip" title="@Localize("Change Language")">
                                <i class="fas fa-globe"></i>
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-2">
                            <img src="@GetSetting.Logo" height="70" alt="Logo" />
                        </div>
                        @if (ViewBag.submitted != null)
                        {
                            <div class="text-muted">
                                <p class="text-center"><strong>@ViewBag.email</strong></p>
                                <p class="text-center">@Localize("We sent a verfication email link to your email. If this email address is registered, you'll receive instructions on how to set a new password.")</p>
                                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg w-100 mt-3">
                                    @Localize("Login")
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="text-muted">
                                @Localize("Enter your email address so we can reset your password.")
                            </div>
                            <form asp-controller="Account" asp-action="ForgotPassword" method="post" class="needs-validation" novalidate="">
                                <div class="form-group">
                                    <label for="email">Email</label>
                                    <input id="email" type="email" class="form-control" name="email" required="" autofocus="">
                                </div>
                                @Html.AntiForgeryToken()
                                <div class="form-group">
                                    <button type="submit" id="submit" class="btn btn-primary btn-lg w-100">
                                        @Localize("Forgot Password")
                                    </button>
                                </div>
                                <div class="form-group">
                                    <a asp-controller="Account" asp-action="Login" class="btn btn-secondary btn-lg w-100">
                                        @Localize("Login")
                                    </a>
                                </div>
                            </form>
                        }
                    </div>
                    <div class="card-footer text-center">
                        @Html.Raw(GetSetting.Copyright)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>