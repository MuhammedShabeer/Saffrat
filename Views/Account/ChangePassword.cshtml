@using Saffrat.Resources
@inherits LocService<TModel>

@{
    Layout = "_Layout";
    ViewData["Title"] = Localize("Change Password");
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        @Localize("Change Password")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item">@Localize("Change Password")</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 col-sm-8 offset-sm-2 col-md-6 offset-md-3 col-lg-6 offset-lg-3 col-xl-4 offset-xl-4">
        <div class="card card-primary">
            <div class="card-header">
                <h4>@Localize("Change Password")</h4>
            </div>
            <div class="card-body">
                <form id="frm" class="needs-validation" novalidate="">
                    <div class="form-group">
                        <label for="OldPassword">@Localize("Old Password") <code>*</code></label>
                        <input id="OldPassword" name="OldPassword" type="password" class="form-control" required>
                        <div class="invalid-feedback">
                            @Localize("Please enter old password.")
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="NewPassword">@Localize("New Password") <code>*</code></label>
                        <input id="NewPassword" name="NewPassword" type="password" class="form-control" required minlength="8">
                        <div class="invalid-feedback">
                            @Localize("Password must be at least 8 characters and contain at 3 of 4 of the following: upper case, lower case, number and special character.")
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="ConfirmPassword">@Localize("Confirm Password") <code>*</code></label>
                        <input id="ConfirmPassword" name="ConfirmPassword" type="password" class="form-control" required minlength="8">
                        <div class="invalid-feedback">
                            @Localize("Password must be at least 8 characters and contain at 3 of 4 of the following: upper case, lower case, number and special character.")
                        </div>
                    </div>
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <button type="submit" id="submit" class="btn btn-primary btn-lg w-100">
                            @Localize("Change Password")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section scripts{
    <script>
        $("#account-menu").addClass("active");
        $("#changePassword-menu").addClass("active");

        $("#frm").submit(function (e) {
            e.preventDefault();
            var formData = new FormData(this);

            if (performValidation($("#frm"))) {
                $("#submit").addClass("disabled btn-progress");
                $.ajax({
                    url: '/Account/ChangePassword',
                    type: 'POST',
                    data: formData,
                    dataType: "json",
                    contentType: false,
                    processData: false,
                    success: function (data) {
                        if (data.status == "success") {
                            $("#frm")[0].reset();
                            successMessage('@Localize("Password changed successfully.")');
                        }
                        else {
                            errorMessage(data.message);
                        }
                    },
                    error: function (data) {
                        if(data.status == 401){
                            window.location.href = '/Account/Login';
                        }
                        else if(data.status == 403){
                            errorMessage('@Localize("Access denied.")');
                        }
                        else{
                            console.log(JSON.stringify(data));
                        }
                    },
                    complete: function () {
                        $("#submit").removeClass("disabled btn-progress");
                    }
                });
            }
        });
    </script>
}