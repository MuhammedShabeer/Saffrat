@model Saffrat.ViewModels.StatementOfAccountsVM
@using Saffrat.Resources
@inherits LocService<TModel>

@{
    bool isDebitAccount = ViewBag.IsDebitAccount ?? false;
    string GetBalanceLabel(decimal bal)
    {
        if (bal == 0) return "";
        if (isDebitAccount) return bal > 0 ? "DR" : "CR";
        return bal > 0 ? "CR" : "DR";
    }
}

<div class="modal-header bg-primary text-white py-3">
    <h5 class="modal-title fw-bold">
        <i class="fa fa-file-invoice me-2"></i>
        @ViewBag.AccountName (@ViewBag.AccountCode) - @Localize("Detailed Statement")
    </h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body p-0">
    <div class="bg-light p-3 border-bottom d-flex justify-content-between align-items-center">
        <div>
            <span class="text-muted small text-uppercase fw-bold">@Localize("Period")</span>
            <div class="fw-bold fs-6">@Model.StartDate.ToString("MMM dd, yyyy") - @Model.EndDate.ToString("MMM dd, yyyy")</div>
        </div>
        <div class="text-end">
            <span class="text-muted small text-uppercase fw-bold">@Localize("Opening Balance")</span>
            <div class="fw-bold fs-6 text-primary">@GetCurrency(Math.Abs(Model.OpeningBalance)) @GetBalanceLabel(Model.OpeningBalance)</div>
        </div>
    </div>

    <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
        <table class="table table-sm table-hover table-striped align-middle mb-0">
            <thead class="bg-light sticky-top shadow-sm small fw-bold">
                <tr>
                    <th class="ps-3 py-2">@Localize("Date")</th>
                    <th class="py-2">@Localize("Reference")</th>
                    <th class="py-2">@Localize("Description")</th>
                    <th class="py-2">@Localize("Offset Account")</th>
                    <th class="text-end py-2">@Localize("Debit")</th>
                    <th class="text-end py-2">@Localize("Credit")</th>
                    <th class="text-end pe-3 py-2">@Localize("Balance")</th>
                    <th class="text-center py-2">@Localize("Action")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Transactions.Any())
                {
                    @foreach (var row in Model.Transactions)
                    {
                        <tr class="small">
                            <td class="ps-3">@row.Date.ToString("yyyy-MM-dd")</td>
                            <td class="fw-bold text-nowrap">@row.Reference</td>
                            <td class="text-wrap" style="max-width: 150px;">@row.Description</td>
                            <td class="text-muted">@row.OffsetAccountName</td>
                            <td class="text-end text-success">@(row.Debit > 0 ? GetCurrency(row.Debit) : "-")</td>
                            <td class="text-end text-danger">@(row.Credit > 0 ? GetCurrency(row.Credit) : "-")</td>
                            <td class="text-end pe-3 fw-bold">@GetCurrency(Math.Abs(row.RunningBalance)) @GetBalanceLabel(row.RunningBalance)</td>
                            <td class="text-center">
                                @if (row.SourceDocumentId > 0)
                                {
                                    <button class="btn btn-sm btn-outline-primary py-0 px-2 view-source-doc" 
                                            data-type="@row.SourceDocumentType" 
                                            data-id="@row.SourceDocumentId" 
                                            title="@Localize("View Detailed Vision")">
                                        <i class="fa fa-eye"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted small">@Localize("No transactions found in this period.")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="modal-footer bg-light py-3 border-top d-flex justify-content-between">
    <div class="text-start">
        <span class="text-muted small text-uppercase fw-bold d-block">@Localize("Closing Balance")</span>
        <span class="h5 fw-bold text-primary mb-0">@GetCurrency(Math.Abs(Model.ClosingBalance)) @GetBalanceLabel(Model.ClosingBalance)</span>
    </div>
    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">@Localize("Close")</button>
</div>

<script>
    $('.view-source-doc').on('click', function() {
        var type = $(this).data('type');
        var id = $(this).data('id');
        
        $('#detailModalBody').html('<div class="text-center py-5"><div class="spinner-border text-dark"></div></div>');
        $('#detailModal').modal('show');

        $.get('@Url.Action("GetSourceDocumentDetails", "AccountingEngine")', { type: type, id: id }, function(res) {
            if (res.status === 'success') {
                var html = '<div class="p-4">';
                html += '<div class="d-flex justify-content-between mb-4 border-bottom pb-2">';
                html += '<div><span class="text-muted small">TYPE</span><br/><strong>' + res.type + '</strong></div>';
                
                if (res.type === 'POS Order') {
                    html += '<div><span class="text-muted small">CUSTOMER</span><br/><strong>' + (res.data.customerName || 'Walk-in') + '</strong></div>';
                    html += '<div><span class="text-muted small">TOTAL</span><br/><strong>' + res.data.total.toFixed(2) + '</strong></div>';
                } else if (res.type === 'Purchase') {
                    html += '<div><span class="text-muted small">SUPPLIER</span><br/><strong>' + res.data.supplierName + '</strong></div>';
                    html += '<div><span class="text-muted small">INVOICE</span><br/><strong>' + res.data.invoiceNo + '</strong></div>';
                } else if (res.type === 'Payroll') {
                    html += '<div><span class="text-muted small">EMPLOYEE</span><br/><strong>' + res.data.employeeName + '</strong></div>';
                    html += '<div><span class="text-muted small">PERIOD</span><br/><strong>' + res.data.period + '</strong></div>';
                }
                html += '</div>';

                // Items Table
                html += '<table class="table table-sm table-bordered">';
                html += '<thead class="bg-light text-uppercase small"><tr><th>Item/Title</th><th class="text-center">Qty/Type</th><th class="text-end">Price/Amt</th><th class="text-end">Total</th></tr></thead><tbody>';
                
                var items = res.data.items || res.data.details;
                items.forEach(function(item) {
                    html += '<tr>';
                    html += '<td>' + (item.itemName || item.title) + '</td>';
                    html += '<td class="text-center">' + (item.quantity !== undefined ? item.quantity : (item.amountType || '-')) + '</td>';
                    html += '<td class="text-end">' + (item.price || item.purchasePrice || item.amount || 0).toFixed(2) + '</td>';
                    html += '<td class="text-end">' + (item.total || item.amount || 0).toFixed(2) + '</td>';
                    html += '</tr>';
                });
                html += '</tbody></table></div>';
                
                $('#detailModalBody').html(html);
                $('#detailModalTitle').text(res.type + ' Detailed Vision');
            } else {
                $('#detailModalBody').html('<div class="alert alert-danger m-3">' + res.message + '</div>');
            }
        });
    });
</script>
