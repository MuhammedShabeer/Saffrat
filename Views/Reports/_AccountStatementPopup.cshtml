@model Saffrat.ViewModels.StatementOfAccountsVM
@using Saffrat.Resources
@inherits LocService<TModel>

<div class="modal-header bg-primary text-white py-3">
    <h5 class="modal-title fw-bold">
        <i class="fa fa-file-invoice me-2"></i>
        @ViewBag.AccountName (@ViewBag.AccountCode) - @Localize("Detailed Statement")
    </h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<div class="modal-body p-0">
    <div class="bg-light p-3 border-bottom d-flex justify-content-between align-items-center">
        <div>
            <span class="text-muted small text-uppercase fw-bold">@Localize("Period")</span>
            <div class="fw-bold fs-6">@Model.StartDate.ToString("MMM dd, yyyy") - @Model.EndDate.ToString("MMM dd, yyyy")</div>
        </div>
        <div class="text-end">
            <span class="text-muted small text-uppercase fw-bold">@Localize("Opening Balance")</span>
            <div class="fw-bold fs-6 text-primary">@GetCurrency(Math.Abs(Model.OpeningBalance)) @(Model.OpeningBalance < 0 ? "DR" : "CR")</div>
        </div>
    </div>

    <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
        <table class="table table-sm table-hover table-striped align-middle mb-0">
            <thead class="bg-light sticky-top shadow-sm small fw-bold">
                <tr>
                    <th class="ps-3 py-2">@Localize("Date")</th>
                    <th class="py-2">@Localize("Reference")</th>
                    <th class="py-2">@Localize("Description")</th>
                    <th class="text-end py-2">@Localize("Debit")</th>
                    <th class="text-end py-2">@Localize("Credit")</th>
                    <th class="text-end pe-3 py-2">@Localize("Balance")</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Transactions.Any())
                {
                    @foreach (var row in Model.Transactions)
                    {
                        <tr class="small">
                            <td class="ps-3">@row.Date.ToString("yyyy-MM-dd")</td>
                            <td class="fw-bold text-nowrap">@row.Reference</td>
                            <td class="text-wrap" style="max-width: 250px;">@row.Description</td>
                            <td class="text-end text-success">@(row.Debit > 0 ? GetCurrency(row.Debit) : "-")</td>
                            <td class="text-end text-danger">@(row.Credit > 0 ? GetCurrency(row.Credit) : "-")</td>
                            <td class="text-end pe-3 fw-bold">@GetCurrency(Math.Abs(row.RunningBalance)) @(row.RunningBalance < 0 ? "DR" : "CR")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted small">@Localize("No transactions found in this period.")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<div class="modal-footer bg-light py-3 border-top d-flex justify-content-between">
    <div class="text-start">
        <span class="text-muted small text-uppercase fw-bold d-block">@Localize("Closing Balance")</span>
        <span class="h5 fw-bold text-primary mb-0">@GetCurrency(Math.Abs(Model.ClosingBalance)) @(Model.ClosingBalance < 0 ? "DR" : "CR")</span>
    </div>
    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">@Localize("Close")</button>
</div>
