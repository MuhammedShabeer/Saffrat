@using Saffrat.ViewModels
@model IEnumerable<TrialBalanceModel>
@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = "Trial Balance Report";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var groups = Model.GroupBy(x => x.AccountGroup).OrderBy(x => x.Key);
    decimal gTotalDebit = Model.Sum(x => x.TotalDebit);
    decimal gTotalCredit = Model.Sum(x => x.TotalCredit);
}

<div class="page-title d-flex justify-content-between">
    <h3>@Localize("Trial Balance Report")</h3>
</div>

<div class="row">

    <div class="col-lg-12">
        <div class="card bg-white mt-1 border-0 custom-shadow rounded">
            <div class="card-body pb-0">

                <form method="get" asp-controller="Reports" asp-action="TrialBalance">
                    <div class="row gx-1">
                        <div class="col-md-3">
                            <label class="font-600 mb-0 form-label">@Localize("Start Date")</label>
                            <div class="input-group mb-3">
                                <span class="input-group-text"><i class="fa fa-calendar font-size-14"></i></span>
                                <input type="date" class="form-control" name="start" value="@ViewBag.start">
                            </div>
                        </div>

                        <div class="col-md-3">
                            <label class="font-600 mb-0 form-label">@Localize("End Date")</label>
                            <div class="input-group mb-3">
                                <span class="input-group-text"><i class="fa fa-calendar font-size-14"></i></span>
                                <input type="date" class="form-control" name="end" value="@ViewBag.end">
                            </div>
                        </div>

                        <div class="col-md-2 mt-4 pt-1">
                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-primary btn-block"><i class="fa fa-filter p-1"></i> @Localize("Filter")</button>
                            </div>
                        </div>
                        <div class="col-md-2 mt-4 pt-1">
                            <div class="d-grid mb-3">
                                <button onclick="window.print()" type="button" class="btn btn-primary d-block w-100"><i class="fa-solid fa-print"></i> @Localize("Print")</button>
                            </div>
                        </div>

                    </div>
                </form>

            </div>

        </div>

        <div class="card bg-white mt-3 border-0 custom-shadow rounded">
            <div class="card-body">
                <style>
                    @@media print {
                        body * {
                            visibility: hidden;
                        }

                        #printarea, #printarea * {
                            visibility: visible;
                        }

                        #printarea {
                            position: absolute;
                            left: 0;
                            top: 0;
                            width: 100%;
                        }
                    }
                </style>
                <div id="printarea">
                    <div class="text-center mb-4">
                        <h4 class="mb-0"><strong>@Localize("Trial Balance")</strong></h4>
                        <p class="text-muted">From @ViewBag.start To @ViewBag.end</p>
                    </div>

                    <div class="table-responsive mt-3">
                        <table class="table table-bordered table-striped" style="width:100%" id="exportTable">
                            <thead class="bg-primary text-white">
                                <tr>
                                    <th>@Localize("Particulars")</th>
                                    <th class="text-end">@Localize("Opening Balance")</th>
                                    <th class="text-end">@Localize("Debit (Period)")</th>
                                    <th class="text-end">@Localize("Credit (Period)")</th>
                                    <th class="text-end">@Localize("Closing Balance")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var group in groups)
                                {
                                    <tr class="table-secondary">
                                        <td class="bg-light"><strong>@group.Key</strong></td>
                                        <td class="bg-light"></td>
                                        <td class="bg-light"></td>
                                        <td class="bg-light"></td>
                                        <td class="bg-light"></td>
                                    </tr>
                                    @foreach (var account in group)
                                    {
                                        bool isDebitNormal = (account.Category == 0 || account.Category == 4);
                                        <tr>
                                            <td class="ps-4">
                                                <a href="javascript:void(0)" class="text-primary fw-bold show-account-details" 
                                                   data-id="@account.AccountId" 
                                                   data-name="@account.AccountName">
                                                    @account.AccountName
                                                </a>
                                            </td>
                                            <td class="text-end">
                                                @Math.Abs(account.OpeningBalance).ToString("N2")
                                                <small class="text-muted">@(account.OpeningBalance >= 0 ? (isDebitNormal ? "DR" : "CR") : (isDebitNormal ? "CR" : "DR"))</small>
                                            </td>
                                            <td class="text-end text-success">@account.TotalDebit.ToString("N2")</td>
                                            <td class="text-end text-danger">@account.TotalCredit.ToString("N2")</td>
                                            <td class="text-end fw-bold">
                                                @Math.Abs(account.ClosingBalance).ToString("N2")
                                                <small class="text-primary">@(account.ClosingBalance >= 0 ? (isDebitNormal ? "DR" : "CR") : (isDebitNormal ? "CR" : "DR"))</small>
                                            </td>
                                        </tr>
                                    }
                                    <tr class="table-light">
                                        <td class="text-end"><strong>Total @group.Key:</strong></td>
                                        <td class="text-end"><strong>@group.Sum(x => x.OpeningBalance).ToString("N2")</strong></td>
                                        <td class="text-end"><strong>@group.Sum(x => x.TotalDebit).ToString("N2")</strong></td>
                                        <td class="text-end"><strong>@group.Sum(x => x.TotalCredit).ToString("N2")</strong></td>
                                        <td class="text-end"><strong>@group.Sum(x => x.ClosingBalance).ToString("N2")</strong></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="bg-primary text-white font-weight-bold">
                                    <th class="text-end text-white">@Localize("Grand Total")</th>
                                    <th class="text-end text-white">@Model.Sum(x => x.OpeningBalance).ToString("N2")</th>
                                    <th class="text-end text-white">@Model.Sum(x => x.TotalDebit).ToString("N2")</th>
                                    <th class="text-end text-white">@Model.Sum(x => x.TotalCredit).ToString("N2")</th>
                                    <th class="text-end text-white">@Model.Sum(x => x.ClosingBalance).ToString("N2")</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- Modal for detailed statement -->
<div class="modal fade" id="statementModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered shadow">
        <div class="modal-content border-0" id="statementModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <div class="mt-2">@Localize("Loading detailed statement...")</div>
            </div>
        </div>
    </div>
</div>

<!-- Modal for source document details (POS items, etc.) -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered shadow">
        <div class="modal-content border-0">
            <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title fw-bold" id="detailModalTitle">@Localize("Document Vision")</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0" id="detailModalBody">
                <!-- Content loaded via Ajax -->
            </div>
        </div>
    </div>
</div>

<style>
    .show-account-details:hover { text-decoration: underline !important; color: #0056b3 !important; }
    #exportTable tbody tr:hover { background-color: rgba(0, 123, 255, 0.05); }
</style>

@section scripts{
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/dataTables.buttons.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.html5.min.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.print.min.js"></script>

    <script>
        var fileName = '@Localize("Trial Balance") - @ViewBag.start to @ViewBag.end';

        $("#report-menu").addClass("active");
        $("#trialBalanceReport-menu").addClass("active");

        $(document).ready(function () {
            $('#exportTable').DataTable({
                dom: 'B',
                'language': {
                    "processing": '@Localize("Processing...")',
                    "loadingRecords": "@Localize("Loading...")",
                    'lengthMenu': '@Localize("Show") _MENU_ @Localize("Entries")',
                    "zeroRecords": "@Localize("No Result Found")",
                    "info": '<small>@Localize("Showing") _START_ - _END_ (_TOTAL_)</small>',
                    "infoEmpty": '',
                    "infoFiltered": '',
                    "search": '@Localize("Search")',
                    'paginate': {
                        'previous': '<i class="fa fa-chevron-left"></i>',
                        'next': '<i class="fa fa-chevron-right"></i>'
                    }
                },
                "ordering": false,
                "paging": false,
                buttons: [
                    {
                        extend: 'excel',
                        title: fileName,
                        text: '<i title="excel" class="fa fa-file-excel"></i>',
                        className: 'btn btn-outline-success',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    },
                    {
                        extend: 'pdf',
                        title: fileName,
                        text: '<i title="pdf" class="fa fa-file-pdf"></i>',
                        className: 'btn btn-outline-danger',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        },
                        customize: function (doc) {
                            if (doc.content[1] && doc.content[1].table) {
                                doc.content[1].table.widths = Array(doc.content[1].table.body[0].length + 1).join('*').split('');
                            }
                        }
                    },
                    {
                        extend: 'print',
                        title: fileName,
                        text: '<i title="print" class="fa fa-print"></i>',
                        className: 'btn btn-outline-info',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    }
                ]
            });

            // Handle Detail Popup
            $('.show-account-details').on('click', function() {
                var accountId = $(this).data('id');
                var start = '@ViewBag.start';
                var end = '@ViewBag.end';
                
                $('#statementModalContent').html('<div class="modal-body text-center py-5"><div class="spinner-border text-primary" role="status"></div><div class="mt-2">@Localize("Loading detailed statement...")</div></div>');
                $('#statementModal').modal('show');

                $.ajax({
                    url: '@Url.Action("GetAccountStatement", "Reports")',
                    type: 'GET',
                    data: { accountId: accountId, start: start, end: end },
                    success: function(response) {
                        $('#statementModalContent').html(response);
                    },
                    error: function() {
                        $('#statementModalContent').html('<div class="modal-body text-center py-5 text-danger"><i class="fa fa-exclamation-triangle fa-3x mb-3"></i><br/>@Localize("Error loading detailed statement. Please try again.")</div>');
                    }
                });
            });
        });
    </script>
}
