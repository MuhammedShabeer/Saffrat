@model IEnumerable<Saffrat.Models.Order>

@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Sale Detailed Report");
    Layout = "~/Views/Shared/_Layout.cshtml";

    string[] orderTypes = { "None", "Dine In", "Pick Up", "Delivery" };
    orderTypes[1] = Localize("Dine In").ToString();
    orderTypes[2] = Localize("Pick Up").ToString();
    orderTypes[3] = Localize("Delivery").ToString();
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        @Localize("Sale Detailed Report")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item">@Localize("Sale Detailed Report")</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <form asp-action="SaleDetailedReport" asp-controller="Reports" method="get" class="needs-validation" novalidate="">
                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label class="control-label">@Localize("From") <code>*</code></label>
                            <input type="date" name="start" value="@ViewBag.start" onclick="this.showPicker()" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please select date.")
                            </div>
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="control-label">@Localize("To") <code>*</code></label>
                            <input type="date" name="end" value="@ViewBag.end" onclick="this.showPicker()" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please select date.")
                            </div>
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="w-100 d-none d-md-inline-block">&nbsp;</label>
                            <button class="btn btn-primary btn-icon" type="submit"><i class="fas fa-paper-plane"></i> @Localize("Filter")</button>
                        </div>
                    </div>
                </form>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered" id="exportTable">
                        <thead>
                            <tr>
                                <th>@Localize("#")</th>
                                <th>@Localize("Date")</th>
                                <th>@Localize("Type")</th>
                                <th>@Localize("Created By")</th>
                                <th>@Localize("Closed By")</th>
                                <th>@Localize("Table")</th>
                                <th>@Localize("Items")</th>
                                <th>@Localize("Quantity")</th>
                                <th>@Localize("Sub Total")</th>
                                <th>@Localize("Charge")</th>
                                <th>@Localize("Discount")</th>
                                <th>@Localize("Tax")</th>
                                <th>@Localize("Total")</th>
                                <th>@Localize("Paid")</th>
                                <th>@Localize("Due")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.ClosedAt</td>
                                    <td>@orderTypes[item.OrderType]</td>
                                    <td>@item.CreatedBy</td>
                                    <td>@item.ClosedBy</td>
                                    @if (item.OrderType == 1)
                                    {
                                        <td>@item.TableName</td>
                                    }
                                    else
                                    {
                                        <td></td>
                                    }
                                    <td></td>
                                    <td>
                                        @{
                                            var totalQty = item.OrderDetails.Sum(x => x.Quantity);
                                            var totalFoc = item.OrderDetails.Sum(x => x.FocQuantity);
                                        }
                                        @totalQty
                                        @if (totalFoc > 0)
                                        {
                                            <span> + @totalFoc FOC</span>
                                        }
                                    </td>
                                    <td>@item.SubTotal</td>
                                    <td>@item.ChargeTotal</td>
                                    <td>@item.DiscountTotal</td>
                                    <td>@item.TaxTotal</td>
                                    <td>@item.Total</td>
                                    <td>@item.PaidAmount</td>
                                    <td>@item.DueAmount</td>
                                </tr>
                                foreach (var item1 in item.OrderDetails)
                                {
                                    var i = 1;
                                    <tr class="items">
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td>
                                            @item1.Item.ItemName
                                            @if (item1.OrderItemModifiers.Count > 0)
                                            {
                                                <br />
                                                <span> - </span>
                                            }
                                            @foreach (var item2 in item1.OrderItemModifiers)
                                            {
                                                @item2.Modifier.Title
                                                if (i != item1.OrderItemModifiers.Count)
                                                {
                                                    <span>, </span>
                                                }
                                                i++;
                                            }
                                        </td>
                                        <td>
                                            @item1.Quantity
                                            @if (item1.FocQuantity > 0)
                                            {
                                                <span> + @item1.FocQuantity FOC</span>
                                            }
                                        </td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                }
                            }
                        </tbody>
                        @if (Model.Count() > 0)
                        {
                            <tfoot>
                                <tr>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th>@GetCurrency(Model.Sum(x=> x.SubTotal))</th>
                                    <th>@GetCurrency(Model.Sum(x=> x.ChargeTotal))</th>
                                    <th>@GetCurrency(Model.Sum(x=> x.DiscountTotal))</th>
                                    <th>@GetCurrency(Model.Sum(x=> x.TaxTotal))</th>
                                    <th>@GetCurrency(Model.Sum(x=> x.Total))</th>
                                    <th>@GetCurrency(Model.Sum(x=> x.PaidAmount))</th>
                                    <th>@GetCurrency(Model.Sum(x=> x.DueAmount))</th>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


@section scripts{
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/dataTables.buttons.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.html5.min.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.print.min.js"></script>

    <script>
        $('#period').val('@ViewBag.period ');
        var fileName = '@Localize("Sale Detailed Report") (@Localize("From") @ViewBag.start @Localize("To") @ViewBag.end)';

        $("#report-menu").addClass("active");
        $("#saleDetailedReport-menu").addClass("active");
        $(document).ready(function () {
            $('#exportTable').DataTable({
                dom: 'B',
                'language': {
                    "processing": '@Localize("Processing...")',
                    "loadingRecords": "@Localize("Loading...")",
                    'lengthMenu': '@Localize("Show") _MENU_ @Localize("Entries")',
                    "zeroRecords": "@Localize("No Result Found")",
                    "info": '<small>@Localize("Showing") _START_ - _END_ (_TOTAL_)</small>',
                    "infoEmpty": '',
                    "infoFiltered": '',
                    "search": '@Localize("Search")',
                    'paginate': {
                        'previous': '<i class="fa fa-chevron-left"></i>',
                        'next': '<i class="fa fa-chevron-right"></i>'
                    }
                },
                "ordering": false,
                paging: false,
                buttons: [
                    {
                        extend: 'excel',
                        title: fileName,
                        text: '<i title="excel" class="fa fa-file-excel"></i>',
                        className: 'btn',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    },
                    {
                        extend: 'pdf',
                        title: fileName,
                        text: '<i title="pdf" class="fa fa-file-pdf"></i>',
                        className: 'btn',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        },
                        customize: function (doc) {
                            doc.content[1].table.widths =
                                Array(doc.content[1].table.body[0].length + 1).join('*').split('');
                        }
                    },
                    {
                        extend: 'print',
                        title: fileName,
                        text: '<i title="print" class="fa fa-print"></i>',
                        className: 'btn',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    },
                    {
                        extend: 'csv',
                        title: fileName,
                        text: '<i title="csv" class="fa fa-file-csv"></i>',
                        className: 'btn',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    },
                ]
            });
        });
    </script>
}
