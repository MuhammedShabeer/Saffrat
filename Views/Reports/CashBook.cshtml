@model Saffrat.ViewModels.BankBookVM
@using Saffrat.Resources
@inherits LocService<Saffrat.ViewModels.BankBookVM>

@{
    ViewData["Title"] = Localize(Model.ReportType);
    Layout = "~/Views/Shared/_Layout.cshtml";
    var settings = GetSetting;
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>@Localize(Model.ReportType)</h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item">@Localize(Model.ReportType)</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="CashBook" asp-controller="Reports" method="get" class="needs-validation" novalidate="">
                    <div class="row align-items-end">
                        <div class="col-md-3 form-group">
                            <label class="control-label fw-bold small">@Localize("Date") <code>*</code></label>
                            <input type="date" name="date" value="@ViewBag.date" onclick="this.showPicker()" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please select date.")
                            </div>
                        </div>
                        <div class="col-md-3 form-group">
                            <button class="btn btn-primary btn-icon" type="submit"><i class="fas fa-filter"></i> @Localize("Filter")</button>
                        </div>
                    </div>
                </form>

                <hr class="my-4" />

                <div class="summary-box mb-4 p-3 bg-light border rounded">
                    <div class="row">
                        <div class="col-md-4 text-center border-md-end">
                            <h6 class="text-muted small text-uppercase">@Localize("Opening Balance")</h6>
                            <h4 class="mb-0">@GetCurrency(Model.OpeningBalance)</h4>
                        </div>
                        <div class="col-md-4 text-center border-md-end">
                            <h6 class="text-muted small text-uppercase">@Localize("Net Change")</h6>
                            @{
                                var netChange = Model.Transactions.Sum(t => t.Inflow - t.Outflow);
                            }
                            <h4 class="mb-0 @(netChange >= 0 ? "text-success" : "text-danger")">
                                @(netChange > 0 ? "+" : "")@GetCurrency(netChange)
                            </h4>
                        </div>
                        <div class="col-md-4 text-center">
                            <h6 class="text-muted small text-uppercase font-weight-bold">@Localize("Closing Balance")</h6>
                            <h4 class="mb-0 font-weight-bold text-primary">@GetCurrency(Model.ClosingBalance)</h4>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle" id="exportTable">
                        <thead class="bg-light">
                            <tr>
                                <th>@Localize("Ref / Time")</th>
                                <th>@Localize("Account")</th>
                                <th>@Localize("Description")</th>
                                <th class="text-end">@Localize("Inflow")</th>
                                <th class="text-end">@Localize("Outflow")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Transactions)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-bold">@item.Reference</div>
                                        <small class="text-muted">@item.Date.ToShortTimeString()</small>
                                    </td>
                                    <td>@item.AccountName</td>
                                    <td>
                                        @item.Description
                                        @if (!string.IsNullOrEmpty(item.SourceDocumentType))
                                        {
                                            <br /><small class="badge bg-info-light text-info border">@item.SourceDocumentType #@item.SourceDocumentId</small>
                                        }
                                    </td>
                                    <td class="text-end text-success">
                                        @(item.Inflow > 0 ? GetCurrency(item.Inflow) : "-")
                                    </td>
                                    <td class="text-end text-danger">
                                        @(item.Outflow > 0 ? GetCurrency(item.Outflow) : "-")
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-light fw-bold">
                            <tr>
                                <td colspan="3" class="text-end">@Localize("Total")</td>
                                <td class="text-end text-success">@GetCurrency(Model.Transactions.Sum(x => x.Inflow))</td>
                                <td class="text-end text-danger">@GetCurrency(Model.Transactions.Sum(x => x.Outflow))</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/dataTables.buttons.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.html5.min.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.print.min.js"></script>

    <script>
        var fileName = '@Localize(Model.ReportType) - @ViewBag.date';

        $("#report-menu").addClass("active");
        $("#cashBookReport-menu").addClass("active");

        $(document).ready(function () {
            $('#exportTable').DataTable({
                dom: 'Bfrtip',
                'language': {
                    "processing": '@Localize("Processing...")',
                    "loadingRecords": "@Localize("Loading...")",
                    'lengthMenu': '@Localize("Show") _MENU_ @Localize("Entries")',
                    "zeroRecords": "@Localize("No Result Found")",
                    "info": '<small>@Localize("Showing") _START_ - _END_ (_TOTAL_)</small>',
                    "infoEmpty": '',
                    "infoFiltered": '',
                    "search": '@Localize("Search")',
                    'paginate': {
                        'previous': '<i class="fa fa-chevron-left"></i>',
                        'next': '<i class="fa fa-chevron-right"></i>'
                    }
                },
                "ordering": true,
                "order": [[0, "asc"]],
                buttons: [
                    {
                        extend: 'excel',
                        title: fileName,
                        text: '<i title="excel" class="fa fa-file-excel"></i>',
                        className: 'btn btn-outline-success btn-sm',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    },
                    {
                        extend: 'pdf',
                        title: fileName,
                        text: '<i title="pdf" class="fa fa-file-pdf"></i>',
                        className: 'btn btn-outline-danger btn-sm',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        },
                        customize: function (doc) {
                            doc.content[1].table.widths = Array(doc.content[1].table.body[0].length + 1).join('*').split('');
                        }
                    },
                    {
                        extend: 'print',
                        title: fileName,
                        text: '<i title="print" class="fa fa-print"></i>',
                        className: 'btn btn-outline-info btn-sm',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    }
                ]
            });
        });
    </script>
}
