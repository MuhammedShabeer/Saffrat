@model IEnumerable<Saffrat.Models.Attendance>

@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Attendance Report");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        @Localize("Attendance Report")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item">@Localize("Attendance Report")</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <form asp-action="AttendanceReport" asp-controller="Reports" method="get" class="needs-validation" novalidate="">
                    <div class="row">
                        <div class="col-md-3 form-group">
                            <label class="control-label">@Localize("Employee") <code>*</code></label>
                            <select class="form-control selectpicker" data-live-search="true" name="employee" id="employee" required>
                                <option value="">@Localize("Choose Option")</option>
                                @foreach (var item in ViewBag.employees)
                                {
                                    <option value="@item.Key">@item.Value</option>
                                }
                            </select>
                            <div class="invalid-feedback">
                                @Localize("Please select employee.")
                            </div>
                        </div>
                        <div class="col-md-3 form-group">
                            <label class="control-label">@Localize("From") <code>*</code></label>
                            <input type="date" name="start" value="@ViewBag.start" onclick="this.showPicker()" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please select date.")
                            </div>
                        </div>
                        <div class="col-md-3 form-group">
                            <label class="control-label">@Localize("To") <code>*</code></label>
                            <input type="date" name="end" value="@ViewBag.end" onclick="this.showPicker()" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please select date.")
                            </div>
                        </div>
                        <div class="col-md-3 form-group">
                            <label class="w-100 d-none d-md-inline-block">&nbsp;</label>
                            <button class="btn btn-primary btn-icon" type="submit"><i class="fas fa-paper-plane"></i> @Localize("Filter")</button>
                        </div>
                    </div>
                </form>
                <div class="table-responsive">
                    <table class="table table-bordered" id="exportTable">
                        <thead>
                            <tr>
                                <th>@Localize("#")</th>
                                <th>@Localize("Employee")</th>
                                <th>@Localize("Shift")</th>
                                <th>@Localize("Date")</th>
                                <th>@Localize("Clock In")</th>
                                <th>@Localize("Clock Out")</th>
                                <th>@Localize("Status")</th>
                                <th>@Localize("Updated At")</th>
                                <th>@Localize("Updated By")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var id = "row" + item.Id;
                                <tr id="@id">
                                    <td>@item.Id</td>
                                    <td>
                                        @String.Format("{0} (EMP-{1})", item.Employee.Name, item.Employee.Id) <br />
                                        @String.Format("{0} - {1}", item.Employee.Department.Title, item.Employee.Designation.Title) <br />
                                    </td>
                                    <td>@item.Shift.Title</td>
                                    <td>@item.AttendaceDate.ToShortDateString()</td>
                                    <td>@item.ClockIn</td>
                                    <td>@item.ClockOut</td>
                                    <td>
                                        @if (item.Status == "Present")
                                        {
                                            <div class="badge badge-primary">@Localize(item.Status)</div>
                                        }
                                        else if (item.Status == "Absent")
                                        {
                                            <div class="badge badge-danger">@Localize(item.Status)</div>
                                        }
                                        else if (item.Status == "Leave")
                                        {
                                            <div class="badge badge-dark">@Localize(item.Status)</div>
                                        }
                                        else if (item.Status == "Late")
                                        {
                                            <div class="badge badge-warning">@Localize(item.Status)</div>
                                        }
                                    </td>
                                    <td>@item.UpdatedAt</td>
                                    <td>&#64;@item.UpdatedBy</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="8" class="text-end">@Localize("Present")</th>
                                <th>@Model.Where(x=> x.Status == "Present").Count()</th>
                            </tr>
                            <tr>
                                <th colspan="8" class="text-end">@Localize("Absent")</th>
                                <th>@Model.Where(x=> x.Status == "Absent").Count()</th>
                            </tr>
                            <tr>
                                <th colspan="8" class="text-end">@Localize("Leave")</th>
                                <th>@Model.Where(x=> x.Status == "Leave").Count()</th>
                            </tr>
                            <tr>
                                <th colspan="8" class="text-end">@Localize("Late")</th>
                                <th>@Model.Where(x=> x.Status == "Late").Count()</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


@section scripts{
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/dataTables.buttons.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.html5.min.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.print.min.js"></script>

    <script>
        $('#employee').val('@ViewBag.employee');
        var fileName = '@Localize("Attendance Report") (@Localize("From") @ViewBag.start @Localize("To") @ViewBag.end)';

        $("#report-menu").addClass("active");
        $("#attendanceReport-menu").addClass("active");
        $(document).ready(function () {
            $('#exportTable').DataTable({
                dom: 'B',
                'language': {
                    "processing": '@Localize("Processing...")',
                    "loadingRecords": "@Localize("Loading...")",
                    'lengthMenu': '@Localize("Show") _MENU_ @Localize("Entries")',
                    "zeroRecords": "@Localize("No Result Found")",
                    "info": '<small>@Localize("Showing") _START_ - _END_ (_TOTAL_)</small>',
                    "infoEmpty": '',
                    "infoFiltered": '',
                    "search": '@Localize("Search")',
                    'paginate': {
                        'previous': '<i class="fa fa-chevron-left"></i>',
                        'next': '<i class="fa fa-chevron-right"></i>'
                    }
                },
                "ordering": false,
                paging: false,
                buttons: [
                    {
                        extend: 'excel',
                        title: fileName,
                        text: '<i title="excel" class="fa fa-file-excel"></i>',
                        className: 'btn',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    },
                    {
                        extend: 'pdf',
                        title: fileName,
                        text: '<i title="pdf" class="fa fa-file-pdf"></i>',
                        className: 'btn',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        },
                        customize: function (doc) {
                            doc.content[1].table.widths =
                                Array(doc.content[1].table.body[0].length + 1).join('*').split('');
                        }
                    },
                    {
                        extend: 'print',
                        title: fileName,
                        text: '<i title="print" class="fa fa-print"></i>',
                        className: 'btn',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    },
                    {
                        extend: 'csv',
                        title: fileName,
                        text: '<i title="csv" class="fa fa-file-csv"></i>',
                        className: 'btn',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    },
                ]
            });
        });
    </script>
}
