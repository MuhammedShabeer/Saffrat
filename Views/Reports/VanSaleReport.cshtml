@model IEnumerable<Saffrat.Models.Order>

@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = Localize("Van Sale Report");
    Layout = "~/Views/Shared/_Layout.cshtml";
    var drivers = (IEnumerable<Saffrat.Models.User>)ViewBag.drivers;
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        @Localize("Van Sale Report")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item">@Localize("Van Sale Report")</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <form asp-action="VanSaleReport" asp-controller="Reports" method="get" class="needs-validation" novalidate="">
                    <div class="row">
                        <div class="col-md-3 form-group">
                            <label class="control-label">@Localize("From") <code>*</code></label>
                            <input type="date" name="start" value="@ViewBag.start" onclick="this.showPicker()" class="form-control" required />
                        </div>
                        <div class="col-md-3 form-group">
                            <label class="control-label">@Localize("To") <code>*</code></label>
                            <input type="date" name="end" value="@ViewBag.end" onclick="this.showPicker()" class="form-control" required />
                        </div>
                        <div class="col-md-3 form-group">
                            <label class="control-label">@Localize("Driver")</label>
                            <select name="driver" class="form-control selectpicker" data-live-search="true">
                                <option value="">@Localize("All Drivers")</option>
                                @foreach (var d in drivers)
                                {
                                    if (ViewBag.driver == d.UserName)
                                    {
                                        <option value="@d.UserName" selected>@d.FullName (@d.UserName)</option>
                                    }
                                    else
                                    {
                                        <option value="@d.UserName">@d.FullName (@d.UserName)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3 form-group">
                            <label class="w-100 d-none d-md-inline-block">&nbsp;</label>
                            <button class="btn btn-primary btn-icon" type="submit"><i class="fas fa-filter"></i> @Localize("Filter")</button>
                        </div>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table table-bordered table-striped" id="exportTable">
                        <thead>
                            <tr>
                                <th>@Localize("Order #")</th>
                                <th>@Localize("Date & Time")</th>
                                <th>@Localize("Customer")</th>
                                <th>@Localize("Driver")</th>
                                <th>@Localize("Total")</th>
                                <th>@Localize("Paid")</th>
                                <th>@Localize("Due")</th>
                                <th>@Localize("Location")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.CreatedAt.ToString("g")</td>
                                    <td>@item.Customer?.CustomerName</td>
                                    <td>@item.ClosedBy</td>
                                    <td>@GetCurrency(item.Total)</td>
                                    <td>@GetCurrency(item.PaidAmount)</td>
                                    <td>@GetCurrency(item.DueAmount)</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Customer?.Latitude) && !string.IsNullOrEmpty(item.Customer?.Longitude))
                                        {
                                            <a href="https://www.google.com/maps/search/?api=1&query=@item.Customer.Latitude,@item.Customer.Longitude" target="_blank" class="btn btn-sm btn-outline-info">
                                                <i class="fas fa-map-marker-alt"></i> @Localize("View Map")
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">@Localize("No GPS")</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/dataTables.buttons.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.html5.min.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.print.min.js"></script>

    <script>
        var fileName = '@Localize("Van Sale Report") (@ViewBag.start @Localize("To") @ViewBag.end)';

        $("#report-menu").addClass("active");
        $("#vanSaleReport-menu").addClass("active");

        $(document).ready(function () {
             $('#exportTable').DataTable({
                dom: 'Bfrtip',
                'language': {
                    "processing": '@Localize("Processing...")',
                    "loadingRecords": "@Localize("Loading...")",
                    'lengthMenu': '@Localize("Show") _MENU_ @Localize("Entries")',
                    "zeroRecords": "@Localize("No Result Found")",
                    "info": '<small>@Localize("Showing") _START_ - _END_ (_TOTAL_)</small>',
                    "search": '@Localize("Search")',
                     'paginate': {
                        'previous': '<i class="fa fa-chevron-left"></i>',
                        'next': '<i class="fa fa-chevron-right"></i>'
                    }
                },
                order: [[1, 'desc']],
                buttons: [
                    {
                        extend: 'excel',
                        title: fileName,
                        text: '<i title="excel" class="fa fa-file-excel"></i>',
                        className: 'btn btn-success p-1 mx-1',
                        exportOptions: { columns: [0, 1, 2, 3, 4, 5, 6] }
                    },
                    {
                        extend: 'pdf',
                        title: fileName,
                        text: '<i title="pdf" class="fa fa-file-pdf"></i>',
                        className: 'btn btn-danger p-1 mx-1',
                        exportOptions: { columns: [0, 1, 2, 3, 4, 5, 6] }
                    },
                    {
                        extend: 'print',
                        title: fileName,
                        text: '<i title="print" class="fa fa-print"></i>',
                        className: 'btn btn-primary p-1 mx-1',
                        exportOptions: { columns: [0, 1, 2, 3, 4, 5, 6] }
                    }
                ]
            });
        });
    </script>
}
