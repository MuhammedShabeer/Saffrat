@model Saffrat.ViewModels.PurchaseComparisonVM
@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Purchase Comparison");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        <i class="fa fa-history me-2 text-primary"></i> @Localize("Purchase Comparison")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item">@Localize("Purchase Comparison")</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0 rounded overflow-hidden">
            <div class="card-body">
                <form asp-action="PurchaseComparison" asp-controller="Reports" method="get" class="mb-4">
                    <div class="row align-items-end g-3">
                        <div class="col-md-5">
                            <label class="form-label small fw-bold text-uppercase text-muted">@Localize("Search Ingredients")</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="fa fa-search text-muted"></i></span>
                                <input type="text" name="search" value="@Model.Search" class="form-control border-start-0" placeholder="@Localize("Ingredient name...")" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-primary px-4 w-100" type="submit">@Localize("Filter")</button>
                        </div>
                    </div>
                </form>

                <div class="table-responsive">
                    <table class="table table-hover align-middle" id="exportTable">
                        <thead class="bg-light border-top border-bottom">
                            <tr>
                                <th class="ps-3">@Localize("Ingredient Name")</th>
                                <th class="text-center">@Localize("Unit")</th>
                                <th class="text-center">@Localize("Latest Purchase")</th>
                                <th>@Localize("Latest Vendor")</th>
                                <th class="text-end pe-3">@Localize("Latest Price")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items.OrderByDescending(x => x.LatestDate))
                            {
                                <tr class="main-row">
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-plus-circle text-primary toggle-details me-3 cursor-pointer" style="font-size: 1.2rem;" title="@Localize("View last 5 purchases")"></i>
                                            <span class="fw-bold h6 mb-0 text-dark">@item.IngredientName</span>
                                        </div>
                                        
                                        <!-- Hidden data for drill-down -->
                                        <div class="details-content d-none">
                                            <div class="p-4 bg-white border rounded shadow-sm my-3 mx-2">
                                                <div class="d-flex justify-content-between align-items-center mb-3">
                                                    <h6 class="fw-bold mb-0 text-primary"><i class="fa fa-list-ul me-2"></i>@Localize("Recent Purchase Records for") @item.IngredientName</h6>
                                                    <span class="badge bg-light text-dark border small">@Localize("Last 5 Entries")</span>
                                                </div>
                                                <div class="table-responsive">
                                                    <table class="table table-sm table-bordered mb-0">
                                                        <thead class="bg-light small">
                                                            <tr>
                                                                <th class="ps-2">@Localize("Date")</th>
                                                                <th>@Localize("Vendor")</th>
                                                                <th class="text-end">@Localize("Qty")</th>
                                                                <th class="text-end">@Localize("Price")</th>
                                                                <th class="text-end pe-2">@Localize("Total")</th>
                                                                <th class="text-center notexport">Action</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @if (item.LastPurchases.Any())
                                                            {
                                                                @foreach (var lp in item.LastPurchases)
                                                                {
                                                                    <tr class="small align-middle">
                                                                        <td class="ps-2">@lp.Date.ToString("yyyy-MM-dd")</td>
                                                                        <td class="text-nowrap">@lp.VendorName</td>
                                                                        <td class="text-end">@lp.Qty.ToString("N2")</td>
                                                                        <td class="text-end fw-bold">@GetCurrency(lp.Price)</td>
                                                                        <td class="text-end pe-2">@GetCurrency(lp.Total)</td>
                                                                        <td class="text-center">
                                                                             <button class="btn btn-link btn-sm p-0" title="View details"><i class="fa fa-external-link-alt small"></i></button>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <tr>
                                                                    <td colspan="6" class="text-center py-4 text-muted small">
                                                                        <i class="fa fa-info-circle me-1"></i> @Localize("No historical purchases found for this ingredient.")
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center"><span class="badge bg-light text-secondary border">@item.Unit</span></td>
                                    <td class="text-center text-muted">
                                        @(item.LatestDate?.ToString("yyyy-MM-dd") ?? "-")
                                    </td>
                                    <td class="text-nowrap">
                                        <span class="text-dark">@item.LatestVendor</span>
                                    </td>
                                    <td class="text-end pe-3">
                                        @if (item.LatestPrice > 0)
                                        {
                                            <span class="fw-bold text-success h6 mb-0">@GetCurrency(item.LatestPrice)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .cursor-pointer { cursor: pointer; }
    .toggle-details:hover { transform: scale(1.2); transition: 0.2s; }
    .main-row.shown { background-color: rgba(0, 123, 255, 0.03) !important; border-left: 3px solid #007bff; }
    #exportTable tbody tr:hover { background-color: rgba(0, 0, 0, 0.01); }
    .table thead th { border-top: none; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; color: #555; }
</style>

@section scripts{
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/dataTables.buttons.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.html5.min.js"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/buttons/2.3.2/js/buttons.print.min.js"></script>

    <script>
        var fileName = '@Localize("Purchase History Report")';

        $("#report-menu").addClass("active");
        $("#purchaseComparison-menu").addClass("active");

        $(document).ready(function () {
            var table = $('#exportTable').DataTable({
                dom: 'Bfrtip',
                'language': {
                    "processing": '@Localize("Processing...")',
                    "loadingRecords": "@Localize("Loading...")",
                    'lengthMenu': '@Localize("Show") _MENU_ @Localize("Entries")',
                    "zeroRecords": "@Localize("No Result Found")",
                    "info": '<small>@Localize("Showing") _START_ - _END_ (_TOTAL_)</small>',
                    "infoEmpty": '',
                    "infoFiltered": '',
                    "search": '@Localize("Search")',
                    'paginate': {
                        'previous': '<i class="fa fa-chevron-left"></i>',
                        'next': '<i class="fa fa-chevron-right"></i>'
                    }
                },
                "ordering": true,
                "order": [[2, "desc"]], // Default sort by Latest Purchase Date
                buttons: [
                    {
                        extend: 'excel',
                        title: fileName,
                        text: '<i title="excel" class="fa fa-file-excel"></i>',
                        className: 'btn btn-outline-success',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    },
                    {
                        extend: 'pdf',
                        orientation: 'portrait',
                        pageSize: 'A4',
                        title: fileName,
                        text: '<i title="pdf" class="fa fa-file-pdf"></i>',
                        className: 'btn btn-outline-danger',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    },
                    {
                        extend: 'print',
                        title: fileName,
                        text: '<i title="print" class="fa fa-print"></i>',
                        className: 'btn btn-outline-info',
                        exportOptions: {
                            columns: ':not(.notexport)'
                        }
                    }
                ]
            });

            // Handle drill-down toggle
            $('#exportTable tbody').on('click', '.toggle-details', function () {
                var tr = $(this).closest('tr');
                var row = table.row(tr);
                var content = tr.find('.details-content').html();

                if (row.child.isShown()) {
                    row.child.hide();
                    tr.removeClass('shown');
                    $(this).removeClass('fa-minus-circle').addClass('fa-plus-circle');
                    $(this).removeClass('text-danger').addClass('text-primary');
                } else {
                    row.child(content).show();
                    tr.addClass('shown');
                    $(this).removeClass('fa-plus-circle').addClass('fa-minus-circle');
                    $(this).removeClass('text-primary').addClass('text-danger');
                }
            });
        });
    </script>
}
