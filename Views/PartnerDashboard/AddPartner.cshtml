@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Add Partner");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>@Localize("Add New Partner")</h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item"><a asp-controller="PartnerDashboard" asp-action="Index">@Localize("Partner Equity")</a></li>
                    <li class="breadcrumb-item">@Localize("Add")</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <form id="partnerForm" class="needs-validation" novalidate="">
                    <div class="form-group mb-3">
                        <label class="control-label">@Localize("Partner Name") <code>*</code></label>
                        <input type="text" name="Name" class="form-control" required />
                    </div>
                    <div class="form-group mb-3">
                        <label class="control-label">@Localize("Contact Info")</label>
                        <input type="text" name="ContactInfo" class="form-control" />
                    </div>
                    <div class="form-group mb-3">
                        <label class="control-label">@Localize("Ownership Percentage (%)")</label>
                        <input type="number" step="0.01" name="OwnershipPercentage" class="form-control" value="0" />
                    </div>
                    <div class="form-group">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i> @Localize("Save Partner")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $("#accounting-engine-menu").addClass("active");
        $("#partner-equity-menu").addClass("active");

        $("#partnerForm").on("submit", function (e) {
            e.preventDefault();
            if (this.checkValidity()) {
                var formData = $(this).serialize();
                $.ajax({
                    url: '/PartnerDashboard/AddPartner',
                    type: 'POST',
                    data: formData,
                    success: function (data) {
                        if (data.status == "success") {
                            successMessage(data.message);
                            window.location.href = '/PartnerDashboard/Index';
                        } else {
                            errorMessage(data.message);
                        }
                    }
                });
            }
            $(this).addClass('was-validated');
        });
    </script>
}
