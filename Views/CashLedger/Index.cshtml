@model IEnumerable<Saffrat.Models.CashLedger>
@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Cash Ledger");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>@Localize("Cash Ledger")</h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item">@Localize("Cash Ledger")</li>
                </ul>
            </div>
            <div class="col">
                <div class="float-end">
                    <a asp-controller="CashLedger" asp-action="Create" class="btn btn-primary">
                        @Localize("Add Transaction")
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <form asp-action="Index" asp-controller="CashLedger" method="get" class="needs-validation" novalidate="">
                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label class="control-label">@Localize("From")</label>
                            <input type="date" name="start" value="@ViewBag.start" onclick="this.showPicker()" class="form-control" />
                        </div>
                        <div class="col-md-4 form-group">
                            <label class="control-label">@Localize("To")</label>
                            <input type="date" name="end" value="@ViewBag.end" onclick="this.showPicker()" class="form-control" />
                        </div>
                        <div class="col-md-4 form-group d-flex align-items-end">
                            <button class="btn btn-primary btn-icon" type="submit"><i class="fas fa-filter"></i> @Localize("Filter")</button>
                        </div>
                    </div>
                </form>
                <div class="table-responsive">
                    <table class="table" id="datatable">
                        <thead>
                            <tr>
                                <th>@Localize("Date")</th>
                                <th>@Localize("Description")</th>
                                <th>@Localize("Type")</th>
                                <th>@Localize("Account")</th>
                                <th>@Localize("Amount")</th>
                                <th>@Localize("Created By")</th>
                                <th>@Localize("Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                    <tr id="row-@item.Id">
                                        <td>@item.EntryDate.ToShortDateString()</td>
                                        <td>@item.Description</td>
                                        <td>
                                        @if (item.Type == "Income")
                                        {
                                                    <span class="badge bg-success">@Localize("Income")</span>
                                        }
                                        else
                                        {
                                                    <span class="badge bg-danger">@Localize("Expense")</span>
                                        }
                                        </td>
                                        <td>@(item.GLAccount?.AccountName ?? "-")</td>
                                        <td>@GetCurrency(item.Amount)</td>
                                        <td>@item.CreatedBy</td>
                                        <td>
                                            <button class="btn btn-sm btn-danger" onclick="Delete(@item.Id)"><i class="fas fa-trash"></i></button>
                                        </td>
                                    </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
        <script>
            $("#cash-ledger-menu").addClass("active");

            $('#datatable').DataTable({
                order: [[0, 'desc']],
                'language': {
                    "search": '@Localize("Search")'
                }
            });

            function Delete(id) {
                $.alert({
                    title: '@Localize("Confirm Delete")',
                    content: '@Localize("Are you sure you want to delete this transaction? This will also reverse the accounting entries.")',
                    rtl: isRTL(),
                    theme: 'modern',
                    buttons: {
                        confirm: {
                            text: '@Localize("Delete")',
                            btnClass: 'btn-danger',
                            action: function () {
                                $.ajax({
                                    url: '/CashLedger/Delete/' + id,
                                    type: 'DELETE',
                                    success: function (data) {
                                        if (data.status == "success") {
                                            successMessage(data.message);
                                            location.reload();
                                        } else {
                                            errorMessage(data.message);
                                        }
                                    }
                                });
                            }
                        },
                        cancel: { text: '@Localize("Cancel")' }
                    }
                });
            }
        </script>
}
