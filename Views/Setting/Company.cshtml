@model Saffrat.Models.AppSetting

@using Saffrat.Resources
@inherits LocService<TModel>

@{
    ViewData["Title"] = @Localize("Company");
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-block">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="page-header-title">
                    <h4>
                        @Localize("Company")
                    </h4>
                </div>
                <ul class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="fa fa-home me-1"></i>@Localize("Home")</a></li>
                    <li class="breadcrumb-item">@Localize("Company")</li>
                </ul>
            </div>
        </div>
    </div>
</div>


<div class="row">
    <div class="col-12">
        <div class="card">
            <form id="frm" class="needs-validation" novalidate="">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="control-label">@Localize("Company Name") <code>*</code></label>
                            <input asp-for="CompanyName" type="text" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please enter company name.")
                            </div>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="control-label">@Localize("Company Phone Number") <code>*</code></label>
                            <input asp-for="CompanyPhone" type="tel" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please enter company phone number.")
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="control-label">@Localize("Company Email") <code>*</code></label>
                            <input asp-for="CompanyEmail" type="text" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please enter company email.")
                            </div>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="control-label">@Localize("Company Tax Number") <code>*</code></label>
                            <input asp-for="CompanyTaxNum" type="text" class="form-control" required />
                            <div class="invalid-feedback">
                                @Localize("Please enter company tax number.")
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="control-label">@Localize("Company Address") <code>*</code></label>
                        <textarea asp-for="CompanyAddress" class="form-control" required></textarea>
                        <div class="invalid-feedback">
                            @Localize("Plase enter company address.")
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <button class="btn btn-primary mr-1" type="submit" id="submit">@Localize("Save Changes")</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts{

    <script>

        $("#setting-menu").addClass("active");
        $("#company-menu").addClass("active");

        $("#frm").submit(function (e) {
            e.preventDefault();
            var formData = new FormData(this);

            if (performValidation($("#frm"))) {
                $("#submit").addClass("disabled btn-progress");
                $.ajax({
                    url: '/Setting/Company',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (data) {
                        if (data.status == "success") {
                            successMessage('@Localize("Company details saved successfully")');
                        }
                        else {
                            errorMessage(data.message);
                        }
                    },
                    error: function (data) {
                        if (data.status == 401) {
                            window.location.href = '/Account/Login';
                        }
                        else if (data.status == 403) {
                            errorMessage('@Localize("Access denied.")');
                        }
                        else {
                            console.log(JSON.stringify(data));
                        }
                    },
                    complete: function () {
                        $("#submit").removeClass("disabled btn-progress");
                        $("#frm").removeClass("was-validated");
                    }
                });
            }
        });
    </script>
}
